tive to rebuild root\n1579\t                    parent.strip_prefix(root).unwrap_or(parent).to_string_lossy().replace('/', \".\")\n1580\t                }\n1581\t            };\n1582\t\n1583\t            let module_id = match module_ids.get(&source_module_name) {\n1584\t                Some(&id) => id,\n1585\t                None => continue,\n1586\t            };\n1587\t\n1588\t            let content = match fs::read_to_string(path) {\n1589\t                Ok(c) => c,\n1590\t                Err(_) => continue,\n1591\t            };\n1592\t\n1593\t            match file_name {\n1594\t                \"pom.xml\" => {\n1595\t                    for caps in maven_dep_re.captures_iter(&content) {\n1596\t                        let artifact_id = caps.get(1).map(|m| m.as_str()).unwrap_or(\"\");\n1597\t                        for (mod_name, &mod_id) in &module_ids {\n1598\t                            let last_segment = mod_name.rsplit('.').next().unwrap_or(mod_name);\n1599\t                            if last_segment == artifact_id {\n1600\t                                dep_stmt.execute(rusqlite::params![module_id, mod_id, \"compile\"])?;\n1601\t                                dep_count += 1;\n1602\t                            }\n1603\t                        }\n1604\t                    }\n1605\t                }\n1606\t                \"ya.make\" => {\n1607\t                    for caps in peerdir_re.captures_iter(&content) {\n1608\t                        let raw = caps.get(1).map(|m| m.as_str()).unwrap_or(\"\");\n1609\t                        for token in raw.split_ascii_whitespace() {\n1610\t                            // Trim trailing comments and separators\n1611\t                            let dep_name = token.trim_end_matches(',').trim();\n1612\t                            if dep_name.is_empty() || dep_name.starts_with('#') {\n1613\t                                continue;\n1614\t                            }\n1615\t                            let dep_name =