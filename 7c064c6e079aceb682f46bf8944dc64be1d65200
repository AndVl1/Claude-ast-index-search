ule_deps row count mismatch — duplicate edge inserted?\");\n3124\t    }\n3125\t\n3126\t    #[test]\n3127\t    fn test_index_deps_python_pyproject() {\n3128\t        let dir = TempDir::new().unwrap();\n3129\t        let root = dir.path();\n3130\t        fs::create_dir_all(root.join(\"libs/shared\")).unwrap();\n3131\t        fs::create_dir_all(root.join(\"services/api\")).unwrap();\n3132\t        fs::write(\n3133\t            root.join(\"libs/shared/pyproject.toml\"),\n3134\t            \"[project]\\nname = \\\"shared\\\"\\n\",\n3135\t        )\n3136\t        .unwrap();\n3137\t        fs::write(\n3138\t            root.join(\"services/api/pyproject.toml\"),\n3139\t            \"[project]\\nname = \\\"api\\\"\\ndependencies = [\\n  \\\"libs.shared>=1.0\\\",\\n  \\\"requests>=2.0\\\",\\n]\\n\",\n3140\t        )\n3141\t        .unwrap();\n3142\t\n3143\t        let mut conn = Connection::open_in_memory().unwrap();\n3144\t        db::init_db(&conn).unwrap();\n3145\t\n3146\t        let files = vec![\n3147\t            root.join(\"libs/shared/pyproject.toml\"),\n3148\t            root.join(\"services/api/pyproject.toml\"),\n3149\t        ];\n3150\t        index_modules_from_files(&conn, root, &files).unwrap();\n3151\t        let dep_count = index_module_dependencies(&mut conn, root, &files, false).unwrap();\n3152\t        // Only the internal dep (libs.shared) should be matched; \"requests\" is external\n3153\t        assert_eq!(dep_count, 1);\n3154\t\n3155\t        let deps = get_module_deps(&conn, \"services.api\").unwrap();\n3156\t        let dep_names: Vec<String> = deps.iter().map(|(n, _, _)| n.clone()).collect();\n3157\t        assert!(dep_names.contains(&\"libs.shared\".to_string()));\n3158\t    }\n3159\t\n3160\t    #[test]\n3161\t    fn test_index_deps_python_poetry() {\n3162\t        let dir = TempDir::new().unwrap();\n3163\t        let root = dir.path();\n3164\t        fs::create_dir_all(root.join(\"libs/core\")).unwrap();\n3165\t        fs::create_dir_all(root.joi