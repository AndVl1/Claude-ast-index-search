 static XML_REF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"@(drawable|string|color|dimen|style|layout|id|mipmap)/([a-zA-Z_][a-zA-Z0-9_]*)\"#).unwrap());\n1914\t\n1915\t    let xml_ref_re = &*XML_REF_RE;\n1916\t\n1917\t    // Resource definitions regex for values/*.xml\n1918\t    static STRING_DEF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"<string\\s+name=\"([^\"]+)\"\"#).unwrap());\n1919\t\n1920\t    let string_def_re = &*STRING_DEF_RE;\n1921\t    static COLOR_DEF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"<color\\s+name=\"([^\"]+)\"\"#).unwrap());\n1922\t\n1923\t    let color_def_re = &*COLOR_DEF_RE;\n1924\t    static DIMEN_DEF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"<dimen\\s+name=\"([^\"]+)\"\"#).unwrap());\n1925\t\n1926\t    let dimen_def_re = &*DIMEN_DEF_RE;\n1927\t    static STYLE_DEF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"<style\\s+name=\"([^\"]+)\"\"#).unwrap());\n1928\t\n1929\t    let style_def_re = &*STYLE_DEF_RE;\n1930\t\n1931\t    {\n1932\t        let mut res_stmt = tx.prepare_cached(\n1933\t            \"INSERT INTO resources (module_id, type, name, file_path, line) VALUES (?1, ?2, ?3, ?4, ?5)\"\n1934\t        )?;\n1935\t\n1936\t        // First pass: index resource definitions\n1937\t        for res_path in res_files {\n1938\t            let rel_path = res_path\n1939\t                .strip_prefix(root)\n1940\t                .unwrap_or(res_path)\n1941\t                .to_string_lossy()\n1942\t                .to_string();\n1943\t\n1944\t            let module_id = module_lookup.find(&rel_path);\n1945\t\n1946\t            // Drawable files\n1947\t            if rel_path.contains(\"/drawable\") || rel_path.contains(\"/mipmap\") {\n1948\t                if let Some(name) = res_path.file_stem().and_then(|n| n.to_str()) {\n1949\t                    let res_type = if rel_path.contains(\"/mipmap\") { \"mipmap\" } else { \"drawable\" };\n1950\t                    res_stmt.execute(rusqlite::params![module_id, res_type, name, rel_path, 1])?;\n1951\t                    resource_count += 1;\n1952\t                }\n1953\t            }\n1954\t\n1955\t            // Layout files\n1956\t            if rel_path.contains(\"/layout\") && rel_path.ends_with(\".xml\") {\n1957\t                if let Some(name) = res_path.file_stem().and_then(|n| n.to_str()) {\n1958\t                    res_stmt.execute(rusqlite::params![module_id, \"layout\", name, rel_path, 1])?;\n1959\t                    resource_count += 1;\n1960\t                }\n1961\t            }\n1962\t\n1963\t            // Values files (strings, colors, dimens, styles)\n1964\t            if rel_path.contains(\"/values\") && rel_path.ends_with(\".xml\") {\n1965\t                if let Ok(content) = fs::read_to_string(res_path) {\n1966\t                    for (line_num, line) in content.lines().enumerate() {\n1967\t                        let line_num = line_num + 1;\n1968\t\n1969\t                        if let Some(caps) = string_def_re.captures(line) {\n1970\t                            let name = caps.get(1).unwrap().as_str();\n1971\t                            res_stmt.execute(rusqlite::params![module_id, \"string\", name, rel_path, line_num as i64])?;\n1972\t                            resource_count += 1;\n1973\t                        }\n1974\t                        if let Some(caps) = color_def_re.captures(line) {\n1975\t                            let name = caps.get(1).unwrap().as_str();\n1976\t                            res_stmt.execute(rusqlite::params![module_id, \"color\", name, rel_path, line_num as i64])?;\n1977\t                            resource_count += 1;\n1978\t                        }\n1979\t                        if let Some(caps) = dimen_def_re.captures(line) {\n1980\t                            let name = caps.get(1).unwrap().as_str();\n1981\t                            res_stmt.execute(rusqlite::params![module_id, \"dimen\", name, rel_path, line_num as i64])?;\n1982\t                            resource_count += 1;\n1983\t                        }\n1984\t                        if let Some(caps) = style_def_re.captures(line) {\n1985\t                            let name = caps.get(1).unwrap().as_str();\n1986\t                            res_stmt.execute(rusqlite::params![module_id, \"style\", name, rel_path, line_num as i64])?;\n1987\t                            resource_count += 1;\n1988\t                        }\n1989\t                    }\n1990\t                }\n1991\t            }\n1992\t        }\n1993\t    }\n1994\t\n1995\t    // Build resource ID map: type -> name -> id (two-level for allocation-free lookup)\n1996\t    let resource_ids: std::collections::HashMap<String, std::collections::HashMap<String, i64>> = {\n1997\t        let mut stmt = tx.prepare(\"SELECT id, type, name FROM resources\")?;\n1998\t        let rows = stmt.query_map([], |row| {\n1999\t            Ok((row.get::<_, i64>(0)?, row.get::<_, String>(1)?, row.get::<_, String>(2)?))\n2000\t        })?;\n2001\t        let mut map: std::collections::HashMap<String, std::collections::HashMap<String, i64>> = std::collections::HashMap::new();\n2002\t        for row in rows {\n2003\t            let (id, res_type, name) = row?;\n2004\t            map.entry(res_type).or_default().insert(name, id);\n2005\t        }\n2006\t        map\n2007\t    };\n2008\t\n2009\t    // Second pass: index resource usages\n2010\t    {\n2011\t        let mut usage_stmt = tx.prepare_cached(\n2012\t            \"INSERT INTO resource_usages (resource_id, usage_file, usage_line, usage_type) VALUES (?1, ?2, ?3, ?4)\"\n2013\t        )?;\n2014\t\n2015\t        // Query code files from DB instead of walking filesystem again\n2016\t        let code_rel_paths: Vec<String> = {\n2017\t            let mut stmt = tx.prepare(\"SELECT path FROM files WHERE path LIKE '%.kt' OR path LIKE '%.java' OR path LIKE '%.xml'\")?;\n2018\t            let rows = stmt.query_map([], |row| row.get::<_, String>(0))?;\n2019\t            rows.filter_map(|r| r.ok()).collect()\n2020\t        };\n2021\t\n2022\t        for rel_path in &code_rel_paths {\n2023\t            let file_path = root.join(rel_path);\n2024\t\n2025\t            if let Ok(content) = fs::read_to_string(file_path) {\n2026\t                let is_xml = rel_path.ends_with(\".xml\");\n2027\t\n2028\t                for (line_num, line) in content.lines().enumerate() {\n2029\t                    let line_num = line_num + 1;\n2030\t\n2031\t                    // R.type.name references (Kotlin/Java)\n2032\t                    if !is_xml {\n2033\t                        for caps in r_ref_re.captures_iter(line) {\n2034\t                            let res_type = caps.get(1).unwrap().as_str();\n2035\t                            let res_name = caps.get(2).unwrap().as_str();\n2036\t\n2037\t                            if let Some(&resource_id) = resource_ids.get(res_type).and_then(|m| m.get(res_name)) {\n2038\t                                usage_stmt.execute(rusqlite::params![resource_id, rel_path, line_num as i64, \"code\"])?;\n2039\t                                usage_count += 1;\n2040\t                            }\n2041\t                        }\n2042\t                    }\n2043\t\n2044\t                    // @type/name references (XML)\n2045\t                    for caps in xml_ref_re.captures_iter(line) {\n2046\t                        let res_type = caps.get(1).unwrap().as_str();\n2047\t                        let res_name = caps.get(2).unwrap().as_str();\n2048\t\n2049\t                        if let Some(&resource_id) = resource_ids.get(res_type).and_then(|m| m.get(res_name)) {\n2050\t                            usage_stmt.execute(rusqlite::params![resource_id, rel_path, line_num as i64, \"xml\"])?;\n2051\t                            usage_count += 1;\n2052\t                        }\n2053\t                    }\n2054\t                }\n2055\t            }\n2056\t        }\n2057\t    }\n2058\t\n2059\t    tx.commit()?;\n2060\t\n2061\t    Ok((resource_count, usage_count))\n2062\t}\n2063\t\n2064\t/// Build transitive dependencies cache\n2065\tpub fn build_transitive_deps(conn: &mut Connection, progress: bool) -> Result<usize> {\n2066\t    // Get all direct dependencies\n2067\t    let direct_deps: Vec<(i64, i64, String)> = {\n2068\t        let mut stmt = conn.prepare(\"SELECT module_id, dep_module_id, dep_kind FROM module_deps\")?;\n2069\t        let rows = stmt.query_map([], |row| {\n2070\t            Ok((row.get(0)?, row.get(1)?, row.get(2)?))\n2071\t        })?;\n2072\t        rows.collect::<Result<Vec<_>, _>>()?\n2073\t    };\n2074\t\n2075\t    // Get module names\n2076\t    let module_names: std::collections::HashMap<i64, String> = {\n2077\t        let mut stmt = conn.prepare(\"SELECT id, name FROM modules\")?;\n2078\t        let rows = stmt.query_map([], |row| {\n2079\t            Ok((row.get::<_, i64>(0)?, row.get::<_, String>(1)?))\n2080\t        })?;\n2081\t        let mut map = std::collections::HashMap::new();\n2082\t        for row in rows {\n2083\t            let (id, name) = row?;\n2084\t            map.insert(id, name);\n2085\t        }\n2086\t        map\n2087\t    };\n2088\t\n2089\t    // Build adjacency list (only api dependencies create transitive access)\n2090\t    let mut api_deps: std::collections::HashMap<i64, Vec<i64>> = std::collections::HashMap::new();\n2091\t    for (module_id, dep_id, dep_kind) in &direct_deps {\n2092\t        if dep_kind == \"api\" {\n2093\t            api_deps.entry(*module_id).or_default().push(*dep_id);\n2094\t        }\n2095\t    }\n2096\t\n2097\t    let tx = conn.transaction()?;\n2098\t\n2099\t    // Clear existing\n2100\t    tx.execute(\"DELETE FROM transitive_deps\", [])?;\n2101\t\n2102\t    let mut count = 0;\n2103\t    {\n2104\t        let mut stmt = tx.prepare_cached(\n2105\t            \"INSERT INTO transitive_deps (module_id, dependency_id, depth, path) VALUES (?1, ?2, ?3, ?4)\"\n2106\t        )?;\n2107\t\n2108\t        let unknown = \"?\";\n2109\t\n2110\t        // For each module, BFS to find all transitive dependencies\n2111\t        for (module_id, dep_id, _) in &direct_deps {\n2112\t            let mod_name = module_names.get(module_id).map(|s| s.as_str()).unwrap_or(unknown);\n2113\t            let dep_name = module_names.get(dep_id).map(|s| s.as_str()).unwrap_or(unknown);\n2114\t\n2115\t            // Direct dependency\n2116\t            let path = format!(\"{} -> {}\", mod_name, dep_name);\n2117\t            stmt.execute(rusqlite::params![module_id, dep_id, 1, path])?;\n2118\t            count += 1;\n2119\t\n2120\t            // BFS for transitive (only through api deps)\n2121\t            let mut visited: std::collections::HashSet<i64> = std::collections::HashSet::new();\n2122\t            visited.insert(*dep_id);\n2123\t            let mut queue: std::collections::VecDeque<(i64, usize, String)> = std::collections::VecDeque::new();\n2124\t\n2125\t            // Add api dependencies of dep_id\n2126\t            if let Some(next_deps) = api_deps.get(dep_id) {\n2127\t                for &next_dep in next_deps {\n2128\t                    let next_name = module_names.get(&next_dep).map(|s| s.as_str()).unwrap_or(unknown);\n2129\t                    let next_path = format!(\"{} -> {} -> {}\", mod_name, dep_name, next_name);\n2130\t                    queue.push_back((next_dep, 2, next_path));\n2131\t                }\n2132\t            }\n2133\t\n2134\t            while let Some((trans_dep, depth, path)) = queue.pop_front() {\n2135\t                if visited.contains(&trans_dep) || depth > 5 {\n2136\t                    continue;\n2137\t                }\n2138\t                visited.insert(trans_dep);\n2139\t\n2140\t                stmt.execute(rusqlite::params![module_id, trans_dep, depth as i64, path])?;\n2141\t                count += 1;\n2142\t\n2143\t                // Continue BFS\n2144\t                if let Some(next_deps) = api_deps.get(&trans_dep) {\n2145\t                    for &next_dep in next_deps {\n2146\t                        if !visited.contains(&next_dep) {\n2147\t                            let next_name = module_names.get(&next_dep).map(|s| s.as_str()).unwrap_or(unknown);\n2148\t                            let next_path = format!(\"{} -> {}\", path, next_name);\n2149\t                            queue.push_back((next_dep, depth + 1, next_path));\n2150\t                        }\n2151\t                    }\n2152\t                }\n2153\t            }\n2154\t        }\n2155\t    }\n2156\t\n2157\t    tx.commit()?;\n2158\t\n2159\t    if progress {\n2160\t        eprintln!(\"Built {} transitive dependency entries\", count);\n2161\t    }\n2162\t\n2163\t    Ok(count)\n2164\t}\n2165\t\n2166\t/// Parsed iOS Storyboard/XIB usage\n2167\t#[derive(Debug)]\n2168\tpub struct StoryboardUsage {\n2169\t    pub file_path: String,\n2170\t    pub line: usize,\n2171\t    pub class_name: String,\n2172\t    pub usage_type: String, // \"viewController\", \"view\", \"cell\", \"segue\"\n2173\t    pub storyboard_id: Option<String>,\n2174\t}\n2175\t\n2176\t/// Index iOS storyboard and XIB files for class usages\n2177\tpub fn index_storyboard_usages(conn: &mut Connection, root: &Path, storyboard_files: &[PathBuf], progress: bool) -> Result<usize> {\n2178\t    let module_lookup = ModuleLookup::from_db(conn)?;\n2179\t\n2180\t    // Regex for customClass in storyboards/xibs\n2181\t    // <viewController customClass=\"MyViewController\" ...>\n2182\t    static CUSTOM_CLASS_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"customClass\\s*=\\s*[\"']([A-Z][a-zA-Z0-9_]+)[\"']\"#).unwrap());\n2183\t\n2184\t    let custom_class_re = &*CUSTOM_CLASS_RE;\n2185\t    // storyboardIdentifier=\"...\"\n2186\t    static STORYBOARD_ID_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"(?:storyboardIdentifier|identifier)\\s*=\\s*[\"']([^\"']+)[\"']\"#).unwrap());\n2187\t\n2188\t    let storyboard_id_re = &*STORYBOARD_ID_RE;\n2189\t\n2190\t    if progress {\n2191\t        eprintln!(\"Found {} storyboard/xib files to index...\", storyboard_files.len());\n2192\t    }\n2193\t\n2194\t    let tx = conn.transaction()?;\n2195\t\n2196\t    // Clear existing storyboard usages\n2197\t    tx.execute(\"DELETE FROM storyboard_usages\", [])?;\n2198\t\n2199\t    let mut count = 0;\n2200\t    {\n2201\t        let mut stmt = tx.prepare_cached(\n2202\t            \"INSERT INTO storyboard_usages (module_id, file_path, line, class_name, usage_type, storyboard_id) VALUES (?1, ?2, ?3, ?4, ?5, ?6)\"\n2203\t        )?;\n2204\t\n2205\t        for sb_path in storyboard_files {\n2206\t            let rel_path = sb_path\n2207\t                .strip_prefix(root)\n2208\t                .unwrap_or(sb_path)\n2209\t                .to_string_lossy()\n2210\t                .to_string();\n2211\t\n2212\t            // Find module for this file\n2213\t            let module_id = module_lookup.find(&rel_path);\n2214\t\n2215\t            if let Ok(content) = fs::read_to_string(sb_path) {\n2216\t                for (line_num, line) in content.lines().enumerate() {\n2217\t                    let line_num = line_num + 1;\n2218\t\n2219\t                    // Extract storyboard identifier if present\n2220\t                    let sb_id = storyboard_id_re.captures(line).map(|c| c.get(1).unwrap().as_str().to_string());\n2221\t\n2222\t                    // Extract custom classes\n2223\t                    if let Some(caps) = custom_class_re.captures(line) {\n2224\t                        let class_name = caps.get(1).unwrap().as_str();\n2225\t\n2226\t                        // Determine usage type based on element\n2227\t                        let usage_type = if line.contains(\"<viewController\") || line.contains(\"<tableViewController\") || line.contains(\"<collectionViewController\") || line.contains(\"<navigationController\") || line.contains(\"<tabBarController\") {\n2228\t                            \"viewController\"\n2229\t                        } else if line.contains(\"<tableViewCell\") || line.contains(\"<collectionViewCell\") {\n2230\t                            \"cell\"\n2231\t                        } else if line.contains(\"<view\") || line.contains(\"<View\") {\n2232\t                            \"view\"\n2233\t                        } else {\n2234\t                            \"other\"\n2235\t                        };\n2236\t\n2237\t                        stmt.execute(rusqlite::params![\n2238\t                            module_id,\n2239\t                            rel_path,\n2240\t                            line_num as i64,\n2241\t                            class_name,\n2242\t                            usage_type,\n2243\t                            sb_id\n2244\t                        ])?;\n2245\t                        count += 1;\n2246\t                    }\n2247\t                }\n2248\t            }\n2249\t        }\n2250\t    }\n2251\t\n2252\t    tx.commit()?;\n2253\t\n2254\t    if progress {\n2255\t        eprintln!(\"Indexed {} storyboard/xib class usages\", count);\n2256\t    }\n2257\t\n2258\t    Ok(count)\n2259\t}\n2260\t\n2261\t/// iOS Asset type\n2262\t#[derive(Debug, Clone, PartialEq)]\n2263\tpub enum IosAssetType {\n2264\t    ImageSet,\n2265\t    ColorSet,\n2266\t    AppIcon,\n2267\t    LaunchImage,\n2268\t    DataSet,\n2269\t    Other(String),\n2270\t}\n2271\t\n2272\timpl IosAssetType {\n2273\t    pub fn as_str(&self) -> &str {\n2274\t        match self {\n2275\t            IosAssetType::ImageSet => \"imageset\",\n2276\t            IosAssetType::ColorSet => \"colorset\",\n2277\t            IosAssetType::AppIcon => \"appiconset\",\n2278\t            IosAssetType::LaunchImage => \"launchimage\",\n2279\t            IosAssetType::DataSet => \"dataset\",\n2280\t            IosAssetType::Other(s) => s,\n2281\t        }\n2282\t    }\n2283\t\n2284\t    pub fn from_extension(ext: &str) -> Self {\n2285\t        match ext {\n2286\t            \"imageset\" => IosAssetType::ImageSet,\n2287\t            \"colorset\" => IosAssetType::ColorSet,\n2288\t            \"appiconset\" => IosAssetType::AppIcon,\n2289\t            \"launchimage\" => IosAssetType::LaunchImage,\n2290\t            \"dataset\" => IosAssetType::DataSet,\n2291\t            other => IosAssetType::Other(other.to_string()),\n2292\t        }\n2293\t    }\n2294\t}\n2295\t\n2296\t/// Index iOS Assets.xcassets\n2297\tpub fn index_ios_assets(conn: &mut Connection, root: &Path, xcassets_dirs: &[PathBuf], progress: bool) -> Result<(usize, usize)> {\n2298\t    use ignore::WalkBuilder;\n2299\t\n2300\t    let module_lookup = ModuleLookup::from_db(conn)?;\n2301\t\n2302\t    if progress {\n2303\t        eprintln!(\"Found {} .xcassets directories...\", xcassets_dirs.len());\n2304\t    }\n2305\t\n2306\t    let tx = conn.transaction()?;\n2307\t\n2308\t    // Clear existing iOS assets\n2309\t    tx.execute(\"DELETE FROM ios_asset_usages\", [])?;\n2310\t    tx.execute(\"DELETE FROM ios_assets\", [])?;\n2311\t\n2312\t    let mut asset_count = 0;\n2313\t    let mut usage_count = 0;\n2314\t\n2315\t    {\n2316\t        let mut asset_stmt = tx.prepare_cached(\n2317\t            \"INSERT INTO ios_assets (module_id, type, name, file_path) VALUES (?1, ?2, ?3, ?4)\"\n2318\t        )?;\n2319\t\n2320\t        // Index assets from .xcassets directories\n2321\t        for xcassets_dir in xcassets_dirs {\n2322\t            let rel_xcassets = xcassets_dir\n2323\t                .strip_prefix(root)\n2324\t                .unwrap_or(xcassets_dir)\n2325\t                .to_string_lossy()\n2326\t                .to_string();\n2327\t\n2328\t            let module_id = module_lookup.find(&rel_xcassets);\n2329\t\n2330\t            // Walk inside xcassets to find imagesets, colorsets, etc.\n2331\t            let inner_walker = WalkBuilder::new(xcassets_dir)\n2332\t                .hidden(false)\n2333\t                .build();\n2334\t\n2335\t            for entry in inner_walker {\n2336\t                if let Ok(entry) = entry {\n2337\t                    let path = entry.path();\n2338\t                    if path.is_dir() {\n2339\t                        if let Some(ext) = path.extension().and_then(|e| e.to_str()) {\n2340\t                            if matches!(ext, \"imageset\" | \"colorset\" | \"appiconset\" | \"launchimage\" | \"dataset\") {\n2341\t                                if let Some(name) = path.file_stem().and_then(|n| n.to_str()) {\n2342\t                                    let rel_path = path\n2343\t                                        .strip_prefix(root)\n2344\t                                        .unwrap_or(path)\n2345\t                                        .to_string_lossy()\n2346\t                                        .to_string();\n2347\t\n2348\t                                    let asset_type = IosAssetType::from_extension(ext);\n2349\t                                    asset_stmt.execute(rusqlite::params![\n2350\t                                        module_id,\n2351\t                                        asset_type.as_str(),\n2352\t                                        name,\n2353\t                                        rel_path\n2354\t                                    ])?;\n2355\t                                    asset_count += 1;\n2356\t                                }\n2357\t                            }\n2358\t                        }\n2359\t                    }\n2360\t                }\n2361\t            }\n2362\t        }\n2363\t    }\n2364\t\n2365\t    // Build asset ID map\n2366\t    let asset_ids: std::collections::HashMap<String, i64> = {\n2367\t        let mut stmt = tx.prepare(\"SELECT id, name FROM ios_assets\")?;\n2368\t        let rows = stmt.query_map([], |row| {\n2369\t            Ok((row.get::<_, String>(1)?, row.get::<_, i64>(0)?))\n2370\t        })?;\n2371\t        let mut map = std::collections::HashMap::new();\n2372\t        for row in rows {\n2373\t            let (name, id) = row?;\n2374\t            map.insert(name, id);\n2375\t        }\n2376\t        map\n2377\t    };\n2378\t\n2379\t    // Index asset usages in Swift code\n2380\t    // UIImage(named: \"assetName\") or Image(\"assetName\") or Color(\"colorName\")\n2381\t    static SWIFT_IMAGE_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"(?:UIImage\\s*\\(\\s*named:\\s*[\"']|Image\\s*\\(\\s*[\"']|\\.image\\s*\\(\\s*named:\\s*[\"'])([^\"']+)[\"']\"#).unwrap());\n2382\t\n2383\t    let swift_image_re = &*SWIFT_IMAGE_RE;\n2384\t    static SWIFT_COLOR_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"(?:UIColor\\s*\\(\\s*named:\\s*[\"']|Color\\s*\\(\\s*[\"'])([^\"']+)[\"']\"#).unwrap());\n2385\t\n2386\t    let swift_color_re = &*SWIFT_COLOR_RE;\n2387\t\n2388\t    {\n2389\t        let mut usage_stmt = tx.prepare_cached(\n2390\t            \"INSERT INTO ios_asset_usages (asset_id, usage_file, usage_line, usage_type) VALUES (?1, ?2, ?3, ?4)\"\n2391\t        )?;\n2392\t\n2393\t        // Query swift files from DB instead of walking filesystem again\n2394\t        let swift_rel_paths: Vec<String> = {\n2395\t            let mut stmt = tx.prepare(\"SELECT path FROM files WHERE path LIKE '%.swift'\")?;\n2396\t            let rows = stmt.query_map([], |row| row.get::<_, String>(0))?;\n2397\t            rows.filter_map(|r| r.ok()).collect()\n2398\t        };\n2399\t\n2400\t        for rel_path in &swift_rel_paths {\n2401\t            let file_path = root.join(rel_path);\n2402\t\n2403\t            if let Ok(content) = fs::read_to_string(file_path) {\n2404\t                for (line_num, line) in content.lines().enumerate() {\n2405\t                    let line_num = line_num + 1;\n2406\t\n2407\t                    // Image references\n2408\t                    for caps in swift_image_re.captures_iter(line) {\n2409\t                        let asset_name = caps.get(1).unwrap().as_str();\n2410\t                        if let Some(&asset_id) = asset_ids.get(asset_name) {\n2411\t                            usage_stmt.execute(rusqlite::params![asset_id, rel_path, line_num as i64, \"code\"])?;\n2412\t                            usage_count += 1;\n2413\t                        }\n2414\t                    }\n2415\t\n2416\t                    // Color references\n2417\t                    for caps in swift_color_re.captures_iter(line) {\n2418\t                        let asset_name = caps.get(1).unwrap().as_str();\n2419\t                        if let Some(&asset_id) = asset_ids.get(asset_name) {\n2420\t                            usage_stmt.execute(rusqlite::params![asset_id, rel_path, line_num as i64, \"code\"])?;\n2421\t                            usage_count += 1;\n2422\t                        }\n2423\t                    }\n2424\t                }\n2425\t            }\n2426\t        }\n2427\t    }\n2428\t\n2429\t    tx.commit()?;\n2430\t\n2431\t    if progress {\n2432\t        eprintln!(\"Indexed {} iOS assets, {} usages\", asset_count, usage_count);\n2433\t    }\n2434\t\n2435\t    Ok((asset_count, usage_count))\n2436\t}\n2437\t\n2438\t/// Index CocoaPods and Carthage dependencies\n2439\tpub fn index_ios_package_managers(conn: &Connection, root: &Path, progress: bool) -> Result<usize> {\n2440\t    let mut count = 0;\n2441\t\n2442\t    // CocoaPods: Podfile\n2443\t    let podfile = root.join(\"Podfile\");\n2444\t    if podfile.exists() {\n2445\t        if let Ok(content) = fs::read_to_string(&podfile) {\n2446\t            // pod 'PodName', '~> 1.0'\n2447\t            static POD_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"pod\\s+['\"]([^'\"]+)['\"]\"#).unwrap());\n2448\t\n2449\t            let pod_re = &*POD_RE;\n2450\t\n2451\t            for caps in pod_re.captures_iter(&content) {\n2452\t                let pod_name = caps.get(1).unwrap().as_str();\n2453\t                conn.execute(\n2454\t                    \"INSERT OR IGNORE INTO modules (name, path, kind) VALUES (?1, ?2, ?3)\",\n2455\t                    rusqlite::params![format!(\"pod.{}\", pod_name), \"Pods\", \"cocoapods\"],\n2456\t                )?;\n2457\t                count += 1;\n2458\t            }\n2459\t        }\n2460\t    }\n2461\t\n2462\t    // Podfile.lock for exact versions\n2463\t    let podfile_lock = root.join(\"Podfile.lock\");\n2464\t    if podfile_lock.exists() {\n2465\t        if let Ok(content) = fs::read_to_string(&podfile_lock) {\n2466\t            // PODS:\n2467\t            //   - PodName (1.0.0)\n2468\t            static POD_LOCK_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"^\\s+-\\s+([A-Za-z0-9_-]+)\\s+\\(\"#).unwrap());\n2469\t\n2470\t            let pod_lock_re = &*POD_LOCK_RE;\n2471\t\n2472\t            for line in content.lines() {\n2473\t                if let Some(caps) = pod_lock_re.captures(line) {\n2474\t                    let pod_name = caps.get(1).unwrap().as_str();\n2475\t                    conn.execute(\n2476\t                        \"INSERT OR IGNORE INTO modules (name, path, kind) VALUES (?1, ?2, ?3)\",\n2477\t                        rusqlite::params![format!(\"pod.{}\", pod_name), \"Pods\", \"cocoapods\"],\n2478\t                    )?;\n2479\t                    count += 1;\n2480\t                }\n2481\t            }\n2482\t        }\n2483\t    }\n2484\t\n2485\t    // Carthage: Cartfile\n2486\t    let cartfile = root.join(\"Cartfile\");\n2487\t    if cartfile.exists() {\n2488\t        if let Ok(content) = fs::read_to_string(&cartfile) {\n2489\t            // github \"owner/repo\" ~> 1.0\n2490\t            static CARTHAGE_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"github\\s+[\"']([^\"']+)[\"']\"#).unwrap());\n2491\t\n2492\t            let carthage_re = &*CARTHAGE_RE;\n2493\t\n2494\t            for caps in carthage_re.captures_iter(&content) {\n2495\t                let repo = caps.get(1).unwrap().as_str();\n2496\t                let name = repo.split('/').last().unwrap_or(repo);\n2497\t                conn.execute(\n2498\t                    \"INSERT OR IGNORE INTO modules (name, path, kind) VALUES (?1, ?2, ?3)\",\n2499\t                    rusqlite::params![format!(\"carthage.{}\", name), \"Carthage/Build\", \"carthage\"],\n2500\t                )?;\n2501\t                count += 1;\n2502\t            }\n2503\t        }\n2504\t    }\n2505\t\n2506\t    // Carthage.resolved for exact versions\n2507\t    let cartfile_resolved = root.join(\"Cartfile.resolved\");\n2508\t    if cartfile_resolved.exists() {\n2509\t        if let Ok(content) = fs::read_to_string(&cartfile_resolved) {\n2510\t            static CARTHAGE_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"github\\s+[\"']([^\"']+)[\"']\"#).unwrap());\n2511\t\n2512\t            let carthage_re = &*CARTHAGE_RE;\n2513\t\n2514\t            for caps in carthage_re.captures_iter(&content) {\n2515\t                let repo = caps.get(1).unwrap().as_str();\n2516\t                let name = repo.split('/').last().unwrap_or(repo);\n2517\t                conn.execute(\n2518\t                    \"INSERT OR IGNORE INTO modules (name, path, kind) VALUES (?1, ?2, ?3)\",\n2519\t                    rusqlite::params![format!(\"carthage.{}\", name), \"Carthage/Build\", \"carthage\"],\n2520\t                )?;\n2521\t                count += 1;\n2522\t            }\n2523\t        }\n2524\t    }\n2525\t\n2526\t    if progress {\n2527\t        eprintln!(\"Indexed {} CocoaPods/Carthage dependencies\", count);\n2528\t    }\n2529\t\n2530\t    Ok(count)\n2531\t}\n2532\t\n2533\t/// Index .d.ts files from node_modules (type declarations for external libraries).\n2534\t/// These provide symbol definitions for imported libraries (e.g., React, lodash).\n2535\t/// Only .d.ts files are indexed — not full JS/TS source from node_modules.\n2536\t///\n2537\t/// Handles pnpm (symlinks to store) by resolving top-level package symlinks\n2538\t/// and mapping paths back to node_modules/... for storage.\n2539\t/// Does NOT use follow_links to avoid loops on FUSE mounts (Arcadia).\n2540\tpub fn index_node_modules_dts(conn: &mut Connection, root: &Path, progress: bool) -> Result<usize> {\n2541\t    use ignore::WalkBuilder;\n2542\t    use std::sync::atomic::{AtomicUsize, Ordering};\n2543\t    use std::time::Instant;\n2544\t\n2545\t    let node_modules = root.join(\"node_modules\");\n2546\t    if !node_modules.exists() || !node_modules.is_dir() {\n2547\t        return Ok(0);\n2548\t    }\n2549\t\n2550\t    let verbose = std::env::var(\"AST_INDEX_VERBOSE\").is_ok();\n2551\t\n2552\t    if progress {\n2553\t        eprintln!(\"Scanning node_modules for .d.ts type declarations...\");\n2554\t    }\n2555\t\n2556\t    let walk_start = Instant::now();\n2557\t\n2558\t    // Collect (resolved_dir, node_modules_prefix) pairs.\n2559\t    // Resolves symlinks only at the package level (safe for pnpm).\n2560\t    // E.g.: (resolved_path, \"node_modules/@types/react\")\n2561\t    let mut pkg_map: Vec<(PathBuf, String)> = Vec::new();\n2562\t\n2563\t    if let Ok(entries) = fs::read_dir(&node_modules) {\n2564\t        for entry in entries.filter_map(|e| e.ok()) {\n2565\t            let path = entry.path();\n2566\t            let name_str = entry.file_name().to_string_lossy().to_string();\n2567\t\n2568\t            if name_str.starts_with('.') {\n2569\t                continue;\n2570\t            }\n2571\t\n2572\t            if name_str.starts_with('@') {\n2573\t                // Scoped packages: enumerate @scope/pkg\n2574\t                let scope_dir = fs::canonicalize(&path).unwrap_or(path);\n2575\t                if let Ok(scoped) = fs::read_dir(&scope_dir) {\n2576\t                    for sub in scoped.filter_map(|e| e.ok()) {\n2577\t                        let sub_name = sub.file_name().to_string_lossy().to_string();\n2578\t                        let sub_resolved = fs::canonicalize(sub.path())\n2579\t                            .unwrap_or_else(|_| sub.path());\n2580\t                        if sub_resolved.is_dir() {\n2581\t                            let prefix = format!(\"node_modules/{}/{}\", name_str, sub_name);\n2582\t                            pkg_map.push((sub_resolved, prefix));\n2583\t                        }\n2584\t                    }\n2585\t                }\n2586\t            } else {\n2587\t                let resolved = fs::canonicalize(&path).unwrap_or(path);\n2588\t                if resolved.is_dir() {\n2589\t                    let prefix = format!(\"node_modules/{}\", name_str);\n2590\t                    pkg_map.push((resolved, prefix));\n2591\t                }\n2592\t            }\n2593\t        }\n2594\t    }\n2595\t\n2596\t    if verbose {\n2597\t        eprintln!(\"[verbose] found {} package dirs in node_modules\", pkg_map.len());\n2598\t    }\n2599\t\n2600\t    // Walk each resolved package dir for .d.ts files.\n2601\t    // follow_links=false — already resolved top-level symlinks.\n2602\t    // Store (abs_path, rel_path) pairs for correct DB storage.\n2603\t    let mut dts_files: Vec<(PathBuf, String)> = Vec::new();\n2604\t\n2605\t    for (pkg_dir, nm_prefix) in &pkg_map {\n2606\t        let mut builder = WalkBuilder::new(pkg_dir);\n2607\t        builder\n2608\t            .hidden(false)\n2609\t            .git_ignore(false)\n2610\t            .git_exclude(false)\n2611\t            .follow_links(false)\n2612\t            .max_depth(Some(8))\n2613\t            .filter_entry(|entry| {\n2614\t                if entry.file_type().map(|ft| ft.is_dir()).unwrap_or(false) {\n2615\t                    if let Some(name) = entry.file_name().to_str() {\n2616\t                        if name == \"node_modules\" || name.starts_with('.') {\n2617\t                            return false;\n2618\t                        }\n2619\t                    }\n2620\t                }\n2621\t                true\n2622\t            });\n2623\t\n2624\t        for entry in builder.build().filter_map(|e| e.ok()) {\n2625\t            let path = entry.path();\n2626\t            if let Some(name) = path.file_name().and_then(|n| n.to_str()) {\n2627\t                if name.ends_with(\".d.ts\") {\n2628\t                    // Map resolved path back to node_modules/... relative path\n2629\t                    let sub_path = path.strip_prefix(pkg_dir)\n2630\t                        .unwrap_or(path)\n2631\t                        .to_string_lossy();\n2632\t                    let rel_path = if sub_path.is_empty() || sub_path == \".\" {\n2633\t                        nm_prefix.clone()\n2634\t                    } else {\n2635\t                        format!(\"{}/{}\", nm_prefix, sub_path)\n2636\t                    };\n2637\t                    dts_files.push((path.to_path_buf(), rel_path));\n2638\t                }\n2639\t            }\n2640\t        }\n2641\t    }\n2642\t\n2643\t    if dts_files.is_empty() {\n2644\t        if verbose {\n2645\t            eprintln!(\"[verbose] no .d.ts files found in node_modules\");\n2646\t        }\n2647\t        return Ok(0);\n2648\t    }\n2649\t\n2650\t    if progress {\n2651\t        eprintln!(\"Found {} .d.ts files in node_modules\", dts_files.len());\n2652\t    }\n2653\t    if verbose {\n2654\t        eprintln!(\"[verbose] .d.ts walk completed in {:?}\", walk_start.elapsed());\n2655\t    }\n2656\t\n2657\t    // Parse in parallel and write to DB in chunks.\n2658\t    // Uses parse_dts_file which takes an explicit rel_path (since real paths\n2659\t    // may be in pnpm store, outside project root).\n2660\t    const CHUNK_SIZE: usize = 500;\n2661\t    let parsed_global = Arc::new(AtomicUsize::new(0));\n2662\t    let total_files = dts_files.len();\n2663\t\n2664\t    let num_threads = std::env::var(\"AST_INDEX_THREADS\")\n2665\t        .ok()\n2666\t        .and_then(|s| s.parse::<usize>().ok())\n2667\t        .filter(|&n| n > 0)\n2668\t        .unwrap_or_else(|| {\n2669\t            std::thread::available_parallelism()\n2670\t                .map(|n| n.get().min(8))\n2671\t                .unwrap_or(4)\n2672\t        });\n2673\t\n2674\t    let pool = rayon::ThreadPoolBuilder::new()\n2675\t        .num_threads(num_threads)\n2676\t        .build()\n2677\t        .map_err(|e| anyhow::anyhow!(\"Failed to build thread pool: {}\", e))?;\n2678\t\n2679\t    let mut total_count = 0;\n2680\t\n2681\t    for chunk in dts_files.chunks(CHUNK_SIZE) {\n2682\t        let counter = parsed_global.clone();\n2683\t        let total = total_files;\n2684\t\n2685\t        let parsed_files: Vec<ParsedFile> = pool.install(|| {\n2686\t            chunk\n2687\t                .par_iter()\n2688\t                .filter_map(|(abs_path, rel_path)| {\n2689\t                    let result = parse_dts_file(abs_path, rel_path).ok();\n2690\t                    let c = counter.fetch_add(1, Ordering::Relaxed) + 1;\n2691\t                    if progress && c % 1000 == 0 {\n2692\t                        eprintln!(\"Parsed {} / {} .d.ts files...\", c, total);\n2693\t                    }\n2694\t                    result\n2695\t                })\n2696\t                .collect()\n2697\t        });\n2698\t\n2699\t        write_batch_to_db(conn, parsed_files, &mut total_count)?;\n2700\t    }\n2701\t\n2702\t    if progress {\n2703\t        eprintln!(\"Indexed {} .d.ts files from node_modules\", total_count);\n2704\t    }\n2705\t\n2706\t    Ok(total_count)\n2707\t}\n2708\t\n2709\t/// Parse a .d.ts file with an explicit relative path (for pnpm store paths)\n2710\tfn parse_dts_file(file_path: &Path, rel_path: &str) -> Result<ParsedFile> {\n2711\t    let metadata = fs::metadata(file_path)?;\n2712\t    let mtime = metadata\n2713\t        .modified()?\n2714\t        .duration_since(SystemTime::UNIX_EPOCH)?\n2715\t        .as_secs() as i64;\n2716\t    let size = metadata.len() as i64;\n2717\t\n2718\t    // Skip files larger than 1 MB\n2719\t    if size > 1_000_000 {\n2720\t        return Ok(ParsedFile {\n2721\t            rel_path: rel_path.to_string(),\n2722\t            mtime,\n2723\t            size,\n2724\t            symbols: vec![],\n2725\t            refs: vec![],\n2726\t        });\n2727\t    }\n2728\t\n2729\t    let content = fs::read_to_string(file_path)?;\n2730\t    let (symbols, refs) = parsers::parse_file_symbols(&content, parsers::FileType::TypeScript)?;\n2731\t\n2732\t    Ok(ParsedFile {\n2733\t        rel_path: rel_path.to_string(),\n2734\t        mtime,\n2735\t        size,\n2736\t        symbols,\n2737\t        refs,\n2738\t    })\n2739\t}\n2740\t\n2741\t#[cfg(test)]\n2742\tmod tests {\n2743\t    use super::*;\n2744\t    use crate::db;\n2745\t    use std::fs;\n2746\t    use tempfile::TempDir;\n2747\t\n2748\t    #[test]\n2749\t    fn test_detect_android_project() {\n2750\t        let dir = TempDir::new().unwrap();\n2751\t        fs::write(dir.path().join(\"settings.gradle.kts\"), \"\").unwrap();\n2752\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Android);\n2753\t    }\n2754\t\n2755\t    #[test]\n2756\t    fn test_detect_ios_project() {\n2757\t        let dir = TempDir::new().unwrap();\n2758\t        fs::write(dir.path().join(\"Package.swift\"), \"\").unwrap();\n2759\t        assert_eq!(detect_project_type(dir.path()), ProjectType::IOS);\n2760\t    }\n2761\t\n2762\t    #[test]\n2763\t    fn test_detect_rust_project() {\n2764\t        let dir = TempDir::new().unwrap();\n2765\t        fs::write(dir.path().join(\"Cargo.toml\"), \"\").unwrap();\n2766\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Rust);\n2767\t    }\n2768\t\n2769\t    #[test]\n2770\t    fn test_detect_python_project() {\n2771\t        let dir = TempDir::new().unwrap();\n2772\t        fs::write(dir.path().join(\"pyproject.toml\"), \"\").unwrap();\n2773\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Python);\n2774\t    }\n2775\t\n2776\t    #[test]\n2777\t    fn test_detect_go_project() {\n2778\t        let dir = TempDir::new().unwrap();\n2779\t        fs::write(dir.path().join(\"go.mod\"), \"\").unwrap();\n2780\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Go);\n2781\t    }\n2782\t\n2783\t    #[test]\n2784\t    fn test_detect_frontend_project() {\n2785\t        let dir = TempDir::new().unwrap();\n2786\t        fs::write(dir.path().join(\"package.json\"), \"{}\").unwrap();\n2787\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Frontend);\n2788\t    }\n2789\t\n2790\t    #[test]\n2791\t    fn test_detect_perl_project() {\n2792\t        let dir = TempDir::new().unwrap();\n2793\t        fs::write(dir.path().join(\"cpanfile\"), \"\").unwrap();\n2794\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Perl);\n2795\t    }\n2796\t\n2797\t    #[test]\n2798\t    fn test_detect_mixed_project() {\n2799\t        let dir = TempDir::new().unwrap();\n2800\t        fs::write(dir.path().join(\"Cargo.toml\"), \"\").unwrap();\n2801\t        fs::write(dir.path().join(\"package.json\"), \"{}\").unwrap();\n2802\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Mixed);\n2803\t    }\n2804\t\n2805\t    #[test]\n2806\t    fn test_detect_bsl_project_by_file() {\n2807\t        let dir = TempDir::new().unwrap();\n2808\t        fs::write(dir.path().join(\"module.bsl\"), \"\").unwrap();\n2809\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Bsl);\n2810\t    }\n2811\t\n2812\t    #[test]\n2813\t    fn test_detect_bsl_project_edt() {\n2814\t        let dir = TempDir::new().unwrap();\n2815\t        fs::create_dir_all(dir.path().join(\"src/Configuration\")).unwrap();\n2816\t        fs::write(dir.path().join(\"src/Configuration/Configuration.mdo\"), \"\").unwrap();\n2817\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Bsl);\n2818\t    }\n2819\t\n2820\t    #[test]\n2821\t    fn test_detect_csharp_project() {\n2822\t        let dir = TempDir::new().unwrap();\n2823\t        fs::write(dir.path().join(\"MyApp.sln\"), \"\").unwrap();\n2824\t        assert_eq!(detect_project_type(dir.path()), ProjectType::CSharp);\n2825\t    }\n2826\t\n2827\t    #[test]\n2828\t    fn test_detect_csharp_project_csproj() {\n2829\t        let dir = TempDir::new().unwrap();\n2830\t        