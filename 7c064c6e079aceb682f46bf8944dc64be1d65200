       let file_name = path.file_name().and_then(|n| n.to_str()).unwrap_or(\"\");\n1552\t            let parent = match path.parent() {\n1553\t                Some(p) => p,\n1554\t                None => continue,\n1555\t            };\n1556\t\n1557\t            // Compute the source module name per build-system flavor (the key used in `modules.name`)\n1558\t            let source_module_name: String = match file_name {\n1559\t                \"ya.make\" => {\n1560\t                    let rel = if let Some(ref mono) = mono_root {\n1561\t                        parent.strip_prefix(mono).ok()\n1562\t                    } else {\n1563\t                        None\n1564\t                    }\n1565\t                    .or_else(|| parent.strip_prefix(root).ok())\n1566\t                    .map(|p| p.to_path_buf())\n1567\t                    .unwrap_or_else(|| parent.to_path_buf());\n1568\t                    rel.to_string_lossy().replace('\\\\', \"/\")\n1569\t                }\n1570\t                \"pyproject.toml\" | \"setup.py\" | \"setup.cfg\" => {\n1571\t                    let module_path = parent.strip_prefix(root).unwrap_or(parent).to_string_lossy().to_string();\n1572\t                    if module_path.is_empty() {\n1573\t                        // Root project — try pyproject.toml name, fall back to root dir name\n1574\t                        if file_name == \"pyproject.toml\" {\n1575\t                            fs::read_to_string(path).ok()\n1576\t                                .as_deref()\n1577\t                                .and_then(extract_python_module_name)\n1578\t                                .unwrap_or_else(|| root.file_name().and_then(|n| n.to_str()).unwrap_or(\"root\").to_string())\n1579\t                        } else {\n1580\t                            root.file_name().and_then(|n| n.to_str()).unwrap_or(\"root\").to_string()\n1581\t                        }\n1582\t                    } else {\n1583\t                        module_path.replace('/', \".\")\n1584\t                    }\n1585\t                }\n1586\t                _ => {\n1587\t                    // Gradle / Maven: dot-separated path relative to rebuild root\n1588\t                    parent.strip_prefix(root).unwrap_or(parent).to_string_lossy().replace('/', \".\")\n1589\t                }\n1590\t            };\n1591\t\n1592\t            let module_id = match module_ids.get(&source_module_name) {\n1593\t                Some(&id) => id,\n1594\t                None => continue,\n1595\t            };\n1596\t\n1597\t            let content = match fs::read_to_string(path) {\n1598\t                Ok(c) => c,\n1599\t                Err(_) => continue,\n1600\t            };\n1601\t\n1602\t            match file_name {\n1603\t                \"pom.xml\" => {\n1604\t                    for caps in maven_dep_re.captures_iter(&content) {\n1605\t                        let artifact_id = caps.get(1).map(|m| m.as_str()).unwrap_or(\"\");\n1606\t                        for (mod_name, &mod_id) in &module_ids {\n1607\t                            let last_segment = mod_name.rsplit('.').next().unwrap_or(mod_name);\n1608\t                            if last_segment == artifact_id {\n1609\t                                dep_stmt.execute(rusqlite::params![module_id, mod_id, \"compile\"])?;\n1610\t                                dep_count += 1;\n1611\t                            }\n1612\t                        }\n1613\t                    }\n1614\t                }\n1615\t                \"ya.make\" => {\n1616\t                    for caps in peerdir_re.captures_iter(&content) {\n1617\t                        let raw = caps.get(1).map(|m| m.as_str()).unwrap_or(\"\");\n1618\t                        for token in raw.split_ascii_whitespace() {\n1619\t                            // Trim trailing comments and separators\n1620\t                            let dep_name = token.trim_end_matches(',').trim();\n1621\t                            if dep_name.is_empty() || dep_name.starts_with('#') {\n1622\t                                continue;\n1623\t                            }\n1624\t                            let dep_name = dep_name.replace('\\\\', \"/\");\n1625\t                            if let Some(&dep_id) = module_ids.get(&dep_name) {\n1626\t                                dep_stmt.execute(rusqlite::params![module_id, dep_id, \"peerdir\"])?;\n1627\t                                dep_count += 1;\n1628\t                            }\n1629\t                        }\n1630\t                    }\n1631\t                }\n1632\t                \"pyproject.toml\" => {\n1633\t                    // [project] dependencies = [...]\n1634\t                    for caps in py_project_deps_re.captures_iter(&content) {\n1635\t                        let body = caps.get(1).map(|m| m.as_str()).unwrap_or(\"\");\n1636\t                        for raw in extract_py_list_strings(body) {\n1637\t                            let dep_name = strip_py_version(&raw);\n1638\t                            if let Some(&dep_id) = module_ids.get(&dep_name) {\n1639\t                                dep_stmt.execute(rusqlite::params![module_id, dep_id, \"compile\"])?;\n1640\t                                dep_count += 1;\n1641\t                            }\n1642\t                        }\n1643\t                    }\n1644\t                    // [tool.poetry.dependencies] section — \"name = ...\" lines\n1645\t                    if let Some(caps) = py_poetry_section_re.captures(&content) {\n1646\t                        let section = caps.get(1).map(|m| m.as_str()).unwrap_or(\"\");\n1647\t                        for line in section.lines() {\n1648\t                            let line = line.trim();\n1649\t                            if line.is_empty() || line.starts_with('#') || line.starts_with('[') {\n1650\t                                continue;\n1651\t                            }\n1652\t                            if let Some(eq_pos) = line.find('=') {\n1653\t                                let dep_name = line[..eq_pos].trim().trim_matches('\"').trim_matches('\\'');\n1654\t                                if dep_name == \"python\" || dep_name.is_empty() {\n1655\t                                    continue;\n1656\t                                }\n1657\t                                if let Some(&dep_id) = module_ids.get(dep_name) {\n1658\t                                    dep_stmt.execute(rusqlite::params![module_id, dep_id, \"compile\"])?;\n1659\t                                    dep_count += 1;\n1660\t                                }\n1661\t                            }\n1662\t                        }\n1663\t                    }\n1664\t                }\n1665\t                \"setup.py\" | \"setup.cfg\" => {\n1666\t                    for caps in py_setup_deps_re.captures_iter(&content) {\n1667\t                        let body = caps.get(1).map(|m| m.as_str()).unwrap_or(\"\");\n1668\t                        for raw in extract_py_list_strings(body) {\n1669\t                            let dep_name = strip_py_version(&raw);\n1670\t                            if let Some(&dep_id) = module_ids.get(&dep_name) {\n1671\t                                dep_stmt.execute(rusqlite::params![module_id, dep_id, \"compile\"])?;\n1672\t                                dep_count += 1;\n1673\t                            }\n1674\t                        }\n1675\t                    }\n1676\t                }\n1677\t                _ => {\n1678\t                    // Gradle\n1679\t                    for caps in projects_dep_re.captures_iter(&content) {\n1680\t                        let dep_kind = caps.get(1).map(|m| m.as_str()).unwrap_or(\"implementation\");\n1681\t                        let dep_name = caps.get(2).map(|m| m.as_str()).unwrap_or(\"\");\n1682\t                        if let Some(&dep_id) = module_ids.get(dep_name) {\n1683\t                            dep_stmt.execute(rusqlite::params![module_id, dep_id, dep_kind])?;\n1684\t                            dep_count += 1;\n1685\t                        }\n1686\t                    }\n1687\t                    for caps in gradle_project_re.captures_iter(&content) {\n1688\t                        let dep_kind = caps.get(1).map(|m| m.as_str()).unwrap_or(\"implementation\");\n1689\t                        let dep_path = caps.get(2).map(|m| m.as_str()).unwrap_or(\"\");\n1690\t                        let dep_name = dep_path.trim_start_matches(':').replace(':', \".\");\n1691\t                        if let Some(&dep_id) = module_ids.get(&dep_name) {\n1692\t                            dep_stmt.execute(rusqlite::params![module_id, dep_id, dep_kind])?;\n1693\t                            dep_count += 1;\n1694\t                        }\n1695\t                    }\n1696\t                    // Fallback: catch project(\":path\") not matched by main regex\n1697\t                    // (e.g., when other deps are between deps( and project())\n1698\t                    for caps in project_only_re.captures_iter(&content) {\n1699\t                        let dep_path = caps.get(1).map(|m| m.as_str()).unwrap_or(\"\");\n1700\t                        let dep_name = dep_path.trim_start_matches(':').replace(':', \".\");\n1701\t                        if let Some(&dep_id) = module_ids.get(&dep_name) {\n1702\t                            dep_stmt.execute(rusqlite::params![module_id, dep_id, \"implementation\"])?;\n1703\t                            dep_count += 1;\n1704\t                        }\n1705\t                    }\n1706\t                }\n1707\t            }\n1708\t        }\n1709\t    }\n1710\t\n1711\t    tx.commit()?;\n1712\t\n1713\t    Ok(dep_count)\n1714\t}\n1715\t\n1716\t/// Get dependencies of a module\n1717\tpub fn get_module_deps(conn: &Connection, module_name: &str) -> Result<Vec<(String, String, String)>> {\n1718\t    // Returns (dep_module_name, dep_module_path, dep_kind)\n1719\t    let mut stmt = conn.prepare(\n1720\t        r#\"\n1721\t        SELECT m2.name, m2.path, md.dep_kind\n1722\t        FROM module_deps md\n1723\t        JOIN modules m1 ON md.module_id = m1.id\n1724\t        JOIN modules m2 ON md.dep_module_id = m2.id\n1725\t        WHERE m1.name = ?1 OR m1.path = ?1\n1726\t        ORDER BY md.dep_kind, m2.name\n1727\t        \"#\n1728\t    )?;\n1729\t\n1730\t    let results = stmt\n1731\t        .query_map(rusqlite::params![module_name], |row| {\n1732\t            Ok((row.get(0)?, row.get(1)?, row.get(2)?))\n1733\t        })?\n1734\t        .collect::<Result<Vec<_>, _>>()?;\n1735\t\n1736\t    Ok(results)\n1737\t}\n1738\t\n1739\t/// Get modules that depend on this module\n1740\tpub fn get_module_dependents(conn: &Connection, module_name: &str) -> Result<Vec<(String, String, String)>> {\n1741\t    // Returns (dependent_module_name, dependent_module_path, dep_kind)\n1742\t    let mut stmt = conn.prepare(\n1743\t        r#\"\n1744\t        SELECT m1.name, m1.path, md.dep_kind\n1745\t        FROM module_deps md\n1746\t        JOIN modules m1 ON md.module_id = m1.id\n1747\t        JOIN modules m2 ON md.dep_module_id = m2.id\n1748\t        WHERE m2.name = ?1 OR m2.path = ?1\n1749\t        ORDER BY md.dep_kind, m1.name\n1750\t        \"#\n1751\t    )?;\n1752\t\n1753\t    let results = stmt\n1754\t        .query_map(rusqlite::params![module_name], |row| {\n1755\t            Ok((row.get(0)?, row.get(1)?, row.get(2)?))\n1756\t        })?\n1757\t        .collect::<Result<Vec<_>, _>>()?;\n1758\t\n1759\t    Ok(results)\n1760\t}\n1761\t\n1762\t/// Parsed XML usage\n1763\t#[derive(Debug)]\n1764\tpub struct XmlUsage {\n1765\t    pub file_path: String,\n1766\t    pub line: usize,\n1767\t    pub class_name: String,\n1768\t    pub usage_type: String,\n1769\t    pub element_id: Option<String>,\n1770\t}\n1771\t\n1772\t/// Index XML layouts for class usages\n1773\tpub fn index_xml_usages(conn: &mut Connection, root: &Path, xml_layout_files: &[PathBuf], progress: bool) -> Result<usize> {\n1774\t    let module_lookup = ModuleLookup::from_db(conn)?;\n1775\t\n1776\t    // Regex for class names in XML\n1777\t    // Full class name: <com.example.MyView ...>\n1778\t    static FULL_CLASS_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r\"<([a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*\\.[A-Z][a-zA-Z0-9_]*)\").unwrap());\n1779\t\n1780\t    let full_class_re = &*FULL_CLASS_RE;\n1781\t    // view class=\"...\" or fragment android:name=\"...\"\n1782\t    static CLASS_ATTR_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"(?:class|android:name)\\s*=\\s*[\"']([a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*\\.[A-Z][a-zA-Z0-9_]*)[\"']\"#).unwrap());\n1783\t\n1784\t    let class_attr_re = &*CLASS_ATTR_RE;\n1785\t    // android:id=\"@+id/xxx\"\n1786\t    static ID_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"android:id\\s*=\\s*[\"']@\\+?id/([^\"']+)[\"']\"#).unwrap());\n1787\t\n1788\t    let id_re = &*ID_RE;\n1789\t\n1790\t    if progress {\n1791\t        eprintln!(\"Found {} XML layout files to index...\", xml_layout_files.len());\n1792\t    }\n1793\t\n1794\t    let tx = conn.transaction()?;\n1795\t\n1796\t    // Clear existing XML usages\n1797\t    tx.execute(\"DELETE FROM xml_usages\", [])?;\n1798\t\n1799\t    let mut count = 0;\n1800\t    {\n1801\t        let mut stmt = tx.prepare_cached(\n1802\t            \"INSERT INTO xml_usages (module_id, file_path, line, class_name, usage_type, element_id) VALUES (?1, ?2, ?3, ?4, ?5, ?6)\"\n1803\t        )?;\n1804\t\n1805\t        for xml_path in xml_layout_files {\n1806\t            let rel_path = xml_path\n1807\t                .strip_prefix(root)\n1808\t                .unwrap_or(xml_path)\n1809\t                .to_string_lossy()\n1810\t                .to_string();\n1811\t\n1812\t            // Find module for this file\n1813\t            let module_id = module_lookup.find(&rel_path);\n1814\t\n1815\t            if let Ok(content) = fs::read_to_string(xml_path) {\n1816\t                for (line_num, line) in content.lines().enumerate() {\n1817\t                    let line_num = line_num + 1;\n1818\t\n1819\t                    // Extract element_id if present on this line\n1820\t                    let element_id = id_re.captures(line).map(|c| c.get(1).unwrap().as_str().to_string());\n1821\t\n1822\t                    // Full class name tags\n1823\t                    for caps in full_class_re.captures_iter(line) {\n1824\t                        let class_name = caps.get(1).unwrap().as_str();\n1825\t                        stmt.execute(rusqlite::params![\n1826\t                            module_id,\n1827\t                            rel_path,\n1828\t                            line_num as i64,\n1829\t                            class_name,\n1830\t                            \"view_tag\",\n1831\t                            element_id\n1832\t                        ])?;\n1833\t                        count += 1;\n1834\t                    }\n1835\t\n1836\t                    // class=\"...\" or android:name=\"...\" attributes\n1837\t                    for caps in class_attr_re.captures_iter(line) {\n1838\t                        let class_name = caps.get(1).unwrap().as_str();\n1839\t                        let usage_type = if line.contains(\"<fragment\") || line.contains(\"android:name\") {\n1840\t                            \"fragment\"\n1841\t                        } else {\n1842\t                            \"view_class_attr\"\n1843\t                        };\n1844\t                        stmt.execute(rusqlite::params![\n1845\t                            module_id,\n1846\t                            rel_path,\n1847\t                            line_num as i64,\n1848\t                            class_name,\n1849\t                            usage_type,\n1850\t                            element_id\n1851\t                        ])?;\n1852\t                        count += 1;\n1853\t                    }\n1854\t                }\n1855\t            }\n1856\t        }\n1857\t    }\n1858\t\n1859\t    tx.commit()?;\n1860\t\n1861\t    Ok(count)\n1862\t}\n1863\t\n1864\t/// Resource type\n1865\t#[derive(Debug, Clone, PartialEq)]\n1866\tpub enum ResourceType {\n1867\t    Drawable,\n1868\t    String,\n1869\t    Color,\n1870\t    Dimen,\n1871\t    Style,\n1872\t    Layout,\n1873\t    Id,\n1874\t    Mipmap,\n1875\t    Other(String),\n1876\t}\n1877\t\n1878\timpl ResourceType {\n1879\t    pub fn as_str(&self) -> &str {\n1880\t        match self {\n1881\t            ResourceType::Drawable => \"drawable\",\n1882\t            ResourceType::String => \"string\",\n1883\t            ResourceType::Color => \"color\",\n1884\t            ResourceType::Dimen => \"dimen\",\n1885\t            ResourceType::Style => \"style\",\n1886\t            ResourceType::Layout => \"layout\",\n1887\t            ResourceType::Id => \"id\",\n1888\t            ResourceType::Mipmap => \"mipmap\",\n1889\t            ResourceType::Other(s) => s,\n1890\t        }\n1891\t    }\n1892\t\n1893\t    pub fn from_str(s: &str) -> Self {\n1894\t        match s {\n1895\t            \"drawable\" => ResourceType::Drawable,\n1896\t            \"string\" => ResourceType::String,\n1897\t            \"color\" => ResourceType::Color,\n1898\t            \"dimen\" => ResourceType::Dimen,\n1899\t            \"style\" => ResourceType::Style,\n1900\t            \"layout\" => ResourceType::Layout,\n1901\t            \"id\" => ResourceType::Id,\n1902\t            \"mipmap\" => ResourceType::Mipmap,\n1903\t            other => ResourceType::Other(other.to_string()),\n1904\t        }\n1905\t    }\n1906\t}\n1907\t\n1908\t/// Index Android resources (drawable, string, color, etc.)\n1909\tpub fn index_resources(conn: &mut Connection, root: &Path, res_files: &[PathBuf], progress: bool) -> Result<(usize, usize)> {\n1910\t    let module_lookup = ModuleLookup::from_db(conn)?;\n1911\t\n1912\t    if progress {\n1913\t        eprintln!(\"Found {} resource files to analyze...\", res_files.len());\n1914\t    }\n1915\t\n1916\t    let tx = conn.transaction()?;\n1917\t\n1918\t    // Clear existing resources\n1919\t    tx.execute(\"DELETE FROM resource_usages\", [])?;\n1920\t    tx.execute(\"DELETE FROM resources\", [])?;\n1921\t\n1922\t    let mut resource_count = 0;\n1923\t    let mut usage_count = 0;\n1924\t\n1925\t    // Regex for resource references\n1926\t    static R_REF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r\"R\\.(drawable|string|color|dimen|style|layout|id|mipmap)\\.([a-zA-Z_][a-zA-Z0-9_]*)\").unwrap());\n1927\t\n1928\t    let r_ref_re = &*R_REF_RE;\n1929\t    static XML_REF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"@(drawable|string|color|dimen|style|layout|id|mipmap)/([a-zA-Z_][a-zA-Z0-9_]*)\"#).unwrap());\n1930\t\n1931\t    let xml_ref_re = &*XML_REF_RE;\n1932\t\n1933\t    // Resource definitions regex for values/*.xml\n1934\t    static STRING_DEF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"<string\\s+name=\"([^\"]+)\"\"#).unwrap());\n1935\t\n1936\t    let string_def_re = &*STRING_DEF_RE;\n1937\t    static COLOR_DEF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"<color\\s+name=\"([^\"]+)\"\"#).unwrap());\n1938\t\n1939\t    let color_def_re = &*COLOR_DEF_RE;\n1940\t    static DIMEN_DEF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"<dimen\\s+name=\"([^\"]+)\"\"#).unwrap());\n1941\t\n1942\t    let dimen_def_re = &*DIMEN_DEF_RE;\n1943\t    static STYLE_DEF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"<style\\s+name=\"([^\"]+)\"\"#).unwrap());\n1944\t\n1945\t    let style_def_re = &*STYLE_DEF_RE;\n1946\t\n1947\t    {\n1948\t        let mut res_stmt = tx.prepare_cached(\n1949\t            \"INSERT INTO resources (module_id, type, name, file_path, line) VALUES (?1, ?2, ?3, ?4, ?5)\"\n1950\t        )?;\n1951\t\n1952\t        // First pass: index resource definitions\n1953\t        for res_path in res_files {\n1954\t            let rel_path = res_path\n1955\t                .strip_prefix(root)\n1956\t                .unwrap_or(res_path)\n1957\t                .to_string_lossy()\n1958\t                .to_string();\n1959\t\n1960\t            let module_id = module_lookup.find(&rel_path);\n1961\t\n1962\t            // Drawable files\n1963\t            if rel_path.contains(\"/drawable\") || rel_path.contains(\"/mipmap\") {\n1964\t                if let Some(name) = res_path.file_stem().and_then(|n| n.to_str()) {\n1965\t                    let res_type = if rel_path.contains(\"/mipmap\") { \"mipmap\" } else { \"drawable\" };\n1966\t                    res_stmt.execute(rusqlite::params![module_id, res_type, name, rel_path, 1])?;\n1967\t                    resource_count += 1;\n1968\t                }\n1969\t            }\n1970\t\n1971\t            // Layout files\n1972\t            if rel_path.contains(\"/layout\") && rel_path.ends_with(\".xml\") {\n1973\t                if let Some(name) = res_path.file_stem().and_then(|n| n.to_str()) {\n1974\t                    res_stmt.execute(rusqlite::params![module_id, \"layout\", name, rel_path, 1])?;\n1975\t                    resource_count += 1;\n1976\t                }\n1977\t            }\n1978\t\n1979\t            // Values files (strings, colors, dimens, styles)\n1980\t            if rel_path.contains(\"/values\") && rel_path.ends_with(\".xml\") {\n1981\t                if let Ok(content) = fs::read_to_string(res_path) {\n1982\t                    for (line_num, line) in content.lines().enumerate() {\n1983\t                        let line_num = line_num + 1;\n1984\t\n1985\t                        if let Some(caps) = string_def_re.captures(line) {\n1986\t                            let name = caps.get(1).unwrap().as_str();\n1987\t                            res_stmt.execute(rusqlite::params![module_id, \"string\", name, rel_path, line_num as i64])?;\n1988\t                            resource_count += 1;\n1989\t                        }\n1990\t                        if let Some(caps) = color_def_re.captures(line) {\n1991\t                            let name = caps.get(1).unwrap().as_str();\n1992\t                            res_stmt.execute(rusqlite::params![module_id, \"color\", name, rel_path, line_num as i64])?;\n1993\t                            resource_count += 1;\n1994\t                        }\n1995\t                        if let Some(caps) = dimen_def_re.captures(line) {\n1996\t                            let name = caps.get(1).unwrap().as_str();\n1997\t                            res_stmt.execute(rusqlite::params![module_id, \"dimen\", name, rel_path, line_num as i64])?;\n1998\t                            resource_count += 1;\n1999\t                        }\n2000\t                        if let Some(caps) = style_def_re.captures(line) {\n2001\t                            let name = caps.get(1).unwrap().as_str();\n2002\t                            res_stmt.execute(rusqlite::params![module_id, \"style\", name, rel_path, line_num as i64])?;\n2003\t                            resource_count += 1;\n2004\t                        }\n2005\t                    }\n2006\t                }\n2007\t            }\n2008\t        }\n2009\t    }\n2010\t\n2011\t    // Build resource ID map: type -> name -> id (two-level for allocation-free lookup)\n2012\t    let resource_ids: std::collections::HashMap<String, std::collections::HashMap<String, i64>> = {\n2013\t        let mut stmt = tx.prepare(\"SELECT id, type, name FROM resources\")?;\n2014\t        let rows = stmt.query_map([], |row| {\n2015\t            Ok((row.get::<_, i64>(0)?, row.get::<_, String>(1)?, row.get::<_, String>(2)?))\n2016\t        })?;\n2017\t        let mut map: std::collections::HashMap<String, std::collections::HashMap<String, i64>> = std::collections::HashMap::new();\n2018\t        for row in rows {\n2019\t            let (id, res_type, name) = row?;\n2020\t            map.entry(res_type).or_default().insert(name, id);\n2021\t        }\n2022\t        map\n2023\t    };\n2024\t\n2025\t    // Second pass: index resource usages\n2026\t    {\n2027\t        let mut usage_stmt = tx.prepare_cached(\n2028\t            \"INSERT INTO resource_usages (resource_id, usage_file, usage_line, usage_type) VALUES (?1, ?2, ?3, ?4)\"\n2029\t        )?;\n2030\t\n2031\t        // Query code files from DB instead of walking filesystem again\n2032\t        let code_rel_paths: Vec<String> = {\n2033\t            let mut stmt = tx.prepare(\"SELECT path FROM files WHERE path LIKE '%.kt' OR path LIKE '%.java' OR path LIKE '%.xml'\")?;\n2034\t            let rows = stmt.query_map([], |row| row.get::<_, String>(0))?;\n2035\t            rows.filter_map(|r| r.ok()).collect()\n2036\t        };\n2037\t\n2038\t        for rel_path in &code_rel_paths {\n2039\t            let file_path = root.join(rel_path);\n2040\t\n2041\t            if let Ok(content) = fs::read_to_string(file_path) {\n2042\t                let is_xml = rel_path.ends_with(\".xml\");\n2043\t\n2044\t                for (line_num, line) in content.lines().enumerate() {\n2045\t                    let line_num = line_num + 1;\n2046\t\n2047\t                    // R.type.name references (Kotlin/Java)\n2048\t                    if !is_xml {\n2049\t                        for caps in r_ref_re.captures_iter(line) {\n2050\t                            let res_type = caps.get(1).unwrap().as_str();\n2051\t                            let res_name = caps.get(2).unwrap().as_str();\n2052\t\n2053\t                            if let Some(&resource_id) = resource_ids.get(res_type).and_then(|m| m.get(res_name)) {\n2054\t                                usage_stmt.execute(rusqlite::params![resource_id, rel_path, line_num as i64, \"code\"])?;\n2055\t                                usage_count += 1;\n2056\t                            }\n2057\t                        }\n2058\t                    }\n2059\t\n2060\t                    // @type/name references (XML)\n2061\t                    for caps in xml_ref_re.captures_iter(line) {\n2062\t                        let res_type = caps.get(1).unwrap().as_str();\n2063\t                        let res_name = caps.get(2).unwrap().as_str();\n2064\t\n2065\t                        if let Some(&resource_id) = resource_ids.get(res_type).and_then(|m| m.get(res_name)) {\n2066\t                            usage_stmt.execute(rusqlite::params![resource_id, rel_path, line_num as i64, \"xml\"])?;\n2067\t                            usage_count += 1;\n2068\t                        }\n2069\t                    }\n2070\t                }\n2071\t            }\n2072\t        }\n2073\t    }\n2074\t\n2075\t    tx.commit()?;\n2076\t\n2077\t    Ok((resource_count, usage_count))\n2078\t}\n2079\t\n2080\t/// Build transitive dependencies cache\n2081\tpub fn build_transitive_deps(conn: &mut Connection, progress: bool) -> Result<usize> {\n2082\t    // Get all direct dependencies\n2083\t    let direct_deps: Vec<(i64, i64, String)> = {\n2084\t        let mut stmt = conn.prepare(\"SELECT module_id, dep_module_id, dep_kind FROM module_deps\")?;\n2085\t        let rows = stmt.query_map([], |row| {\n2086\t            Ok((row.get(0)?, row.get(1)?, row.get(2)?))\n2087\t        })?;\n2088\t        rows.collect::<Result<Vec<_>, _>>()?\n2089\t    };\n2090\t\n2091\t    // Get module names\n2092\t    let module_names: std::collections::HashMap<i64, String> = {\n2093\t        let mut stmt = conn.prepare(\"SELECT id, name FROM modules\")?;\n2094\t        let rows = stmt.query_map([], |row| {\n2095\t            Ok((row.get::<_, i64>(0)?, row.get::<_, String>(1)?))\n2096\t        })?;\n2097\t        let mut map = std::collections::HashMap::new();\n2098\t        for row in rows {\n2099\t            let (id, name) = row?;\n2100\t            map.insert(id, name);\n2101\t        }\n2102\t        map\n2103\t    };\n2104\t\n2105\t    // Build adjacency list (only api dependencies create transitive access)\n2106\t    let mut api_deps: std::collections::HashMap<i64, Vec<i64>> = std::collections::HashMap::new();\n2107\t    for (module_id, dep_id, dep_kind) in &direct_deps {\n2108\t        if dep_kind == \"api\" {\n2109\t            api_deps.entry(*module_id).or_default().push(*dep_id);\n2110\t        }\n2111\t    }\n2112\t\n2113\t    let tx = conn.transaction()?;\n2114\t\n2115\t    // Clear existing\n2116\t    tx.execute(\"DELETE FROM transitive_deps\", [])?;\n2117\t\n2118\t    let mut count = 0;\n2119\t    {\n2120\t        let mut stmt = tx.prepare_cached(\n2121\t            \"INSERT INTO transitive_deps (module_id, dependency_id, depth, path) VALUES (?1, ?2, ?3, ?4)\"\n2122\t        )?;\n2123\t\n2124\t        let unknown = \"?\";\n2125\t\n2126\t        // For each module, BFS to find all transitive dependencies\n2127\t        for (module_id, dep_id, _) in &direct_deps {\n2128\t            let mod_name = module_names.get(module_id).map(|s| s.as_str()).unwrap_or(unknown);\n2129\t            let dep_name = module_names.get(dep_id).map(|s| s.as_str()).unwrap_or(unknown);\n2130\t\n2131\t            // Direct dependency\n2132\t            let path = format!(\"{} -> {}\", mod_name, dep_name);\n2133\t            stmt.execute(rusqlite::params![module_id, dep_id, 1, path])?;\n2134\t            count += 1;\n2135\t\n2136\t            // BFS for transitive (only through api deps)\n2137\t            let mut visited: std::collections::HashSet<i64> = std::collections::HashSet::new();\n2138\t            visited.insert(*dep_id);\n2139\t            let mut queue: std::collections::VecDeque<(i64, usize, String)> = std::collections::VecDeque::new();\n2140\t\n2141\t            // Add api dependencies of dep_id\n2142\t            if let Some(next_deps) = api_deps.get(dep_id) {\n2143\t                for &next_dep in next_deps {\n2144\t                    let next_name = module_names.get(&next_dep).map(|s| s.as_str()).unwrap_or(unknown);\n2145\t                    let next_path = format!(\"{} -> {} -> {}\", mod_name, dep_name, next_name);\n2146\t                    queue.push_back((next_dep, 2, next_path));\n2147\t                }\n2148\t            }\n2149\t\n2150\t            while let Some((trans_dep, depth, path)) = queue.pop_front() {\n2151\t                if visited.contains(&trans_dep) || depth > 5 {\n2152\t                    continue;\n2153\t                }\n2154\t                visited.insert(trans_dep);\n2155\t\n2156\t                stmt.execute(rusqlite::params![module_id, trans_dep, depth as i64, path])?;\n2157\t                count += 1;\n2158\t\n2159\t                // Continue BFS\n2160\t                if let Some(next_deps) = api_deps.get(&trans_dep) {\n2161\t                    for &next_dep in next_deps {\n2162\t                        if !visited.contains(&next_dep) {\n2163\t                            let next_name = module_names.get(&next_dep).map(|s| s.as_str()).unwrap_or(unknown);\n2164\t                            let next_path = format!(\"{} -> {}\", path, next_name);\n2165\t                            queue.push_back((next_dep, depth + 1, next_path));\n2166\t                        }\n2167\t                    }\n2168\t                }\n2169\t            }\n2170\t        }\n2171\t    }\n2172\t\n2173\t    tx.commit()?;\n2174\t\n2175\t    if progress {\n2176\t        eprintln!(\"Built {} transitive dependency entries\", count);\n2177\t    }\n2178\t\n2179\t    Ok(count)\n2180\t}\n2181\t\n2182\t/// Parsed iOS Storyboard/XIB usage\n2183\t#[derive(Debug)]\n2184\tpub struct StoryboardUsage {\n2185\t    pub file_path: String,\n2186\t    pub line: usize,\n2187\t    pub class_name: String,\n2188\t    pub usage_type: String, // \"viewController\", \"view\", \"cell\", \"segue\"\n2189\t    pub storyboard_id: Option<String>,\n2190\t}\n2191\t\n2192\t/// Index iOS storyboard and XIB files for class usages\n2193\tpub fn index_storyboard_usages(conn: &mut Connection, root: &Path, storyboard_files: &[PathBuf], progress: bool) -> Result<usize> {\n2194\t    let module_lookup = ModuleLookup::from_db(conn)?;\n2195\t\n2196\t    // Regex for customClass in storyboards/xibs\n2197\t    // <viewController customClass=\"MyViewController\" ...>\n2198\t    static CUSTOM_CLASS_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"customClass\\s*=\\s*[\"']([A-Z][a-zA-Z0-9_]+)[\"']\"#).unwrap());\n2199\t\n2200\t    let custom_class_re = &*CUSTOM_CLASS_RE;\n2201\t    // storyboardIdentifier=\"...\"\n2202\t    static STORYBOARD_ID_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"(?:storyboardIdentifier|identifier)\\s*=\\s*[\"']([^\"']+)[\"']\"#).unwrap());\n2203\t\n2204\t    let storyboard_id_re = &*STORYBOARD_ID_RE;\n2205\t\n2206\t    if progress {\n2207\t        eprintln!(\"Found {} storyboard/xib files to index...\", storyboard_files.len());\n2208\t    }\n2209\t\n2210\t    let tx = conn.transaction()?;\n2211\t\n2212\t    // Clear existing storyboard usages\n2213\t    tx.execute(\"DELETE FROM storyboard_usages\", [])?;\n2214\t\n2215\t    let mut count = 0;\n2216\t    {\n2217\t        let mut stmt = tx.prepare_cached(\n2218\t            \"INSERT INTO storyboard_usages (module_id, file_path, line, class_name, usage_type, storyboard_id) VALUES (?1, ?2, ?3, ?4, ?5, ?6)\"\n2219\t        )?;\n2220\t\n2221\t        for sb_path in storyboard_files {\n2222\t            let rel_path = sb_path\n2223\t                .strip_prefix(root)\n2224\t                .unwrap_or(sb_path)\n2225\t                .to_string_lossy()\n2226\t                .to_string();\n2227\t\n2228\t            // Find module for this file\n2229\t            let module_id = module_lookup.find(&rel_path);\n2230\t\n2231\t            if let Ok(content) = fs::read_to_string(sb_path) {\n2232\t                for (line_num, line) in content.lines().enumerate() {\n2233\t                    let line_num = line_num + 1;\n2234\t\n2235\t                    // Extract storyboard identifier if present\n2236\t                    let sb_id = storyboard_id_re.captures(line).map(|c| c.get(1).unwrap().as_str().to_string());\n2237\t\n2238\t                    // Extract custom classes\n2239\t                    if let Some(caps) = custom_class_re.captures(line) {\n2240\t                        let class_name = caps.get(1).unwrap().as_str();\n2241\t\n2242\t                        // Determine usage type based on element\n2243\t                        let usage_type = if line.contains(\"<viewController\") || line.contains(\"<tableViewController\") || line.contains(\"<collectionViewController\") || line.contains(\"<navigationController\") || line.contains(\"<tabBarController\") {\n2244\t                            \"viewController\"\n2245\t                        } else if line.contains(\"<tableViewCell\") || line.contains(\"<collectionViewCell\") {\n2246\t                            \"cell\"\n2247\t                        } else if line.contains(\"<view\") || line.contains(\"<View\") {\n2248\t                            \"view\"\n2249\t                        } else {\n2250\t                            \"other\"\n2251\t                        };\n2252\t\n2253\t                        stmt.execute(rusqlite::params![\n2254\t                            module_id,\n2255\t                            rel_path,\n2256\t                            line_num as i64,\n2257\t                            class_name,\n2258\t                            usage_type,\n2259\t                            sb_id\n2260\t                        ])?;\n2261\t                        count += 1;\n2262\t                    }\n2263\t                }\n2264\t            }\n2265\t        }\n2266\t    }\n2267\t\n2268\t    tx.commit()?;\n2269\t\n2270\t    if progress {\n2271\t        eprintln!(\"Indexed {} storyboard/xib class usages\", count);\n2272\t    }\n2273\t\n2274\t    Ok(count)\n2275\t}\n2276\t\n2277\t/// iOS Asset type\n2278\t#[derive(Debug, Clone, PartialEq)]\n2279\tpub enum IosAssetType {\n2280\t    ImageSet,\n2281\t    ColorSet,\n2282\t    AppIcon,\n2283\t    LaunchImage,\n2284\t    DataSet,\n2285\t    Other(String),\n2286\t}\n2287\t\n2288\timpl IosAssetType {\n2289\t    pub fn as_str(&self) -> &str {\n2290\t        match self {\n2291\t            IosAssetType::ImageSet => \"imageset\",\n2292\t            IosAssetType::ColorSet => \"colorset\",\n2293\t            IosAssetType::AppIcon => \"appiconset\",\n2294\t            IosAssetType::LaunchImage => \"launchimage\",\n2295\t            IosAssetType::DataSet => \"dataset\",\n2296\t            IosAssetType::Other(s) => s,\n2297\t        }\n2298\t    }\n2299\t\n2300\t    pub fn from_extension(ext: &str) -> Self {\n2301\t        match ext {\n2302\t            \"imageset\" => IosAssetType::ImageSet,\n2303\t            \"colorset\" => IosAssetType::ColorSet,\n2304\t            \"appiconset\" => IosAssetType::AppIcon,\n2305\t            \"launchimage\" => IosAssetType::LaunchImage,\n2306\t            \"dataset\" => IosAssetType::DataSet,\n2307\t            other => IosAssetType::Other(other.to_string()),\n2308\t        }\n2309\t    }\n2310\t}\n2311\t\n2312\t/// Index iOS Assets.xcassets\n2313\tpub fn index_ios_assets(conn: &mut Connection, root: &Path, xcassets_dirs: &[PathBuf], progress: bool) -> Result<(usize, usize)> {\n2314\t    use ignore::WalkBuilder;\n2315\t\n2316\t    let module_lookup = ModuleLookup::from_db(conn)?;\n2317\t\n2318\t    if progress {\n2319\t        eprintln!(\"Found {} .xcassets directories...\", xcassets_dirs.len());\n2320\t    }\n2321\t\n2322\t    let tx = conn.transaction()?;\n2323\t\n2324\t    // Clear existing iOS assets\n2325\t    tx.execute(\"DELETE FROM ios_asset_usages\", [])?;\n2326\t    tx.execute(\"DELETE FROM ios_assets\", [])?;\n2327\t\n2328\t    let mut asset_count = 0;\n2329\t    let mut usage_count = 0;\n2330\t\n2331\t    {\n2332\t        let mut asset_stmt = tx.prepare_cached(\n2333\t            \"INSERT INTO ios_assets (module_id, type, name, file_path) VALUES (?1, ?2, ?3, ?4)\"\n2334\t        )?;\n2335\t\n2336\t        // Index assets from .xcassets directories\n2337\t        for xcassets_dir in xcassets_dirs {\n2338\t            let rel_xcassets = xcassets_dir\n2339\t                .strip_prefix(root)\n2340\t                .unwrap_or(xcassets_dir)\n2341\t                .to_string_lossy()\n2342\t                .to_string();\n2343\t\n2344\t            let module_id = module_lookup.find(&rel_xcassets);\n2345\t\n2346\t            // Walk inside xcassets to find imagesets, colorsets, etc.\n2347\t            let inner_walker = WalkBuilder::new(xcassets_dir)\n2348\t                .hidden(false)\n2349\t                .build();\n2350\t\n2351\t            for entry in inner_walker {\n2352\t                if let Ok(entry) = entry {\n2353\t                    let path = entry.path();\n2354\t                    if path.is_dir() {\n2355\t                        if let Some(ext) = path.extension().and_then(|e| e.to_str()) {\n2356\t                            if matches!(ext, \"imageset\" | \"colorset\" | \"appiconset\" | \"launchimage\" | \"dataset\") {\n2357\t                                if let Some(name) = path.file_stem().and_then(|n| n.to_str()) {\n2358\t                                    let rel_path = path\n2359\t                                        .strip_prefix(root)\n2360\t                                        .unwrap_or(path)\n2361\t                                        .to_string_lossy()\n2362\t                                        .to_string();\n2363\t\n2364\t                                    let asset_type = IosAssetType::from_extension(ext);\n2365\t                                    asset_stmt.execute(rusqlite::params![\n2366\t                                        module_id,\n2367\t                                        asset_type.as_str(),\n2368\t                                        name,\n2369\t                                        rel_path\n2370\t                                    ])?;\n2371\t                                    asset_count += 1;\n2372\t                                }\n2373\t                            }\n2374\t                        }\n2375\t                    }\n2376\t                }\n2377\t            }\n2378\t        }\n2379\t    }\n2380\t\n2381\t    // Build asset ID map\n2382\t    let asset_ids: std::collections::HashMap<String, i64> = {\n2383\t        let mut stmt = tx.prepare(\"SELECT id, name FROM ios_assets\")?;\n2384\t        let rows = stmt.query_map([], |row| {\n2385\t            Ok((row.get::<_, String>(1)?, row.get::<_, i64>(0)?))\n2386\t        })?;\n2387\t        let mut map = std::collections::HashMap::new();\n2388\t        for row in rows {\n2389\t            let (name, id) = row?;\n2390\t            map.insert(name, id);\n2391\t        }\n2392\t        map\n2393\t    };\n2394\t\n2395\t    // Index asset usages in Swift code\n2396\t    // UIImage(named: \"assetName\") or Image(\"assetName\") or Color(\"colorName\")\n2397\t    static SWIFT_IMAGE_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"(?:UIImage\\s*\\(\\s*named:\\s*[\"']|Image\\s*\\(\\s*[\"']|\\.image\\s*\\(\\s*named:\\s*[\"'])([^\"']+)[\"']\"#).unwrap());\n2398\t\n2399\t    let swift_image_re = &*SWIFT_IMAGE_RE;\n2400\t    static SWIFT_COLOR_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"(?:UIColor\\s*\\(\\s*named:\\s*[\"']|Color\\s*\\(\\s*[\"'])([^\"']+)[\"']\"#).unwrap());\n2401\t\n2402\t    let swift_color_re = &*SWIFT_COLOR_RE;\n2403\t\n2404\t    {\n2405\t        let mut usage_stmt = tx.prepare_cached(\n2406\t            \"INSERT INTO ios_asset_usages (asset_id, usage_file, usage_line, usage_type) VALUES (?1, ?2, ?3, ?4)\"\n2407\t        )?;\n2408\t\n2409\t        // Query swift files from DB instead of walking filesystem again\n2410\t        let swift_rel_paths: Vec<String> = {\n2411\t            let mut stmt = tx.prepare(\"SELECT path FROM files WHERE path LIKE '%.swift'\")?;\n2412\t            let rows = stmt.query_map([], |row| row.get::<_, String>(0))?;\n2413\t            rows.filter_map(|r| r.ok()).collect()\n2414\t        };\n2415\t\n2416\t        for rel_path in &swift_rel_paths {\n2417\t            let file_path = root.join(rel_path);\n2418\t\n2419\t            if let Ok(content) = fs::read_to_string(file_path) {\n2420\t                for (line_num, line) in content.lines().enumerate() {\n2421\t                    let line_num = line_num + 1;\n2422\t\n2423\t                    // Image references\n2424\t                    for caps in swift_image_re.captures_iter(line) {\n2425\t                        let asset_name = caps.get(1).unwrap().as_str();\n2426\t                        if let Some(&asset_id) = asset_ids.get(asset_name) {\n2427\t                            usage_stmt.execute(rusqlite::params![asset_id, rel_path, line_num as i64, \"code\"])?;\n2428\t                            usage_count += 1;\n2429\t                        }\n2430\t                    }\n2431\t\n2432\t                    // Color references\n2433\t                    for caps in swift_color_re.captures_iter(line) {\n2434\t                        let asset_name = caps.get(1).unwrap().as_str();\n2435\t                        if let Some(&asset_id) = asset_ids.get(asset_name) {\n2436\t                            usage_stmt.execute(rusqlite::params![asset_id, rel_path, line_num as i64, \"code\"])?;\n2437\t                            usage_count += 1;\n2438\t                        }\n2439\t                    }\n2440\t                }\n2441\t            }\n2442\t        }\n2443\t    }\n2444\t\n2445\t    tx.commit()?;\n2446\t\n2447\t    if progress {\n2448\t        eprintln!(\"Indexed {} iOS assets, {} usages\", asset_count, usage_count);\n2449\t    }\n2450\t\n2451\t    Ok((asset_count, usage_count))\n2452\t}\n2453\t\n2454\t/// Index CocoaPods and Carthage dependencies\n2455\tpub fn index_ios_package_managers(conn: &Connection, root: &Path, progress: bool) -> Result<usize> {\n2456\t    let mut count = 0;\n2457\t\n2458\t    // CocoaPods: Podfile\n2459\t    let podfile = root.join(\"Podfile\");\n2460\t    if podfile.exists() {\n2461\t        if let Ok(content) = fs::read_to_string(&podfile) {\n2462\t            // pod 'PodName', '~> 1.0'\n2463\t            static POD_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"pod\\s+['\"]([^'\"]+)['\"]\"#).unwrap());\n2464\t\n2465\t            let pod_re = &*POD_RE;\n2466\t\n2467\t            for caps in pod_re.captures_iter(&content) {\n2468\t                let pod_name = caps.get(1).unwrap().as_str();\n2469\t                conn.execute(\n2470\t                    \"INSERT OR IGNORE INTO modules (name, path, kind) VALUES (?1, ?2, ?3)\",\n2471\t                    rusqlite::params![format!(\"pod.{}\", pod_name), \"Pods\", \"cocoapods\"],\n2472\t                )?;\n2473\t                count += 1;\n2474\t            }\n2475\t        }\n2476\t    }\n2477\t\n2478\t    // Podfile.lock for exact versions\n2479\t    let podfile_lock = root.join(\"Podfile.lock\");\n2480\t    if podfile_lock.exists() {\n2481\t        if let Ok(content) = fs::read_to_string(&podfile_lock) {\n2482\t            // PODS:\n2483\t            //   - PodName (1.0.0)\n2484\t            static POD_LOCK_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"^\\s+-\\s+([A-Za-z0-9_-]+)\\s+\\(\"#).unwrap());\n2485\t\n2486\t            let pod_lock_re = &*POD_LOCK_RE;\n2487\t\n2488\t            for line in content.lines() {\n2489\t                if let Some(caps) = pod_lock_re.captures(line) {\n2490\t                    let pod_name = caps.get(1).unwrap().as_str();\n2491\t                    conn.execute(\n2492\t                        \"INSERT OR IGNORE INTO modules (name, path, kind) VALUES (?1, ?2, ?3)\",\n2493\t                        rusqlite::params![format!(\"pod.{}\", pod_name), \"Pods\", \"cocoapods\"],\n2494\t                    )?;\n2495\t                    count += 1;\n2496\t                }\n2497\t            }\n2498\t        }\n2499\t    }\n2500\t\n2501\t    // Carthage: Cartfile\n2502\t    let cartfile = root.join(\"Cartfile\");\n2503\t    if cartfile.exists() {\n2504\t        if let Ok(content) = fs::read_to_string(&cartfile) {\n2505\t            // github \"owner/repo\" ~> 1.0\n2506\t            static CARTHAGE_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"github\\s+[\"']([^\"']+)[\"']\"#).unwrap());\n2507\t\n2508\t            let carthage_re = &*CARTHAGE_RE;\n2509\t\n2510\t            for caps in carthage_re.captures_iter(&content) {\n2511\t                let repo = caps.get(1).unwrap().as_str();\n2512\t                let name = repo.split('/').last().unwrap_or(repo);\n2513\t                conn.execute(\n2514\t                    \"INSERT OR IGNORE INTO modules (name, path, kind) VALUES (?1, ?2, ?3)\",\n2515\t                    rusqlite::params![format!(\"carthage.{}\", name), \"Carthage/Build\", \"carthage\"],\n2516\t                )?;\n2517\t                count += 1;\n2518\t            }\n2519\t        }\n2520\t    }\n2521\t\n2522\t    // Carthage.resolved for exact versions\n2523\t    let cartfile_resolved = root.join(\"Cartfile.resolved\");\n2524\t    if cartfile_resolved.exists() {\n2525\t        if let Ok(content) = fs::read_to_string(&cartfile_resolved) {\n2526\t            static CARTHAGE_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"github\\s+[\"']([^\"']+)[\"']\"#).unwrap());\n2527\t\n2528\t            let carthage_re = &*CARTHAGE_RE;\n2529\t\n2530\t            for caps in carthage_re.captures_iter(&content) {\n2531\t                let repo = caps.get(1).unwrap().as_str();\n2532\t                let name = repo.split('/').last().unwrap_or(repo);\n2533\t                conn.execute(\n2534\t                    \"INSERT OR IGNORE INTO modules (name, path, kind) VALUES (?1, ?2, ?3)\",\n2535\t                    rusqlite::params![format!(\"carthage.{}\", name), \"Carthage/Build\", \"carthage\"],\n2536\t                )?;\n2537\t                count += 1;\n2538\t            }\n2539\t        }\n2540\t    }\n2541\t\n2542\t    if progress {\n2543\t        eprintln!(\"Indexed {} CocoaPods/Carthage dependencies\", count);\n2544\t    }\n2545\t\n2546\t    Ok(count)\n2547\t}\n2548\t\n2549\t/// Index .d.ts files from node_modules (type declarations for external libraries).\n2550\t/// These provide symbol definitions for imported libraries (e.g., React, lodash).\n2551\t/// Only .d.ts files are indexed — not full JS/TS source from node_modules.\n2552\t///\n2553\t/// Handles pnpm (symlinks to store) by resolving top-level package symlinks\n2554\t/// and mapping paths back to node_modules/... for storage.\n2555\t/// Does NOT use follow_links to avoid loops on FUSE mounts (Arcadia).\n2556\tpub fn index_node_modules_dts(conn: &mut Connection, root: &Path, progress: bool) -> Result<usize> {\n2557\t    use ignore::WalkBuilder;\n2558\t    use std::sync::atomic::{AtomicUsize, Ordering};\n2559\t    use std::time::Instant;\n2560\t\n2561\t    let node_modules = root.join(\"node_modules\");\n2562\t    if !node_modules.exists() || !node_modules.is_dir() {\n2563\t        return Ok(0);\n2564\t    }\n2565\t\n2566\t    let verbose = std::env::var(\"AST_INDEX_VERBOSE\").is_ok();\n2567\t\n2568\t    if progress {\n2569\t        eprintln!(\"Scanning node_modules for .d.ts type declarations...\");\n2570\t    }\n2571\t\n2572\t    let walk_start = Instant::now();\n2573\t\n2574\t    // Collect (resolved_dir, node_modules_prefix) pairs.\n2575\t    // Resolves symlinks only at the package level (safe for pnpm).\n2576\t    // E.g.: (resolved_path, \"node_modules/@types/react\")\n2577\t    let mut pkg_map: Vec<(PathBuf, String)> = Vec::new();\n2578\t\n2579\t    if let Ok(entries) = fs::read_dir(&node_modules) {\n2580\t        for entry in entries.filter_map(|e| e.ok()) {\n2581\t            let path = entry.path();\n2582\t            let name_str = entry.file_name().to_string_lossy().to_string();\n2583\t\n2584\t            if name_str.starts_with('.') {\n2585\t                continue;\n2586\t            }\n2587\t\n2588\t            if name_str.starts_with('@') {\n2589\t                // Scoped packages: enumerate @scope/pkg\n2590\t                let scope_dir = fs::canonicalize(&path).unwrap_or(path);\n2591\t                if let Ok(scoped) = fs::read_dir(&scope_dir) {\n2592\t                    for sub in scoped.filter_map(|e| e.ok()) {\n2593\t                        let sub_name = sub.file_name().to_string_lossy().to_string();\n2594\t                        let sub_resolved = fs::canonicalize(sub.path())\n2595\t                            .unwrap_or_else(|_| sub.path());\n2596\t                        if sub_resolved.is_dir() {\n2597\t                            let prefix = format!(\"node_modules/{}/{}\", name_str, sub_name);\n2598\t                            pkg_map.push((sub_resolved, prefix));\n2599\t                        }\n2600\t                    }\n2601\t                }\n2602\t            } else {\n2603\t                let resolved = fs::canonicalize(&path).unwrap_or(path);\n2604\t                if resolved.is_dir() {\n2605\t                    let prefix = format!(\"node_modules/{}\", name_str);\n2606\t                    pkg_map.push((resolved, prefix));\n2607\t                }\n2608\t            }\n2609\t        }\n2610\t    }\n2611\t\n2612\t    if verbose {\n2613\t        eprintln!(\"[verbose] found {} package dirs in node_modules\", pkg_map.len());\n2614\t    }\n2615\t\n2616\t    // Walk each resolved package dir for .d.ts files.\n2617\t    // follow_links=false — already resolved top-level symlinks.\n2618\t    // Store (abs_path, rel_path) pairs for correct DB storage.\n2619\t    let mut dts_files: Vec<(PathBuf, String)> = Vec::new();\n2620\t\n2621\t    for (pkg_dir, nm_prefix) in &pkg_map {\n2622\t        let mut builder = WalkBuilder::new(pkg_dir);\n2623\t        builder\n2624\t            .hidden(false)\n2625\t            .git_ignore(false)\n2626\t            .git_exclude(false)\n2627\t            .follow_links(false)\n2628\t            .max_depth(Some(8))\n2629\t            .filter_entry(|entry| {\n2630\t                if entry.file_type().map(|ft| ft.is_dir()).unwrap_or(false) {\n2631\t                    if let Some(name) = entry.file_name().to_str() {\n2632\t                        if name == \"node_modules\" || name.starts_with('.') {\n2633\t                            return false;\n2634\t                        }\n2635\t                    }\n2636\t                }\n2637\t                true\n2638\t            });\n2639\t\n2640\t        for entry in builder.build().filter_map(|e| e.ok()) {\n2641\t            let path = entry.path();\n2642\t            if let Some(name) = path.file_name().and_then(|n| n.to_str()) {\n2643\t                if name.ends_with(\".d.ts\") {\n2644\t                    // Map resolved path back to node_modules/... relative path\n2645\t                    let sub_path = path.strip_prefix(pkg_dir)\n2646\t                        .unwrap_or(path)\n2647\t                        .to_string_lossy();\n2648\t                    let rel_path = if sub_path.is_empty() || sub_path == \".\" {\n2649\t                        nm_prefix.clone()\n2650\t                    } else {\n2651\t                        format!(\"{}/{}\", nm_prefix, sub_path)\n2652\t                    };\n2653\t                    dts_files.push((path.to_path_buf(), rel_path));\n2654\t                }\n2655\t            }\n2656\t        }\n2657\t    }\n2658\t\n2659\t    if dts_files.is_empty() {\n2660\t        if verbose {\n2661\t            eprintln!(\"[verbose] no .d.ts files found in node_modules\");\n2662\t        }\n2663\t        return Ok(0);\n2664\t    }\n2665\t\n2666\t    if progress {\n2667\t        eprintln!(\"Found {} .d.ts files in node_modules\", dts_files.len());\n2668\t    }\n2669\t    if verbose {\n2670\t        eprintln!(\"[verbose] .d.ts walk completed in {:?}\", walk_start.elapsed());\n2671\t    }\n2672\t\n2673\t    // Parse in parallel and write to DB in chunks.\n2674\t    // Uses parse_dts_file which takes an explicit rel_path (since real paths\n2675\t    // may be in pnpm store, outside project root).\n2676\t    const CHUNK_SIZE: usize = 500;\n2677\t    let parsed_global = Arc::new(AtomicUsize::new(0));\n2678\t    let total_files = dts_files.len();\n2679\t\n2680\t    let num_threads = std::env::var(\"AST_INDEX_THREADS\")\n2681\t        .ok()\n2682\t        .and_then(|s| s.parse::<usize>().ok())\n2683\t        .filter(|&n| n > 0)\n2684\t        .unwrap_or_else(|| {\n2685\t            std::thread::available_parallelism()\n2686\t                .map(|n| n.get().min(8))\n2687\t                .unwrap_or(4)\n2688\t        });\n2689\t\n2690\t    let pool = rayon::ThreadPoolBuilder::new()\n2691\t        .num_threads(num_threads)\n2692\t        .build()\n2693\t        .map_err(|e| anyhow::anyhow!(\"Failed to build thread pool: {}\", e))?;\n2694\t\n2695\t    let mut total_count = 0;\n2696\t\n2697\t    for chunk in dts_files.chunks(CHUNK_SIZE) {\n2698\t        let counter = parsed_global.clone();\n2699\t        let total = total_files;\n2700\t\n2701\t        let parsed_files: Vec<ParsedFile> = pool.install(|| {\n2702\t            chunk\n2703\t                .par_iter()\n2704\t                .filter_map(|(abs_path, rel_path)| {\n2705\t                    let result = parse_dts_file(abs_path, rel_path).ok();\n2706\t                    let c = counter.fetch_add(1, Ordering::Relaxed) + 1;\n2707\t                    if progress && c % 1000 == 0 {\n2708\t                        eprintln!(\"Parsed {} / {} .d.ts files...\", c, total);\n2709\t                    }\n2710\t                    result\n2711\t                })\n2712\t                .collect()\n2713\t        });\n2714\t\n2715\t        write_batch_to_db(conn, parsed_files, &mut total_count)?;\n2716\t    }\n2717\t\n2718\t    if progress {\n2719\t        eprintln!(\"Indexed {} .d.ts files from node_modules\", total_count);\n2720\t    }\n2721\t\n2722\t    Ok(total_count)\n2723\t}\n2724\t\n2725\t/// Parse a .d.ts file with an explicit relative path (for pnpm store paths)\n2726\tfn parse_dts_file(file_path: &Path, rel_path: &str) -> Result<ParsedFile> {\n2727\t    let metadata = fs::metadata(file_path)?;\n2728\t    let mtime = metadata\n2729\t        .modified()?\n2730\t        .duration_since(SystemTime::UNIX_EPOCH)?\n2731\t        .as_secs() as i64;\n2732\t    let size = metadata.len() as i64;\n2733\t\n2734\t    // Skip files larger than 1 MB\n2735\t    if size > 1_000_000 {\n2736\t        return Ok(ParsedFile {\n2737\t            rel_path: rel_path.to_string(),\n2738\t            mtime,\n2739\t            size,\n2740\t            symbols: vec![],\n2741\t            refs: vec![],\n2742\t        });\n2743\t    }\n2744\t\n2745\t    let content = fs::read_to_string(file_path)?;\n2746\t    let (symbols, refs) = parsers::parse_file_symbols(&content, parsers::FileType::TypeScript)?;\n2747\t\n2748\t    Ok(ParsedFile {\n2749\t        rel_path: rel_path.to_string(),\n2750\t        mtime,\n2751\t        size,\n2752\t        symbols,\n2753\t        refs,\n2754\t    })\n2755\t}\n2756\t\n2757\t#[cfg(test)]\n2758\tmod tests {\n2759\t    use super::*;\n2760\t    use crate::db;\n2761\t    use std::fs;\n2762\t    use tempfile::TempDir;\n2763\t\n2764\t    #[test]\n2765\t    fn test_detect_android_project() {\n2766\t        let dir = TempDir::new().unwrap();\n2767\t        fs::write(dir.path().join(\"settings.gradle.kts\"), \"\").unwrap();\n2768\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Android);\n2769\t    }\n2770\t\n2771\t    #[test]\n2772\t    fn test_detect_ios_project() {\n2773\t        let dir = TempDir::new().unwrap();\n2774\t        fs::write(dir.path().join(\"Package.swift\"), \"\").unwrap();\n2775\t        assert_eq!(detect_project_type(dir.path()), ProjectType::IOS);\n2776\t    }\n2777\t\n2778\t    #[test]\n2779\t    fn test_detect_rust_project() {\n2780\t        let dir = TempDir::new().unwrap();\n2781\t        fs::write(dir.path().join(\"Cargo.toml\"), \"\").unwrap();\n2782\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Rust);\n2783\t    }\n2784\t\n2785\t    #[test]\n2786\t    fn test_detect_python_project() {\n2787\t        let dir = TempDir::new().unwrap();\n2788\t        fs::write(dir.path().join(\"pyproject.toml\"), \"\").unwrap();\n2789\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Python);\n2790\t    }\n2791\t\n2792\t    #[test]\n2793\t    fn test_detect_go_project() {\n2794\t        let dir = TempDir::new().unwrap();\n2795\t        fs::write(dir.path().join(\"go.mod\"), \"\").unwrap();\n2796\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Go);\n2797\t    }\n2798\t\n2799\t    #[test]\n2800\t    fn test_detect_frontend_project() {\n2801\t        let dir = TempDir::new().unwrap();\n2802\t        fs::write(dir.path().join(\"package.json\"), \"{}\").unwrap();\n2803\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Frontend);\n2804\t    }\n2805\t\n2806\t    #[test]\n2807\t    fn test_detect_perl_project() {\n2808\t        let dir = TempDir::new().unwrap();\n2809\t        fs::write(dir.path().join(\"cpanfile\"), \"\").unwrap();\n2810\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Perl);\n2811\t    }\n2812\t\n2813\t    #[test]\n2814\t    fn test_detect_mixed_project() {\n2815\t        let dir = TempDir::new().unwrap();\n2816\t        fs::write(dir.path().join(\"Cargo.toml\"), \"\").unwrap();\n2817\t        fs::write(dir.path().join(\"package.json\"), \"{}\").unwrap();\n2818\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Mixed);\n2819\t    }\n2820\t\n2821\t    #[test]\n2822\t    fn test_detect_bsl_project_by_file() {\n2823\t        let dir = TempDir::new().unwrap();\n2824\t        fs::write(dir.path().join(\"module.bsl\"), \"\").unwrap();\n2825\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Bsl);\n2826\t    }\n2827\t\n2828\t    #[test]\n2829\t    fn test_detect_bsl_project_edt() {\n2830\t        let dir = TempDir::new().unwrap();\n2831\t        fs::create_dir_all(dir.path().join(\"src/Configuration\")).unwrap();\n2832\t        fs::write(dir.path().join(\"s