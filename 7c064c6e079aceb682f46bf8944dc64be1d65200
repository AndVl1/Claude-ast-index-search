          "text": "1467\tpub fn index_module_dependencies(conn: &mut Connection, root: &Path, gradle_files: &[PathBuf], progress: bool) -> Result<usize> {\n1468\t\n1469\t    // Regex patterns for dependency declarations\n1470\t    // Gradle projects DSL style: modules { api(projects.features.payments.api) }\n1471\t    static PROJECTS_DEP_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r\"(?m)^\\s*(api|implementation|compileOnly|testImplementation)\\s*\\(\\s*projects\\.([a-zA-Z_][a-zA-Z0-9_.]*)\\s*\\)\").unwrap());\n1472\t\n1473\t    let projects_dep_re = &*PROJECTS_DEP_RE;\n1474\t\n1475\t    // Gradle project(...) deps: implementation(project(\":features:payments:api\"))\n1476\t    // Also matches custom DSL wrappers like deps(project(\":path\")) used in Forma-like Gradle DSLs.\n1477\t    // See https://github.com/formatools/forma for the Forma DSL.\n1478\t    // Capture group 1 is the configuration/wrapper identifier; the leading `:` on the path is optional.\n1479\t    static GRADLE_PROJECT_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"(?m)\\b(\\w+)\\s*\\(\\s*project\\s*\\(\\s*[\"']:?([^\"']+)[\"']\\s*\\)\"#).unwrap());\n1480\t\n1481\t    let gradle_project_re = &*GRADLE_PROJECT_RE;\n1482\t\n1483\t    // ya.make PEERDIR(...) — accepts one or more whitespace-separated paths\n1484\t    static PEERDIR_RE: LazyLock<Regex> = LazyLock::new(||\n1485\t        Regex::new(r\"(?s)PEERDIR\\s*\\(\\s*([^)]*)\\s*\\)\").unwrap()\n1486\t    );\n1487\t    let peerdir_re = &*PEERDIR_RE;\n1488\t\n1489\t    // Python pyproject.toml: [project] dependencies = [\"foo>=1.0\", ...]\n1490\t    static PY_PROJECT_DEPS_RE: LazyLock<Regex> = LazyLock::new(||\n1491\t        Regex::new(r\"(?ms)^\\s*dependencies\\s*=\\s*\\[([^\\]]*)\\]\").unwrap()\n1492\t    );\n1493\t    let py_project_deps_re = &*PY_PROJECT_DEPS_RE;\n1494\t\n1495\t    // Python pyproject.toml poetry section: [tool.poetry.dependencies]\n1496\t    static PY_POETRY_SECTION_RE: LazyLock<Regex> = LazyLock::new(||\n1497\t        Regex::new(r\"(?ms)^\\s*\\[\\s*tool\\.poetry\\.dependencies\\s*\\]\\s*$(.*?)(?:^\\s*\\[|\\z)\").unwrap()\n1498\t    );\n1499\t    let py_poetry_section_re = &*PY_POETRY_SECTION_RE;\n1500\t\n1501\t    // Python setup.py install_requires=[...]\n1502\t    static PY_SETUP_DEPS_RE: LazyLock<Regex> = LazyLock::new(||\n1503\t        Regex::new(r#\"(?ms)install_requires\\s*=\\s*\\[([^\\]]*)\\]\"#).unwrap()\n1504\t    );\n1505\t    let py_setup_deps_re = &*PY_SETUP_DEPS_RE;\n1506\t\n1507\t    let mono_root = find_arc_root(root);\n1508\t\n1509\t    // First, ensure all modules are indexed and get their IDs\n1510\t    let module_ids: std::collections::HashMap<String, i64> = {\n1511\t        let mut stmt = conn.prepare(\"SELECT id, name FROM modules\")?;\n1512\t        let rows = stmt.query_map([], |row| {\n1513\t            Ok((row.get::<_, String>(1)?, row.get::<_, i64>(0)?))\n1514\t        })?;\n1515\t        let mut map = std::collections::HashMap::new();\n1516\t        for row in rows {\n1517\t            let (name, id) = row?;\n1518\t            map.insert(name, id);\n1519\t        }\n1520\t        map\n1521\t    };\n1522\t\n1523\t    if progress {\n1524\t        eprintln!(\"Found {} modules in index\", module_ids.len());\n1525\t    }\n1526\t\n1527\t    let mut dep_count = 0;\n1528\t    let tx = conn.transaction()?;\n1529\t\n1530\t    // Clear existing dependencies\n1531\t    tx.execute(\"DELETE FROM module_deps\", [])?;\n1532\t\n1533\t    {\n1534\t        let mut dep_stmt = tx.prepare_cached(\n1535\t            \"INSERT OR IGNORE INTO module_deps (module_id, dep_module_id, dep_kind) VALUES (?1, ?2, ?3)\"\n1536\t        )?;\n1537\t\n1538\t        // Maven dependency regex: <dependency>...<artifactId>name</artifactId>...</dependency>\n1539\t        static MAVEN_DEP_RE: LazyLock<Regex> = LazyLock::new(||\n1540\t            Regex::new(r\"(?s)<dependency>.*?<artifactId>\\s*([^<]+?)\\s*</artifactId>.*?</dependency>\").unwrap()\n1541\t        );\n1542\t        let maven_dep