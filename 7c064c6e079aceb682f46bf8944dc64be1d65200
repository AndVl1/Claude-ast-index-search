          "text": "140\t    let dependents = indexer::get_module_dependents(&conn, module)?;\n141\t\n142\t    println!(\n143\t        \"{}\",\n144\t        format!(\"Modules depending on '{}' ({}):\", module, dependents.len()).bold()\n145\t    );\n146\t\n147\t    // Group by kind\n148\t    let api_deps: Vec<_> = dependents.iter().filter(|(_, _, k)| k == \"api\").collect();\n149\t    let impl_deps: Vec<_> = dependents.iter().filter(|(_, _, k)| k == \"implementation\").collect();\n150\t    let other_deps: Vec<_> = dependents.iter().filter(|(_, _, k)| k != \"api\" && k != \"implementation\").collect();\n151\t\n152\t    if !api_deps.is_empty() {\n153\t        println!(\"  {} ({}):\", \"via api\".cyan(), api_deps.len());\n154\t        for (name, path, _) in &api_deps {\n155\t            println!(\"    {} ({})\", name, path);\n156\t        }\n157\t    }\n158\t\n159\t    if !impl_deps.is_empty() {\n160\t        println!(\"  {} ({}):\", \"via implementation\".cyan(), impl_deps.len());\n161\t        for (name, path, _) in &impl_deps {\n162\t            println!(\"    {} ({})\", name, path);\n163\t        }\n164\t    }\n165\t\n166\t    if !other_deps.is_empty() {\n167\t        println!(\"  {} ({}):\", \"via other\".cyan(), other_deps.len());\n168\t        for (name, path, kind) in &other_deps {\n169\t            println!(\"    {} ({}) [{}]\", name, path, kind);\n170\t        }\n171\t    }\n172\t\n173\t    if dependents.is_empty() {\n174\t        println!(\"  No dependents found.\");\n175\t    }\n176\t\n177\t    Ok(())\n178\t}\n179\t\n180\t/// Find unused dependencies in a module\n181\tpub fn cmd_unused_deps(\n182\t    root: &Path,\n183\t    module: &str,\n184\t    verbose: bool,\n185\t    check_transitive: bool,\n186\t    check_xml: bool,\n187\t    check_resources: bool,\n188\t) -> Result<()> {\n189\t    if !db::db_exists(root) {\n190\t        println!(\"{}\", \"Index not found. Run 'ast-index rebuild' first.\".red());\n191\t        return Ok(());\n192\t    }\n193\t\n194\t    let conn = db::open_db(root)?;\n195\t\n196\t    // Check if module deps are indexed\n197\t    let dep_count: i64 = conn.query_row(\"SELECT COUNT(*) FROM module_deps\", [], |row| row.get(0))?;\n198\t    if dep_count == 0 {\n199\t        println!(\"{}\", \"Module dependencies not indexed. Run 'ast-index rebuild' first.\".yellow());\n200\t        return Ok(());\n201\t    }\n202\t\n203\t    // Get module id and path\n204\t    let module_info: Option<(i64, String)> = conn.query_row(\n205\t        \"SELECT id, path FROM modules WHERE name = ?1\",\n206\t        params![module],\n207\t        |row| Ok((row.get(0)?, row.get(1)?))\n208\t    ).ok();\n209\t\n210\t    let (module_id, module_path) = match module_info {\n211\t        Some((id, p)) => (id, p),\n212\t        None => {\n213\t            println!(\"{}\", format!(\"Module '{}' not found in index.\", module).red());\n214\t            return Ok(());\n215\t        }\n216\t    };\n217\t\n218\t    // Get all dependencies\n219\t    let deps = indexer::get_module_deps(&conn, module)?;\n220\t\n221\t    if deps.is_empty() {\n222\t        println!(\"{}\", format!(\"Module '{}' has no dependencies.\", module).yellow());\n223\t        return Ok(());\n224\t    }\n225\t\n226\t    println!(\"{}\", format!(\"Analyzing {} dependencies of '{}'...\", deps.len(), module).bold());\n227\t    if check_transitive || check_xml || check_resources {\n228\t        let checks: Vec<&str> = [\n229\t            if check_transitive { Some(\"transitive\") } else { None },\n230\t            if check_xml { Some(\"XML\") } else { None },\n231\t            if check_resources { Some(\"resources\") } else { None },\n232\t        ].into_iter().flatten().collect();\n233\t        println!(\"  Checking: direct imports + {}\\n\", checks.join(\", \"));\n234\t    } else {\n235\t        println!(\"  Checking: direct imports only (strict mode)\\n\");\n236\t    }\n237\t\n238\t    // Results tracking\n239\t    #[derive(Default)]\n240\t    struct DepUsage {\n241\t        direct_count: usize,\n242\t        direct_symbols: Vec<String>,\n243\t        transitive_count: usize,\n244\t        transitive_via: Vec<(String, Vec<String>)>, // (intermediate_module, symbols)\n245\t        xml_count: usize,\n246\t        xml_usages: Vec<(String, i64)>, // (class_name, line)\n247\t        resource_count: usize,\n248\t        resource_usages: Vec<(String, String)>, // (resource_name, usage_type)\n249\t    }\n250\t\n251\t    let mut dep_usages: HashMap<String, DepUsage> = HashMap::new();\n252\t    let mut unused: Vec<(String, String, String)> = vec![];\n253\t    let mut exported: Vec<(String, String, String)> = vec![]; // api deps not directly used\n254\t    let mut used_direct: Vec<(String, String, String, usize)> = vec![];\n255\t    let mut used_transitive: Vec<(String, String, String, usize)> = vec![];\n256\t    let mut used_xml: Vec<(String, String, String, usize)> = vec![];\n257\t    let mut used_resources: Vec<(String, String, String, usize)> = vec![];\n258\t\n259\t    for (dep_name, dep_path, dep_kind) in &deps {\n260\t        let mut usage = DepUsage::default();\n261\t\n262\t        // 1. Check direct usage via index (refs table)\n263\t        let dep_symbols = get_module_public_symbols(&conn, root, dep_path)?;\n264\t        let (direct_count, direct_names) = count_symbols_used_in_module(&conn, &dep_symbols, &module_path)?;\n265\t        usage.direct_count = direct_count;\n266\t        usage.direct_symbols = direct_names;\n267\t\n268\t        // 2. Check transitive usage (via api dependency chain in transitive_deps table)\n269\t        if check_transitive && usage.direct_count == 0 {\n270\t            let trans_count: i64 = conn.query_row(\n271\t                \"SELECT COUNT(*) FROM transitive_deps td\n272\t                 JOIN modules m ON td.dependency_id = m.id\n273\t                 WHERE td.module_id = ?1 AND m.name = ?2 AND td.depth > 1\",\n274\t                params![module_id, dep_name],\n275\t                |row| row.get(0),\n276\t            ).unwrap_or(0);\n277\t\n278\t            if trans_count > 0 {\n279\t                let path: String = conn.query_row(\n280\t                    \"SELECT td.path FROM transitive_deps td\n281\t                     JOIN modules m ON td.dependency_id = m.id\n282\t                     WHERE td.module_id = ?1 AND m.name = ?2 AND td.depth > 1\n283\t                     ORDER BY td.depth LIMIT 1\",\n284\t                    params![module_id, dep_name],\n285\t                    |row| row.get(0),\n286\t                ).unwrap_or_default();\n287\t\n288\t                usage.transitive_count = 1;\n289\t                let parts: Vec<&str> = path.split(\" -> \").collect();\n290\t                if parts.len() >= 2 {\n291\t                    usage.transitive_via.push((parts[1].to_string(), vec![\"(api chain)\".to_string()]));\n292\t                }\n293\t            }\n294\t        }\n295\t\n296\t        // 3. Check XML usages\n297\t        if check_xml && usage.direct_count == 0 && usage.transitive_count == 0 {\n298\t            // Get classes from the dependency module\n299\t            let mut class_stmt = conn.prepare(\n300\t                \"SELECT DISTINCT s.name FROM symbols s\n301\t                 JOIN files f ON s.file_id = f.id\n302\t                 WHERE f.path LIKE ?1 AND s.kind IN ('class', 'object')\n303\t                 LIMIT 50\"\n304\t            )?;\n305\t            let dep_pattern = format!(\"{}%\", dep_path);\n306\t            let classes: Vec<String> = class_stmt\n307\t                .query_map(params![dep_pattern], |row| row.get(0))?\n308\t                .filter_map(|r| r.ok())\n309\t                .collect();\n310\t\n311\t            // Check if any class is used in XML layouts of the target module\n312\t            for class_name in &classes {\n313\t                let mut xml_stmt = conn.prepare(\n314\t                    \"SELECT x.file_path, x.line FROM xml_usages x\n315\t                     JOIN modules m ON x.module_id = m.id\n316\t                     WHERE m.id = ?1 AND x.class_name LIKE ?2\"\n317\t                )?;\n318\t                let class_pattern = format!(\"%{}\", class_name);\n319\t                let xml_results: Vec<(String, i64)> = xml_stmt\n320\t                    .query_map(params![module_id, class_pattern], |row| Ok((row.get(0)?, row.get(1)?)))?\n321\t                    .filter_map(|r| r.ok())\n322\t                    .collect();\n323\t\n324\t                for (_file_path, line) in xml_results {\n325\t                    usage.xml_count += 1;\n326\t                    if usage.xml_usages.len() < 3 {\n327\t                        usage.xml_usages.push((class_name.clone(), line));\n328\t                    }\n329\t                }\n330\t            }\n331\t        }\n332\t\n333\t        // 4. Check resource usages\n334\t        if check_resources && usage.direct_count == 0 && usage.transitive_count == 0 && usage.xml_count == 0 {\n335\t            // Get resources defined in the dependency module\n336\t            let mut res_stmt = conn.prepare(\n337\t                \"SELECT r.type, r.name FROM resources r\n338\t                 JOIN modules m ON r.module_id = m.id\n339\t                 WHERE m.name = ?1\n340\t                 LIMIT 100\"\n341\t            )?;\n342\t            let resources: Vec<(String, String)> = res_stmt\n343\t                .query_map(params![dep_name], |row| Ok((row.get(0)?, row.get(1)?)))?\n344\t                .filter_map(|r| r.ok())\n345\t                .collect();\n346\t\n347\t            // Check if these resources are used in the target module\n348\t            for (res_type, res_name) in &resources {\n349\t                let mut usage_stmt = conn.prepare(\n350\t                    \"SELECT ru.usage_type FROM resource_usages ru\n351\t                     JOIN resources r ON ru.resource_id = r.id\n352\t                     WHERE r.type = ?1 AND r.name = ?2\n353\t                     AND ru.usage_file LIKE ?3\"\n354\t                )?;\n355\t                let module_pattern = format!(\"{}%\", module_path);\n356\t                let usages: Vec<String> = usage_stmt\n357\t                    .query_map(params![res_type, res_name, module_pattern], |row| row.get(0))?\n358\t                    .filter_map(|r| r.ok())\n359\t                    .collect();\n360\t\n361\t                if !usages.is_empty() {\n362\t                    usage.resource_count += usages.len();\n363\t                    if usage.resource_usages.len() < 3 {\n364\t                        usage.resource_usages.push((\n365\t                            format!(\"@{}/{}\", res_type, res_name),\n366\t                            usages.first().cloned().unwrap_or_default()\n367\t                        ));\n368\t                    }\n369\t                }\n370\t            }\n371\t        }\n372\t\n373\t        // Categorize the dependency\n374\t        let total_usage = usage.direct_count + usage.transitive_count + usage.xml_count + usage.resource_count;\n375\t\n376\t        if total_usage == 0 {\n377\t            // Check if this is an api dependency (exported for consumers)\n378\t            if dep_kind == \"api\" {\n379\t                exported.push((dep_name.clone(), dep_path.clone(), dep_kind.clone()));\n380\t            } else {\n381\t                unused.push((dep_name.clone(), dep_path.clone(), dep_kind.clone()));\n382\t            }\n383\t        } else if usage.direct_count > 0 {\n384\t            used_direct.push((dep_name.clone(), dep_path.clone(), dep_kind.clone(), usage.direct_count));\n385\t        } else if usage.transitive_count > 0 {\n386\t            used_transitive.push((dep_name.clone(), dep_path.clone(), dep_kind.clone(), usage.transitive_count));\n387\t        } else if usage.xml_count > 0 {\n388\t            used_xml.push((dep_name.clone(), dep_path.clone(), dep_kind.clone(), usage.xml_count));\n389\t        } else if usage.resource_count > 0 {\n390\t            used_resources.push((dep_name