r caps in gradle_project_re.captures_iter(&content) {\n1679\t                        let dep_kind = caps.get(1).map(|m| m.as_str()).unwrap_or(\"implementation\");\n1680\t                        let dep_path = caps.get(2).map(|m| m.as_str()).unwrap_or(\"\");\n1681\t                        let dep_name = dep_path.trim_start_matches(':').replace(':', \".\");\n1682\t                        if let Some(&dep_id) = module_ids.get(&dep_name) {\n1683\t                            dep_stmt.execute(rusqlite::params![module_id, dep_id, dep_kind])?;\n1684\t                            dep_count += 1;\n1685\t                        }\n1686\t                    }\n1687\t                }\n1688\t            }\n1689\t        }\n1690\t    }\n1691\t\n1692\t    tx.commit()?;\n1693\t\n1694\t    Ok(dep_count)\n1695\t}\n1696\t\n1697\t/// Get dependencies of a module\n1698\tpub fn get_module_deps(conn: &Connection, module_name: &str) -> Result<Vec<(String, String, String)>> {\n1699\t    // Returns (dep_module_name, dep_module_path, dep_kind)\n1700\t    let mut stmt = conn.prepare(\n1701\t        r#\"\n1702\t        SELECT m2.name, m2.path, md.dep_kind\n1703\t        FROM module_deps md\n1704\t        JOIN modules m1 ON md.module_id = m1.id\n1705\t        JOIN modules m2 ON md.dep_module_id = m2.id\n1706\t        WHERE m1.name = ?1 OR m1.path = ?1\n1707\t        ORDER BY md.dep_kind, m2.name\n1708\t        \"#\n1709\t    )?;\n1710\t\n1711\t    let results = stmt\n1712\t        .query_map(rusqlite::params![module_name], |row| {\n1713\t            Ok((row.get(0)?, row.get(1)?, row.get(2)?))\n1714\t        })?\n1715\t        .collect::<Result<Vec<_>, _>>()?;\n1716\t\n1717\t    Ok(results)\n1718\t}\n1719\t\n1720\t/// Get modules that depend on this module\n1721\tpub fn get_module_dependents(conn: &Connection, module_name: &str) -> Result<Vec<(String, String, String)>> {\n1722\t    // Returns (dependent_module_name, dependent_module_path, dep_kind)\n1723\t    let mut stmt = conn.prepare(\n1724\t        r#\"\n1725\t        SELECT m1.name, m1.path, md.dep_kind\n1726\t        FROM module_deps md\n1727\t        JOIN modules m1 ON md.module_id = m1.id\n1728\t        JOIN modules m2 ON md.dep_module_id = m2.id\n1729\t        WHERE m2.name = ?1 OR m2.path = ?1\n1730\t        ORDER BY md.dep_kind, m1.name\n1731\t        \"#\n1732\t    )?;\n1733\t\n1734\t    let results = stmt\n1735\t        .query_map(rusqlite::params![module_name], |row| {\n1736\t            Ok((row.get(0)?, row.get(1)?, row.get(2)?))\n1737\t        })?\n1738\t        .collect::<Result<Vec<_>, _>>()?;\n1739\t\n1740\t    Ok(results)\n1741\t}\n1742\t\n1743\t/// Parsed XML usage\n1744\t#[derive(Debug)]\n1745\tpub struct XmlUsage {\n1746\t    pub file_path: String,\n1747\t    pub line: usize,\n1748\t    pub class_name: String,\n1749\t    pub usage_type: String,\n1750\t    pub element_id: Option<String>,\n1751\t}\n1752\t\n1753\t/// Index XML layouts for class usages\n1754\tpub fn index_xml_usages(conn: &mut Connection, root: &Path, xml_layout_files: &[PathBuf], progress: bool) -> Result<usize> {\n1755\t    let module_lookup = ModuleLookup::from_db(conn)?;\n1756\t\n1757\t    // Regex for class names in XML\n1758\t    // Full class name: <com.example.MyView ...>\n1759\t    static FULL_CLASS_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r\"<([a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*\\.[A-Z][a-zA-Z0-9_]*)\").unwrap());\n1760\t\n1761\t    let full_class_re = &*FULL_CLASS_RE;\n1762\t    // view class=\"...\" or fragment android:name=\"...\"\n1763\t    static CLASS_ATTR_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"(?:class|android:name)\\s*=\\s*[\"']([a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)*\\.[A-Z][a-zA-Z0-9_]*)[\"']\"#).unwrap());\n1764\t\n1765\t    let class_attr_re = &*CLASS_ATTR_RE;\n1766\t    // android:id=\"@+id/xxx\"\n1767\t    static ID_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"android:id\\s*=\\s*[\"']@\\+?id/([^\"']+)[\"']\"#).unwrap());\n1768\t\n1769\t    let id_re = &*ID_RE;\n1770\t\n1771\t    if progress {\n1772\t        eprintln!(\"Found {} XML layout files to index...\", xml_layout_files.len());\n1773\t    }\n1774\t\n1775\t    let tx = conn.transaction()?;\n1776\t\n1777\t    // Clear existing XML usages\n1778\t    tx.execute(\"DELETE FROM xml_usages\", [])?;\n1779\t\n1780\t    let mut count = 0;\n1781\t    {\n1782\t        let mut stmt = tx.prepare_cached(\n1783\t            \"INSERT INTO xml_usages (module_id, file_path, line, class_name, usage_type, element_id) VALUES (?1, ?2, ?3, ?4, ?5, ?6)\"\n1784\t        )?;\n1785\t\n1786\t        for xml_path in xml_layout_files {\n1787\t            let rel_path = xml_path\n1788\t                .strip_prefix(root)\n1789\t                .unwrap_or(xml_path)\n1790\t                .to_string_lossy()\n1791\t                .to_string();\n1792\t\n1793\t            // Find module for this file\n1794\t            let module_id = module_lookup.find(&rel_path);\n1795\t\n1796\t            if let Ok(content) = fs::read_to_string(xml_path) {\n1797\t                for (line_num, line) in content.lines().enumerate() {\n1798\t                    let line_num = line_num + 1;\n1799\t\n1800\t                    // Extract element_id if present on this line\n1801\t                    let element_id = id_re.captures(line).map(|c| c.get(1).unwrap().as_str().to_string());\n1802\t\n1803\t                    // Full class name tags\n1804\t                    for caps in full_class_re.captures_iter(line) {\n1805\t                        let class_name = caps.get(1).unwrap().as_str();\n1806\t                        stmt.execute(rusqlite::params![\n1807\t                            module_id,\n1808\t                            rel_path,\n1809\t                            line_num as i64,\n1810\t                            class_name,\n1811\t                            \"view_tag\",\n1812\t                            element_id\n1813\t                        ])?;\n1814\t                        count += 1;\n1815\t                    }\n1816\t\n1817\t                    // class=\"...\" or android:name=\"...\" attributes\n1818\t                    for caps in class_attr_re.captures_iter(line) {\n1819\t                        let class_name = caps.get(1).unwrap().as_str();\n1820\t                        let usage_type = if line.contains(\"<fragment\") || line.contains(\"android:name\") {\n1821\t                            \"fragment\"\n1822\t                        } else {\n1823\t                            \"view_class_attr\"\n1824\t                        };\n1825\t                        stmt.execute(rusqlite::params![\n1826\t                            module_id,\n1827\t                            rel_path,\n1828\t                            line_num as i64,\n1829\t                            class_name,\n1830\t                            usage_type,\n1831\t                            element_id\n1832\t                        ])?;\n1833\t                        count += 1;\n1834\t                    }\n1835\t                }\n1836\t            }\n1837\t        }\n1838\t    }\n1839\t\n1840\t    tx.commit()?;\n1841\t\n1842\t    Ok(count)\n1843\t}\n1844\t\n1845\t/// Resource type\n1846\t#[derive(Debug, Clone, PartialEq)]\n1847\tpub enum ResourceType {\n1848\t    Drawable,\n1849\t    String,\n1850\t    Color,\n1851\t    Dimen,\n1852\t    Style,\n1853\t    Layout,\n1854\t    Id,\n1855\t    Mipmap,\n1856\t    Other(String),\n1857\t}\n1858\t\n1859\timpl ResourceType {\n1860\t    pub fn as_str(&self) -> &str {\n1861\t        match self {\n1862\t            ResourceType::Drawable => \"drawable\",\n1863\t            ResourceType::String => \"string\",\n1864\t            ResourceType::Color => \"color\",\n1865\t            ResourceType::Dimen => \"dimen\",\n1866\t            ResourceType::Style => \"style\",\n1867\t            ResourceType::Layout => \"layout\",\n1868\t            ResourceType::Id => \"id\",\n1869\t            ResourceType::Mipmap => \"mipmap\",\n1870\t            ResourceType::Other(s) => s,\n1871\t        }\n1872\t    }\n1873\t\n1874\t    pub fn from_str(s: &str) -> Self {\n1875\t        match s {\n1876\t            \"drawable\" => ResourceType::Drawable,\n1877\t            \"string\" => ResourceType::String,\n1878\t            \"color\" => ResourceType::Color,\n1879\t            \"dimen\" => ResourceType::Dimen,\n1880\t            \"style\" => ResourceType::Style,\n1881\t            \"layout\" => ResourceType::Layout,\n1882\t            \"id\" => ResourceType::Id,\n1883\t            \"mipmap\" => ResourceType::Mipmap,\n1884\t            other => ResourceType::Other(other.to_string()),\n1885\t        }\n1886\t    }\n1887\t}\n1888\t\n1889\t/// Index Android resources (drawable, string, color, etc.)\n1890\tpub fn index_resources(conn: &mut Connection, root: &Path, res_files: &[PathBuf], progress: bool) -> Result<(usize, usize)> {\n1891\t    let module_lookup = ModuleLookup::from_db(conn)?;\n1892\t\n1893\t    if progress {\n1894\t        eprintln!(\"Found {} resource files to analyze...\", res_files.len());\n1895\t    }\n1896\t\n1897\t    let tx = conn.transaction()?;\n1898\t\n1899\t    // Clear existing resources\n1900\t    tx.execute(\"DELETE FROM resource_usages\", [])?;\n1901\t    tx.execute(\"DELETE FROM resources\", [])?;\n1902\t\n1903\t    let mut resource_count = 0;\n1904\t    let mut usage_count = 0;\n1905\t\n1906\t    // Regex for resource references\n1907\t    static R_REF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r\"R\\.(drawable|string|color|dimen|style|layout|id|mipmap)\\.([a-zA-Z_][a-zA-Z0-9_]*)\").unwrap());\n1908\t\n1909\t    let r_ref_re = &*R_REF_RE;\n1910\t    static XML_REF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"@(drawable|string|color|dimen|style|layout|id|mipmap)/([a-zA-Z_][a-zA-Z0-9_]*)\"#).unwrap());\n1911\t\n1912\t    let xml_ref_re = &*XML_REF_RE;\n1913\t\n1914\t    // Resource definitions regex for values/*.xml\n1915\t    static STRING_DEF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"<string\\s+name=\"([^\"]+)\"\"#).unwrap());\n1916\t\n1917\t    let string_def_re = &*STRING_DEF_RE;\n1918\t    static COLOR_DEF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"<color\\s+name=\"([^\"]+)\"\"#).unwrap());\n1919\t\n1920\t    let color_def_re = &*COLOR_DEF_RE;\n1921\t    static DIMEN_DEF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"<dimen\\s+name=\"([^\"]+)\"\"#).unwrap());\n1922\t\n1923\t    let dimen_def_re = &*DIMEN_DEF_RE;\n1924\t    static STYLE_DEF_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"<style\\s+name=\"([^\"]+)\"\"#).unwrap());\n1925\t\n1926\t    let style_def_re = &*STYLE_DEF_RE;\n1927\t\n1928\t    {\n1929\t        let mut res_stmt = tx.prepare_cached(\n1930\t            \"INSERT INTO resources (module_id, type, name, file_path, line) VALUES (?1, ?2, ?3, ?4, ?5)\"\n1931\t        )?;\n1932\t\n1933\t        // First pass: index resource definitions\n1934\t        for res_path in res_files {\n1935\t            let rel_path = res_path\n1936\t                .strip_prefix(root)\n1937\t                .unwrap_or(res_path)\n1938\t                .to_string_lossy()\n1939\t                .to_string();\n1940\t\n1941\t            let module_id = module_lookup.find(&rel_path);\n1942\t\n1943\t            // Drawable files\n1944\t            if rel_path.contains(\"/drawable\") || rel_path.contains(\"/mipmap\") {\n1945\t                if let Some(name) = res_path.file_stem().and_then(|n| n.to_str()) {\n1946\t                    let res_type = if rel_path.contains(\"/mipmap\") { \"mipmap\" } else { \"drawable\" };\n1947\t                    res_stmt.execute(rusqlite::params![module_id, res_type, name, rel_path, 1])?;\n1948\t                    resource_count += 1;\n1949\t                }\n1950\t            }\n1951\t\n1952\t            // Layout files\n1953\t            if rel_path.contains(\"/layout\") && rel_path.ends_with(\".xml\") {\n1954\t                if let Some(name) = res_path.file_stem().and_then(|n| n.to_str()) {\n1955\t                    res_stmt.execute(rusqlite::params![module_id, \"layout\", name, rel_path, 1])?;\n1956\t                    resource_count += 1;\n1957\t                }\n1958\t            }\n1959\t\n1960\t            // Values files (strings, colors, dimens, styles)\n1961\t            if rel_path.contains(\"/values\") && rel_path.ends_with(\".xml\") {\n1962\t                if let Ok(content) = fs::read_to_string(res_path) {\n1963\t                    for (line_num, line) in content.lines().enumerate() {\n1964\t                        let line_num = line_num + 1;\n1965\t\n1966\t                        if let Some(caps) = string_def_re.captures(line) {\n1967\t                            let name = caps.get(1).unwrap().as_str();\n1968\t                            res_stmt.execute(rusqlite::params![module_id, \"string\", name, rel_path, line_num as i64])?;\n1969\t                            resource_count += 1;\n1970\t                        }\n1971\t                        if let Some(caps) = color_def_re.captures(line) {\n1972\t                            let name = caps.get(1).unwrap().as_str();\n1973\t                            res_stmt.execute(rusqlite::params![module_id, \"color\", name, rel_path, line_num as i64])?;\n1974\t                            resource_count += 1;\n1975\t                        }\n1976\t                        if let Some(caps) = dimen_def_re.captures(line) {\n1977\t                            let name = caps.get(1).unwrap().as_str();\n1978\t                            res_stmt.execute(rusqlite::params![module_id, \"dimen\", name, rel_path, line_num as i64])?;\n1979\t                            resource_count += 1;\n1980\t                        }\n1981\t                        if let Some(caps) = style_def_re.captures(line) {\n1982\t                            let name = caps.get(1).unwrap().as_str();\n1983\t                            res_stmt.execute(rusqlite::params![module_id, \"style\", name, rel_path, line_num as i64])?;\n1984\t                            resource_count += 1;\n1985\t                        }\n1986\t                    }\n1987\t                }\n1988\t            }\n1989\t        }\n1990\t    }\n1991\t\n1992\t    // Build resource ID map: type -> name -> id (two-level for allocation-free lookup)\n1993\t    let resource_ids: std::collections::HashMap<String, std::collections::HashMap<String, i64>> = {\n1994\t        let mut stmt = tx.prepare(\"SELECT id, type, name FROM resources\")?;\n1995\t        let rows = stmt.query_map([], |row| {\n1996\t            Ok((row.get::<_, i64>(0)?, row.get::<_, String>(1)?, row.get::<_, String>(2)?))\n1997\t        })?;\n1998\t        let mut map: std::collections::HashMap<String, std::collections::HashMap<String, i64>> = std::collections::HashMap::new();\n1999\t        for row in rows {\n2000\t            let (id, res_type, name) = row?;\n2001\t            map.entry(res_type).or_default().insert(name, id);\n2002\t        }\n2003\t        map\n2004\t    };\n2005\t\n2006\t    // Second pass: index resource usages\n2007\t    {\n2008\t        let mut usage_stmt = tx.prepare_cached(\n2009\t            \"INSERT INTO resource_usages (resource_id, usage_file, usage_line, usage_type) VALUES (?1, ?2, ?3, ?4)\"\n2010\t        )?;\n2011\t\n2012\t        // Query code files from DB instead of walking filesystem again\n2013\t        let code_rel_paths: Vec<String> = {\n2014\t            let mut stmt = tx.prepare(\"SELECT path FROM files WHERE path LIKE '%.kt' OR path LIKE '%.java' OR path LIKE '%.xml'\")?;\n2015\t            let rows = stmt.query_map([], |row| row.get::<_, String>(0))?;\n2016\t            rows.filter_map(|r| r.ok()).collect()\n2017\t        };\n2018\t\n2019\t        for rel_path in &code_rel_paths {\n2020\t            let file_path = root.join(rel_path);\n2021\t\n2022\t            if let Ok(content) = fs::read_to_string(file_path) {\n2023\t                let is_xml = rel_path.ends_with(\".xml\");\n2024\t\n2025\t                for (line_num, line) in content.lines().enumerate() {\n2026\t                    let line_num = line_num + 1;\n2027\t\n2028\t                    // R.type.name references (Kotlin/Java)\n2029\t                    if !is_xml {\n2030\t                        for caps in r_ref_re.captures_iter(line) {\n2031\t                            let res_type = caps.get(1).unwrap().as_str();\n2032\t                            let res_name = caps.get(2).unwrap().as_str();\n2033\t\n2034\t                            if let Some(&resource_id) = resource_ids.get(res_type).and_then(|m| m.get(res_name)) {\n2035\t                                usage_stmt.execute(rusqlite::params![resource_id, rel_path, line_num as i64, \"code\"])?;\n2036\t                                usage_count += 1;\n2037\t                            }\n2038\t                        }\n2039\t                    }\n2040\t\n2041\t                    // @type/name references (XML)\n2042\t                    for caps in xml_ref_re.captures_iter(line) {\n2043\t                        let res_type = caps.get(1).unwrap().as_str();\n2044\t                        let res_name = caps.get(2).unwrap().as_str();\n2045\t\n2046\t                        if let Some(&resource_id) = resource_ids.get(res_type).and_then(|m| m.get(res_name)) {\n2047\t                            usage_stmt.execute(rusqlite::params![resource_id, rel_path, line_num as i64, \"xml\"])?;\n2048\t                            usage_count += 1;\n2049\t                        }\n2050\t                    }\n2051\t                }\n2052\t            }\n2053\t        }\n2054\t    }\n2055\t\n2056\t    tx.commit()?;\n2057\t\n2058\t    Ok((resource_count, usage_count))\n2059\t}\n2060\t\n2061\t/// Build transitive dependencies cache\n2062\tpub fn build_transitive_deps(conn: &mut Connection, progress: bool) -> Result<usize> {\n2063\t    // Get all direct dependencies\n2064\t    let direct_deps: Vec<(i64, i64, String)> = {\n2065\t        let mut stmt = conn.prepare(\"SELECT module_id, dep_module_id, dep_kind FROM module_deps\")?;\n2066\t        let rows = stmt.query_map([], |row| {\n2067\t            Ok((row.get(0)?, row.get(1)?, row.get(2)?))\n2068\t        })?;\n2069\t        rows.collect::<Result<Vec<_>, _>>()?\n2070\t    };\n2071\t\n2072\t    // Get module names\n2073\t    let module_names: std::collections::HashMap<i64, String> = {\n2074\t        let mut stmt = conn.prepare(\"SELECT id, name FROM modules\")?;\n2075\t        let rows = stmt.query_map([], |row| {\n2076\t            Ok((row.get::<_, i64>(0)?, row.get::<_, String>(1)?))\n2077\t        })?;\n2078\t        let mut map = std::collections::HashMap::new();\n2079\t        for row in rows {\n2080\t            let (id, name) = row?;\n2081\t            map.insert(id, name);\n2082\t        }\n2083\t        map\n2084\t    };\n2085\t\n2086\t    // Build adjacency list (only api dependencies create transitive access)\n2087\t    let mut api_deps: std::collections::HashMap<i64, Vec<i64>> = std::collections::HashMap::new();\n2088\t    for (module_id, dep_id, dep_kind) in &direct_deps {\n2089\t        if dep_kind == \"api\" {\n2090\t            api_deps.entry(*module_id).or_default().push(*dep_id);\n2091\t        }\n2092\t    }\n2093\t\n2094\t    let tx = conn.transaction()?;\n2095\t\n2096\t    // Clear existing\n2097\t    tx.execute(\"DELETE FROM transitive_deps\", [])?;\n2098\t\n2099\t    let mut count = 0;\n2100\t    {\n2101\t        let mut stmt = tx.prepare_cached(\n2102\t            \"INSERT INTO transitive_deps (module_id, dependency_id, depth, path) VALUES (?1, ?2, ?3, ?4)\"\n2103\t        )?;\n2104\t\n2105\t        let unknown = \"?\";\n2106\t\n2107\t        // For each module, BFS to find all transitive dependencies\n2108\t        for (module_id, dep_id, _) in &direct_deps {\n2109\t            let mod_name = module_names.get(module_id).map(|s| s.as_str()).unwrap_or(unknown);\n2110\t            let dep_name = module_names.get(dep_id).map(|s| s.as_str()).unwrap_or(unknown);\n2111\t\n2112\t            // Direct dependency\n2113\t            let path = format!(\"{} -> {}\", mod_name, dep_name);\n2114\t            stmt.execute(rusqlite::params![module_id, dep_id, 1, path])?;\n2115\t            count += 1;\n2116\t\n2117\t            // BFS for transitive (only through api deps)\n2118\t            let mut visited: std::collections::HashSet<i64> = std::collections::HashSet::new();\n2119\t            visited.insert(*dep_id);\n2120\t            let mut queue: std::collections::VecDeque<(i64, usize, String)> = std::collections::VecDeque::new();\n2121\t\n2122\t            // Add api dependencies of dep_id\n2123\t            if let Some(next_deps) = api_deps.get(dep_id) {\n2124\t                for &next_dep in next_deps {\n2125\t                    let next_name = module_names.get(&next_dep).map(|s| s.as_str()).unwrap_or(unknown);\n2126\t                    let next_path = format!(\"{} -> {} -> {}\", mod_name, dep_name, next_name);\n2127\t                    queue.push_back((next_dep, 2, next_path));\n2128\t                }\n2129\t            }\n2130\t\n2131\t            while let Some((trans_dep, depth, path)) = queue.pop_front() {\n2132\t                if visited.contains(&trans_dep) || depth > 5 {\n2133\t                    continue;\n2134\t                }\n2135\t                visited.insert(trans_dep);\n2136\t\n2137\t                stmt.execute(rusqlite::params![module_id, trans_dep, depth as i64, path])?;\n2138\t                count += 1;\n2139\t\n2140\t                // Continue BFS\n2141\t                if let Some(next_deps) = api_deps.get(&trans_dep) {\n2142\t                    for &next_dep in next_deps {\n2143\t                        if !visited.contains(&next_dep) {\n2144\t                            let next_name = module_names.get(&next_dep).map(|s| s.as_str()).unwrap_or(unknown);\n2145\t                            let next_path = format!(\"{} -> {}\", path, next_name);\n2146\t                            queue.push_back((next_dep, depth + 1, next_path));\n2147\t                        }\n2148\t                    }\n2149\t                }\n2150\t            }\n2151\t        }\n2152\t    }\n2153\t\n2154\t    tx.commit()?;\n2155\t\n2156\t    if progress {\n2157\t        eprintln!(\"Built {} transitive dependency entries\", count);\n2158\t    }\n2159\t\n2160\t    Ok(count)\n2161\t}\n2162\t\n2163\t/// Parsed iOS Storyboard/XIB usage\n2164\t#[derive(Debug)]\n2165\tpub struct StoryboardUsage {\n2166\t    pub file_path: String,\n2167\t    pub line: usize,\n2168\t    pub class_name: String,\n2169\t    pub usage_type: String, // \"viewController\", \"view\", \"cell\", \"segue\"\n2170\t    pub storyboard_id: Option<String>,\n2171\t}\n2172\t\n2173\t/// Index iOS storyboard and XIB files for class usages\n2174\tpub fn index_storyboard_usages(conn: &mut Connection, root: &Path, storyboard_files: &[PathBuf], progress: bool) -> Result<usize> {\n2175\t    let module_lookup = ModuleLookup::from_db(conn)?;\n2176\t\n2177\t    // Regex for customClass in storyboards/xibs\n2178\t    // <viewController customClass=\"MyViewController\" ...>\n2179\t    static CUSTOM_CLASS_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"customClass\\s*=\\s*[\"']([A-Z][a-zA-Z0-9_]+)[\"']\"#).unwrap());\n2180\t\n2181\t    let custom_class_re = &*CUSTOM_CLASS_RE;\n2182\t    // storyboardIdentifier=\"...\"\n2183\t    static STORYBOARD_ID_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"(?:storyboardIdentifier|identifier)\\s*=\\s*[\"']([^\"']+)[\"']\"#).unwrap());\n2184\t\n2185\t    let storyboard_id_re = &*STORYBOARD_ID_RE;\n2186\t\n2187\t    if progress {\n2188\t        eprintln!(\"Found {} storyboard/xib files to index...\", storyboard_files.len());\n2189\t    }\n2190\t\n2191\t    let tx = conn.transaction()?;\n2192\t\n2193\t    // Clear existing storyboard usages\n2194\t    tx.execute(\"DELETE FROM storyboard_usages\", [])?;\n2195\t\n2196\t    let mut count = 0;\n2197\t    {\n2198\t        let mut stmt = tx.prepare_cached(\n2199\t            \"INSERT INTO storyboard_usages (module_id, file_path, line, class_name, usage_type, storyboard_id) VALUES (?1, ?2, ?3, ?4, ?5, ?6)\"\n2200\t        )?;\n2201\t\n2202\t        for sb_path in storyboard_files {\n2203\t            let rel_path = sb_path\n2204\t                .strip_prefix(root)\n2205\t                .unwrap_or(sb_path)\n2206\t                .to_string_lossy()\n2207\t                .to_string();\n2208\t\n2209\t            // Find module for this file\n2210\t            let module_id = module_lookup.find(&rel_path);\n2211\t\n2212\t            if let Ok(content) = fs::read_to_string(sb_path) {\n2213\t                for (line_num, line) in content.lines().enumerate() {\n2214\t                    let line_num = line_num + 1;\n2215\t\n2216\t                    // Extract storyboard identifier if present\n2217\t                    let sb_id = storyboard_id_re.captures(line).map(|c| c.get(1).unwrap().as_str().to_string());\n2218\t\n2219\t                    // Extract custom classes\n2220\t                    if let Some(caps) = custom_class_re.captures(line) {\n2221\t                        let class_name = caps.get(1).unwrap().as_str();\n2222\t\n2223\t                        // Determine usage type based on element\n2224\t                        let usage_type = if line.contains(\"<viewController\") || line.contains(\"<tableViewController\") || line.contains(\"<collectionViewController\") || line.contains(\"<navigationController\") || line.contains(\"<tabBarController\") {\n2225\t                            \"viewController\"\n2226\t                        } else if line.contains(\"<tableViewCell\") || line.contains(\"<collectionViewCell\") {\n2227\t                            \"cell\"\n2228\t                        } else if line.contains(\"<view\") || line.contains(\"<View\") {\n2229\t                            \"view\"\n2230\t                        } else {\n2231\t                            \"other\"\n2232\t                        };\n2233\t\n2234\t                        stmt.execute(rusqlite::params![\n2235\t                            module_id,\n2236\t                            rel_path,\n2237\t                            line_num as i64,\n2238\t                            class_name,\n2239\t                            usage_type,\n2240\t                            sb_id\n2241\t                        ])?;\n2242\t                        count += 1;\n2243\t                    }\n2244\t                }\n2245\t            }\n2246\t        }\n2247\t    }\n2248\t\n2249\t    tx.commit()?;\n2250\t\n2251\t    if progress {\n2252\t        eprintln!(\"Indexed {} storyboard/xib class usages\", count);\n2253\t    }\n2254\t\n2255\t    Ok(count)\n2256\t}\n2257\t\n2258\t/// iOS Asset type\n2259\t#[derive(Debug, Clone, PartialEq)]\n2260\tpub enum IosAssetType {\n2261\t    ImageSet,\n2262\t    ColorSet,\n2263\t    AppIcon,\n2264\t    LaunchImage,\n2265\t    DataSet,\n2266\t    Other(String),\n2267\t}\n2268\t\n2269\timpl IosAssetType {\n2270\t    pub fn as_str(&self) -> &str {\n2271\t        match self {\n2272\t            IosAssetType::ImageSet => \"imageset\",\n2273\t            IosAssetType::ColorSet => \"colorset\",\n2274\t            IosAssetType::AppIcon => \"appiconset\",\n2275\t            IosAssetType::LaunchImage => \"launchimage\",\n2276\t            IosAssetType::DataSet => \"dataset\",\n2277\t            IosAssetType::Other(s) => s,\n2278\t        }\n2279\t    }\n2280\t\n2281\t    pub fn from_extension(ext: &str) -> Self {\n2282\t        match ext {\n2283\t            \"imageset\" => IosAssetType::ImageSet,\n2284\t            \"colorset\" => IosAssetType::ColorSet,\n2285\t            \"appiconset\" => IosAssetType::AppIcon,\n2286\t            \"launchimage\" => IosAssetType::LaunchImage,\n2287\t            \"dataset\" => IosAssetType::DataSet,\n2288\t            other => IosAssetType::Other(other.to_string()),\n2289\t        }\n2290\t    }\n2291\t}\n2292\t\n2293\t/// Index iOS Assets.xcassets\n2294\tpub fn index_ios_assets(conn: &mut Connection, root: &Path, xcassets_dirs: &[PathBuf], progress: bool) -> Result<(usize, usize)> {\n2295\t    use ignore::WalkBuilder;\n2296\t\n2297\t    let module_lookup = ModuleLookup::from_db(conn)?;\n2298\t\n2299\t    if progress {\n2300\t        eprintln!(\"Found {} .xcassets directories...\", xcassets_dirs.len());\n2301\t    }\n2302\t\n2303\t    let tx = conn.transaction()?;\n2304\t\n2305\t    // Clear existing iOS assets\n2306\t    tx.execute(\"DELETE FROM ios_asset_usages\", [])?;\n2307\t    tx.execute(\"DELETE FROM ios_assets\", [])?;\n2308\t\n2309\t    let mut asset_count = 0;\n2310\t    let mut usage_count = 0;\n2311\t\n2312\t    {\n2313\t        let mut asset_stmt = tx.prepare_cached(\n2314\t            \"INSERT INTO ios_assets (module_id, type, name, file_path) VALUES (?1, ?2, ?3, ?4)\"\n2315\t        )?;\n2316\t\n2317\t        // Index assets from .xcassets directories\n2318\t        for xcassets_dir in xcassets_dirs {\n2319\t            let rel_xcassets = xcassets_dir\n2320\t                .strip_prefix(root)\n2321\t                .unwrap_or(xcassets_dir)\n2322\t                .to_string_lossy()\n2323\t                .to_string();\n2324\t\n2325\t            let module_id = module_lookup.find(&rel_xcassets);\n2326\t\n2327\t            // Walk inside xcassets to find imagesets, colorsets, etc.\n2328\t            let inner_walker = WalkBuilder::new(xcassets_dir)\n2329\t                .hidden(false)\n2330\t                .build();\n2331\t\n2332\t            for entry in inner_walker {\n2333\t                if let Ok(entry) = entry {\n2334\t                    let path = entry.path();\n2335\t                    if path.is_dir() {\n2336\t                        if let Some(ext) = path.extension().and_then(|e| e.to_str()) {\n2337\t                            if matches!(ext, \"imageset\" | \"colorset\" | \"appiconset\" | \"launchimage\" | \"dataset\") {\n2338\t                                if let Some(name) = path.file_stem().and_then(|n| n.to_str()) {\n2339\t                                    let rel_path = path\n2340\t                                        .strip_prefix(root)\n2341\t                                        .unwrap_or(path)\n2342\t                                        .to_string_lossy()\n2343\t                                        .to_string();\n2344\t\n2345\t                                    let asset_type = IosAssetType::from_extension(ext);\n2346\t                                    asset_stmt.execute(rusqlite::params![\n2347\t                                        module_id,\n2348\t                                        asset_type.as_str(),\n2349\t                                        name,\n2350\t                                        rel_path\n2351\t                                    ])?;\n2352\t                                    asset_count += 1;\n2353\t                                }\n2354\t                            }\n2355\t                        }\n2356\t                    }\n2357\t                }\n2358\t            }\n2359\t        }\n2360\t    }\n2361\t\n2362\t    // Build asset ID map\n2363\t    let asset_ids: std::collections::HashMap<String, i64> = {\n2364\t        let mut stmt = tx.prepare(\"SELECT id, name FROM ios_assets\")?;\n2365\t        let rows = stmt.query_map([], |row| {\n2366\t            Ok((row.get::<_, String>(1)?, row.get::<_, i64>(0)?))\n2367\t        })?;\n2368\t        let mut map = std::collections::HashMap::new();\n2369\t        for row in rows {\n2370\t            let (name, id) = row?;\n2371\t            map.insert(name, id);\n2372\t        }\n2373\t        map\n2374\t    };\n2375\t\n2376\t    // Index asset usages in Swift code\n2377\t    // UIImage(named: \"assetName\") or Image(\"assetName\") or Color(\"colorName\")\n2378\t    static SWIFT_IMAGE_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"(?:UIImage\\s*\\(\\s*named:\\s*[\"']|Image\\s*\\(\\s*[\"']|\\.image\\s*\\(\\s*named:\\s*[\"'])([^\"']+)[\"']\"#).unwrap());\n2379\t\n2380\t    let swift_image_re = &*SWIFT_IMAGE_RE;\n2381\t    static SWIFT_COLOR_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"(?:UIColor\\s*\\(\\s*named:\\s*[\"']|Color\\s*\\(\\s*[\"'])([^\"']+)[\"']\"#).unwrap());\n2382\t\n2383\t    let swift_color_re = &*SWIFT_COLOR_RE;\n2384\t\n2385\t    {\n2386\t        let mut usage_stmt = tx.prepare_cached(\n2387\t            \"INSERT INTO ios_asset_usages (asset_id, usage_file, usage_line, usage_type) VALUES (?1, ?2, ?3, ?4)\"\n2388\t        )?;\n2389\t\n2390\t        // Query swift files from DB instead of walking filesystem again\n2391\t        let swift_rel_paths: Vec<String> = {\n2392\t            let mut stmt = tx.prepare(\"SELECT path FROM files WHERE path LIKE '%.swift'\")?;\n2393\t            let rows = stmt.query_map([], |row| row.get::<_, String>(0))?;\n2394\t            rows.filter_map(|r| r.ok()).collect()\n2395\t        };\n2396\t\n2397\t        for rel_path in &swift_rel_paths {\n2398\t            let file_path = root.join(rel_path);\n2399\t\n2400\t            if let Ok(content) = fs::read_to_string(file_path) {\n2401\t                for (line_num, line) in content.lines().enumerate() {\n2402\t                    let line_num = line_num + 1;\n2403\t\n2404\t                    // Image references\n2405\t                    for caps in swift_image_re.captures_iter(line) {\n2406\t                        let asset_name = caps.get(1).unwrap().as_str();\n2407\t                        if let Some(&asset_id) = asset_ids.get(asset_name) {\n2408\t                            usage_stmt.execute(rusqlite::params![asset_id, rel_path, line_num as i64, \"code\"])?;\n2409\t                            usage_count += 1;\n2410\t                        }\n2411\t                    }\n2412\t\n2413\t                    // Color references\n2414\t                    for caps in swift_color_re.captures_iter(line) {\n2415\t                        let asset_name = caps.get(1).unwrap().as_str();\n2416\t                        if let Some(&asset_id) = asset_ids.get(asset_name) {\n2417\t                            usage_stmt.execute(rusqlite::params![asset_id, rel_path, line_num as i64, \"code\"])?;\n2418\t                            usage_count += 1;\n2419\t                        }\n2420\t                    }\n2421\t                }\n2422\t            }\n2423\t        }\n2424\t    }\n2425\t\n2426\t    tx.commit()?;\n2427\t\n2428\t    if progress {\n2429\t        eprintln!(\"Indexed {} iOS assets, {} usages\", asset_count, usage_count);\n2430\t    }\n2431\t\n2432\t    Ok((asset_count, usage_count))\n2433\t}\n2434\t\n2435\t/// Index CocoaPods and Carthage dependencies\n2436\tpub fn index_ios_package_managers(conn: &Connection, root: &Path, progress: bool) -> Result<usize> {\n2437\t    let mut count = 0;\n2438\t\n2439\t    // CocoaPods: Podfile\n2440\t    let podfile = root.join(\"Podfile\");\n2441\t    if podfile.exists() {\n2442\t        if let Ok(content) = fs::read_to_string(&podfile) {\n2443\t            // pod 'PodName', '~> 1.0'\n2444\t            static POD_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"pod\\s+['\"]([^'\"]+)['\"]\"#).unwrap());\n2445\t\n2446\t            let pod_re = &*POD_RE;\n2447\t\n2448\t            for caps in pod_re.captures_iter(&content) {\n2449\t                let pod_name = caps.get(1).unwrap().as_str();\n2450\t                conn.execute(\n2451\t                    \"INSERT OR IGNORE INTO modules (name, path, kind) VALUES (?1, ?2, ?3)\",\n2452\t                    rusqlite::params![format!(\"pod.{}\", pod_name), \"Pods\", \"cocoapods\"],\n2453\t                )?;\n2454\t                count += 1;\n2455\t            }\n2456\t        }\n2457\t    }\n2458\t\n2459\t    // Podfile.lock for exact versions\n2460\t    let podfile_lock = root.join(\"Podfile.lock\");\n2461\t    if podfile_lock.exists() {\n2462\t        if let Ok(content) = fs::read_to_string(&podfile_lock) {\n2463\t            // PODS:\n2464\t            //   - PodName (1.0.0)\n2465\t            static POD_LOCK_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"^\\s+-\\s+([A-Za-z0-9_-]+)\\s+\\(\"#).unwrap());\n2466\t\n2467\t            let pod_lock_re = &*POD_LOCK_RE;\n2468\t\n2469\t            for line in content.lines() {\n2470\t                if let Some(caps) = pod_lock_re.captures(line) {\n2471\t                    let pod_name = caps.get(1).unwrap().as_str();\n2472\t                    conn.execute(\n2473\t                        \"INSERT OR IGNORE INTO modules (name, path, kind) VALUES (?1, ?2, ?3)\",\n2474\t                        rusqlite::params![format!(\"pod.{}\", pod_name), \"Pods\", \"cocoapods\"],\n2475\t                    )?;\n2476\t                    count += 1;\n2477\t                }\n2478\t            }\n2479\t        }\n2480\t    }\n2481\t\n2482\t    // Carthage: Cartfile\n2483\t    let cartfile = root.join(\"Cartfile\");\n2484\t    if cartfile.exists() {\n2485\t        if let Ok(content) = fs::read_to_string(&cartfile) {\n2486\t            // github \"owner/repo\" ~> 1.0\n2487\t            static CARTHAGE_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"github\\s+[\"']([^\"']+)[\"']\"#).unwrap());\n2488\t\n2489\t            let carthage_re = &*CARTHAGE_RE;\n2490\t\n2491\t            for caps in carthage_re.captures_iter(&content) {\n2492\t                let repo = caps.get(1).unwrap().as_str();\n2493\t                let name = repo.split('/').last().unwrap_or(repo);\n2494\t                conn.execute(\n2495\t                    \"INSERT OR IGNORE INTO modules (name, path, kind) VALUES (?1, ?2, ?3)\",\n2496\t                    rusqlite::params![format!(\"carthage.{}\", name), \"Carthage/Build\", \"carthage\"],\n2497\t                )?;\n2498\t                count += 1;\n2499\t            }\n2500\t        }\n2501\t    }\n2502\t\n2503\t    // Carthage.resolved for exact versions\n2504\t    let cartfile_resolved = root.join(\"Cartfile.resolved\");\n2505\t    if cartfile_resolved.exists() {\n2506\t        if let Ok(content) = fs::read_to_string(&cartfile_resolved) {\n2507\t            static CARTHAGE_RE: LazyLock<Regex> = LazyLock::new(|| Regex::new(r#\"github\\s+[\"']([^\"']+)[\"']\"#).unwrap());\n2508\t\n2509\t            let carthage_re = &*CARTHAGE_RE;\n2510\t\n2511\t            for caps in carthage_re.captures_iter(&content) {\n2512\t                let repo = caps.get(1).unwrap().as_str();\n2513\t                let name = repo.split('/').last().unwrap_or(repo);\n2514\t                conn.execute(\n2515\t                    \"INSERT OR IGNORE INTO modules (name, path, kind) VALUES (?1, ?2, ?3)\",\n2516\t                    rusqlite::params![format!(\"carthage.{}\", name), \"Carthage/Build\", \"carthage\"],\n2517\t                )?;\n2518\t                count += 1;\n2519\t            }\n2520\t        }\n2521\t    }\n2522\t\n2523\t    if progress {\n2524\t        eprintln!(\"Indexed {} CocoaPods/Carthage dependencies\", count);\n2525\t    }\n2526\t\n2527\t    Ok(count)\n2528\t}\n2529\t\n2530\t/// Index .d.ts files from node_modules (type declarations for external libraries).\n2531\t/// These provide symbol definitions for imported libraries (e.g., React, lodash).\n2532\t/// Only .d.ts files are indexed — not full JS/TS source from node_modules.\n2533\t///\n2534\t/// Handles pnpm (symlinks to store) by resolving top-level package symlinks\n2535\t/// and mapping paths back to node_modules/... for storage.\n2536\t/// Does NOT use follow_links to avoid loops on FUSE mounts (Arcadia).\n2537\tpub fn index_node_modules_dts(conn: &mut Connection, root: &Path, progress: bool) -> Result<usize> {\n2538\t    use ignore::WalkBuilder;\n2539\t    use std::sync::atomic::{AtomicUsize, Ordering};\n2540\t    use std::time::Instant;\n2541\t\n2542\t    let node_modules = root.join(\"node_modules\");\n2543\t    if !node_modules.exists() || !node_modules.is_dir() {\n2544\t        return Ok(0);\n2545\t    }\n2546\t\n2547\t    let verbose = std::env::var(\"AST_INDEX_VERBOSE\").is_ok();\n2548\t\n2549\t    if progress {\n2550\t        eprintln!(\"Scanning node_modules for .d.ts type declarations...\");\n2551\t    }\n2552\t\n2553\t    let walk_start = Instant::now();\n2554\t\n2555\t    // Collect (resolved_dir, node_modules_prefix) pairs.\n2556\t    // Resolves symlinks only at the package level (safe for pnpm).\n2557\t    // E.g.: (resolved_path, \"node_modules/@types/react\")\n2558\t    let mut pkg_map: Vec<(PathBuf, String)> = Vec::new();\n2559\t\n2560\t    if let Ok(entries) = fs::read_dir(&node_modules) {\n2561\t        for entry in entries.filter_map(|e| e.ok()) {\n2562\t            let path = entry.path();\n2563\t            let name_str = entry.file_name().to_string_lossy().to_string();\n2564\t\n2565\t            if name_str.starts_with('.') {\n2566\t                continue;\n2567\t            }\n2568\t\n2569\t            if name_str.starts_with('@') {\n2570\t                // Scoped packages: enumerate @scope/pkg\n2571\t                let scope_dir = fs::canonicalize(&path).unwrap_or(path);\n2572\t                if let Ok(scoped) = fs::read_dir(&scope_dir) {\n2573\t                    for sub in scoped.filter_map(|e| e.ok()) {\n2574\t                        let sub_name = sub.file_name().to_string_lossy().to_string();\n2575\t                        let sub_resolved = fs::canonicalize(sub.path())\n2576\t                            .unwrap_or_else(|_| sub.path());\n2577\t                        if sub_resolved.is_dir() {\n2578\t                            let prefix = format!(\"node_modules/{}/{}\", name_str, sub_name);\n2579\t                            pkg_map.push((sub_resolved, prefix));\n2580\t                        }\n2581\t                    }\n2582\t                }\n2583\t            } else {\n2584\t                let resolved = fs::canonicalize(&path).unwrap_or(path);\n2585\t                if resolved.is_dir() {\n2586\t                    let prefix = format!(\"node_modules/{}\", name_str);\n2587\t                    pkg_map.push((resolved, prefix));\n2588\t                }\n2589\t            }\n2590\t        }\n2591\t    }\n2592\t\n2593\t    if verbose {\n2594\t        eprintln!(\"[verbose] found {} package dirs in node_modules\", pkg_map.len());\n2595\t    }\n2596\t\n2597\t    // Walk each resolved package dir for .d.ts files.\n2598\t    // follow_links=false — already resolved top-level symlinks.\n2599\t    // Store (abs_path, rel_path) pairs for correct DB storage.\n2600\t    let mut dts_files: Vec<(PathBuf, String)> = Vec::new();\n2601\t\n2602\t    for (pkg_dir, nm_prefix) in &pkg_map {\n2603\t        let mut builder = WalkBuilder::new(pkg_dir);\n2604\t        builder\n2605\t            .hidden(false)\n2606\t            .git_ignore(false)\n2607\t            .git_exclude(false)\n2608\t            .follow_links(false)\n2609\t            .max_depth(Some(8))\n2610\t            .filter_entry(|entry| {\n2611\t                if entry.file_type().map(|ft| ft.is_dir()).unwrap_or(false) {\n2612\t                    if let Some(name) = entry.file_name().to_str() {\n2613\t                        if name == \"node_modules\" || name.starts_with('.') {\n2614\t                            return false;\n2615\t                        }\n2616\t                    }\n2617\t                }\n2618\t                true\n2619\t            });\n2620\t\n2621\t        for entry in builder.build().filter_map(|e| e.ok()) {\n2622\t            let path = entry.path();\n2623\t            if let Some(name) = path.file_name().and_then(|n| n.to_str()) {\n2624\t                if name.ends_with(\".d.ts\") {\n2625\t                    // Map resolved path back to node_modules/... relative path\n2626\t                    let sub_path = path.strip_prefix(pkg_dir)\n2627\t                        .unwrap_or(path)\n2628\t                        .to_string_lossy();\n2629\t                    let rel_path = if sub_path.is_empty() || sub_path == \".\" {\n2630\t                        nm_prefix.clone()\n2631\t                    } else {\n2632\t                        format!(\"{}/{}\", nm_prefix, sub_path)\n2633\t                    };\n2634\t                    dts_files.push((path.to_path_buf(), rel_path));\n2635\t                }\n2636\t            }\n2637\t        }\n2638\t    }\n2639\t\n2640\t    if dts_files.is_empty() {\n2641\t        if verbose {\n2642\t            eprintln!(\"[verbose] no .d.ts files found in node_modules\");\n2643\t        }\n2644\t        return Ok(0);\n2645\t    }\n2646\t\n2647\t    if progress {\n2648\t        eprintln!(\"Found {} .d.ts files in node_modules\", dts_files.len());\n2649\t    }\n2650\t    if verbose {\n2651\t        eprintln!(\"[verbose] .d.ts walk completed in {:?}\", walk_start.elapsed());\n2652\t    }\n2653\t\n2654\t    // Parse in parallel and write to DB in chunks.\n2655\t    // Uses parse_dts_file which takes an explicit rel_path (since real paths\n2656\t    // may be in pnpm store, outside project root).\n2657\t    const CHUNK_SIZE: usize = 500;\n2658\t    let parsed_global = Arc::new(AtomicUsize::new(0));\n2659\t    let total_files = dts_files.len();\n2660\t\n2661\t    let num_threads = std::env::var(\"AST_INDEX_THREADS\")\n2662\t        .ok()\n2663\t        .and_then(|s| s.parse::<usize>().ok())\n2664\t        .filter(|&n| n > 0)\n2665\t        .unwrap_or_else(|| {\n2666\t            std::thread::available_parallelism()\n2667\t                .map(|n| n.get().min(8))\n2668\t                .unwrap_or(4)\n2669\t        });\n2670\t\n2671\t    let pool = rayon::ThreadPoolBuilder::new()\n2672\t        .num_threads(num_threads)\n2673\t        .build()\n2674\t        .map_err(|e| anyhow::anyhow!(\"Failed to build thread pool: {}\", e))?;\n2675\t\n2676\t    let mut total_count = 0;\n2677\t\n2678\t    for chunk in dts_files.chunks(CHUNK_SIZE) {\n2679\t        let counter = parsed_global.clone();\n2680\t        let total = total_files;\n2681\t\n2682\t        let parsed_files: Vec<ParsedFile> = pool.install(|| {\n2683\t            chunk\n2684\t                .par_iter()\n2685\t                .filter_map(|(abs_path, rel_path)| {\n2686\t                    let result = parse_dts_file(abs_path, rel_path).ok();\n2687\t                    let c = counter.fetch_add(1, Ordering::Relaxed) + 1;\n2688\t                    if progress && c % 1000 == 0 {\n2689\t                        eprintln!(\"Parsed {} / {} .d.ts files...\", c, total);\n2690\t                    }\n2691\t                    result\n2692\t                })\n2693\t                .collect()\n2694\t        });\n2695\t\n2696\t        write_batch_to_db(conn, parsed_files, &mut total_count)?;\n2697\t    }\n2698\t\n2699\t    if progress {\n2700\t        eprintln!(\"Indexed {} .d.ts files from node_modules\", total_count);\n2701\t    }\n2702\t\n2703\t    Ok(total_count)\n2704\t}\n2705\t\n2706\t/// Parse a .d.ts file with an explicit relative path (for pnpm store paths)\n2707\tfn parse_dts_file(file_path: &Path, rel_path: &str) -> Result<ParsedFile> {\n2708\t    let metadata = fs::metadata(file_path)?;\n2709\t    let mtime = metadata\n2710\t        .modified()?\n2711\t        .duration_since(SystemTime::UNIX_EPOCH)?\n2712\t        .as_secs() as i64;\n2713\t    let size = metadata.len() as i64;\n2714\t\n2715\t    // Skip files larger than 1 MB\n2716\t    if size > 1_000_000 {\n2717\t        return Ok(ParsedFile {\n2718\t            rel_path: rel_path.to_string(),\n2719\t            mtime,\n2720\t            size,\n2721\t            symbols: vec![],\n2722\t            refs: vec![],\n2723\t        });\n2724\t    }\n2725\t\n2726\t    let content = fs::read_to_string(file_path)?;\n2727\t    let (symbols, refs) = parsers::parse_file_symbols(&content, parsers::FileType::TypeScript)?;\n2728\t\n2729\t    Ok(ParsedFile {\n2730\t        rel_path: rel_path.to_string(),\n2731\t        mtime,\n2732\t        size,\n2733\t        symbols,\n2734\t        refs,\n2735\t    })\n2736\t}\n2737\t\n2738\t#[cfg(test)]\n2739\tmod tests {\n2740\t    use super::*;\n2741\t    use crate::db;\n2742\t    use std::fs;\n2743\t    use tempfile::TempDir;\n2744\t\n2745\t    #[test]\n2746\t    fn test_detect_android_project() {\n2747\t        let dir = TempDir::new().unwrap();\n2748\t        fs::write(dir.path().join(\"settings.gradle.kts\"), \"\").unwrap();\n2749\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Android);\n2750\t    }\n2751\t\n2752\t    #[test]\n2753\t    fn test_detect_ios_project() {\n2754\t        let dir = TempDir::new().unwrap();\n2755\t        fs::write(dir.path().join(\"Package.swift\"), \"\").unwrap();\n2756\t        assert_eq!(detect_project_type(dir.path()), ProjectType::IOS);\n2757\t    }\n2758\t\n2759\t    #[test]\n2760\t    fn test_detect_rust_project() {\n2761\t        let dir = TempDir::new().unwrap();\n2762\t        fs::write(dir.path().join(\"Cargo.toml\"), \"\").unwrap();\n2763\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Rust);\n2764\t    }\n2765\t\n2766\t    #[test]\n2767\t    fn test_detect_python_project() {\n2768\t        let dir = TempDir::new().unwrap();\n2769\t        fs::write(dir.path().join(\"pyproject.toml\"), \"\").unwrap();\n2770\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Python);\n2771\t    }\n2772\t\n2773\t    #[test]\n2774\t    fn test_detect_go_project() {\n2775\t        let dir = TempDir::new().unwrap();\n2776\t        fs::write(dir.path().join(\"go.mod\"), \"\").unwrap();\n2777\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Go);\n2778\t    }\n2779\t\n2780\t    #[test]\n2781\t    fn test_detect_frontend_project() {\n2782\t        let dir = TempDir::new().unwrap();\n2783\t        fs::write(dir.path().join(\"package.json\"), \"{}\").unwrap();\n2784\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Frontend);\n2785\t    }\n2786\t\n2787\t    #[test]\n2788\t    fn test_detect_perl_project() {\n2789\t        let dir = TempDir::new().unwrap();\n2790\t        fs::write(dir.path().join(\"cpanfile\"), \"\").unwrap();\n2791\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Perl);\n2792\t    }\n2793\t\n2794\t    #[test]\n2795\t    fn test_detect_mixed_project() {\n2796\t        let dir = TempDir::new().unwrap();\n2797\t        fs::write(dir.path().join(\"Cargo.toml\"), \"\").unwrap();\n2798\t        fs::write(dir.path().join(\"package.json\"), \"{}\").unwrap();\n2799\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Mixed);\n2800\t    }\n2801\t\n2802\t    #[test]\n2803\t    fn test_detect_bsl_project_by_file() {\n2804\t        let dir = TempDir::new().unwrap();\n2805\t        fs::write(dir.path().join(\"module.bsl\"), \"\").unwrap();\n2806\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Bsl);\n2807\t    }\n2808\t\n2809\t    #[test]\n2810\t    fn test_detect_bsl_project_edt() {\n2811\t        let dir = TempDir::new().unwrap();\n2812\t        fs::create_dir_all(dir.path().join(\"src/Configuration\")).unwrap();\n2813\t        fs::write(dir.path().join(\"src/Configuration/Configuration.mdo\"), \"\").unwrap();\n2814\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Bsl);\n2815\t    }\n2816\t\n2817\t    #[test]\n2818\t    fn test_detect_csharp_project() {\n2819\t        let dir = TempDir::new().unwrap();\n2820\t        fs::write(dir.path().join(\"MyApp.sln\"), \"\").unwrap();\n2821\t        assert_eq!(detect_project_type(dir.path()), ProjectType::CSharp);\n2822\t    }\n2823\t\n2824\t    #[test]\n2825\t    fn test_detect_csharp_project_csproj() {\n2826\t        let dir = TempDir::new().unwrap();\n2827\t        fs::write(dir.path().join(\"MyApp.csproj\"), \"\").unwrap();\n2828\t        assert_eq!(detect_project_type(dir.path()), ProjectType::CSharp);\n2829\t    }\n2830\t\n2831\t    #[test]\n2832\t    fn test_detect_cpp_project() {\n2833\t        let dir = TempDir::new().unwrap();\n2834\t        fs::write(dir.path().join(\"CMakeLists.txt\"), \"\").unwrap();\n2835\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Cpp);\n2836\t    }\n2837\t\n2838\t    #[test]\n2839\t    fn test_detect_dart_project() {\n2840\t        let dir = TempDir::new().unwrap();\n2841\t        fs::write(dir.path().join(\"pubspec.yaml\"), \"\").unwrap();\n2842\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Dart);\n2843\t    }\n2844\t\n2845\t    #[test]\n2846\t    fn test_detect_php_project() {\n2847\t        let dir = TempDir::new().unwrap();\n2848\t        fs::write(dir.path().join(\"composer.json\"), \"{}\").unwrap();\n2849\t        assert_eq!(detect_project_type(dir.path()), ProjectType::PHP);\n2850\t    }\n2851\t\n2852\t    #[test]\n2853\t    fn test_detect_ruby_project() {\n2854\t        let dir = TempDir::new().unwrap();\n2855\t        fs::write(dir.path().join(\"Gemfile\"), \"\").unwrap();\n2856\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Ruby);\n2857\t    }\n2858\t\n2859\t    #[test]\n2860\t    fn test_detect_ruby_project_gemspec() {\n2861\t        let dir = TempDir::new().unwrap();\n2862\t        fs::write(dir.path().join(\"mylib.gemspec\"), \"\").unwrap();\n2863\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Ruby);\n2864\t    }\n2865\t\n2866\t    #[test]\n2867\t    fn test_detect_scala_project() {\n2868\t        let dir = TempDir::new().unwrap();\n2869\t        fs::write(dir.path().join(\"build.sbt\"), \"\").unwrap();\n2870\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Scala);\n2871\t    }\n2872\t\n2873\t    #[test]\n2874\t    fn test_detect_unknown_project() {\n2875\t        let dir = TempDir::new().unwrap();\n2876\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Unknown);\n2877\t    }\n2878\t\n2879\t    #[test]\n2880\t    fn test_excluded_dirs_contains_expected() {\n2881\t        assert!(EXCLUDED_DIRS.contains(&\"node_modules\"));\n2882\t        assert!(EXCLUDED_DIRS.contains(&\"build\"));\n2883\t        assert!(EXCLUDED_DIRS.contains(&\"target\"));\n2884\t        assert!(EXCLUDED_DIRS.contains(&\"bazel-out\"));\n2885\t        assert!(EXCLUDED_DIRS.contains(&\".gradle\"));\n2886\t        assert!(EXCLUDED_DIRS.contains(&\"Pods\"));\n2887\t        assert!(EXCLUDED_DIRS.contains(&\"DerivedData\"));\n2888\t    }\n2889\t\n2890\t    #[test]\n2891\t    fn test_parse_file_skips_large_files() {\n2892\t        let dir = TempDir::new().unwrap();\n2893\t        let large_file = dir.path().join(\"large.kt\");\n2894\t        let content = \"a\".repeat(1_100_000);\n2895\t        fs::write(&large_file, &content).unwrap();\n2896\t\n2897\t        let result = parse_file(dir.path(), &large_file).unwrap();\n2898\t        assert!(result.symbols.is_empty(), \"should skip large files\");\n2899\t        assert!(result.refs.is_empty());\n2900\t    }\n2901\t\n2902\t    #[test]\n2903\t    fn test_parse_file_kotlin() {\n2904\t        let dir = TempDir::new().unwrap();\n2905\t        let kt_file = dir.path().join(\"Test.kt\");\n2906\t        fs::write(&kt_file, \"class TestClass {\\n    fun doSomething() {}\\n}\\n\").unwrap();\n2907\t\n2908\t        let result = parse_file(dir.path(), &kt_file).unwrap();\n2909\t        assert!(result.symbols.iter().any(|s| s.name == \"TestClass\"));\n2910\t        assert!(result.symbols.iter().any(|s| s.name == \"doSomething\"));\n2911\t    }\n2912\t\n2913\t    #[test]\n2914\t    fn test_parse_file_swift() {\n2915\t        let dir = TempDir::new().unwrap();\n2916\t        let swift_file = dir.path().join(\"Test.swift\");\n2917\t        fs::write(&swift_file, \"class MyView: UIView {\\n    func setup() {}\\n}\\n\").unwrap();\n2918\t\n2919\t        let result = parse_file(dir.path(), &swift_file).unwrap();\n2920\t        assert!(result.symbols.iter().any(|s| s.name == \"MyView\"));\n2921\t        assert!(result.symbols.iter().any(|s| s.name == \"setup\"));\n2922\t    }\n2923\t\n2924\t    #[test]\n2925\t    fn test_parse_file_python() {\n2926\t        let dir = TempDir::new().unwrap();\n2927\t        let py_file = dir.path().join(\"test.py\");\n2928\t        fs::write(&py_file, \"class Service:\\n    def process(self):\\n        pass\\n\").unwrap();\n2929\t\n2930\t        let result = parse_file(dir.path(), &py_file).unwrap();\n2931\t        assert!(result.symbols.iter().any(|s| s.name == \"Service\"));\n2932\t        assert!(result.symbols.iter().any(|s| s.name == \"process\"));\n2933\t    }\n2934\t\n2935\t    #[test]\n2936\t    fn test_extract_py_list_strings() {\n2937\t        let body = r#\"\"foo>=1.0\", \"bar[extra]==2.0\", 'baz; python_version>=\"3.8\"'\"#;\n2938\t        let v = extract_py_list_strings(body);\n2939\t        assert_eq!(v.len(), 3);\n2940\t        assert_eq!(v[0], \"foo>=1.0\");\n2941\t        assert_eq!(v[1], \"bar[extra]==2.0\");\n2942\t    }\n2943\t\n2944\t    #[test]\n2945\t    fn test_strip_py_version() {\n2946\t        assert_eq!(strip_py_version(\"foo\"), \"foo\");\n2947\t        assert_eq!(strip_py_version(\"foo>=1.0\"), \"foo\");\n2948\t        assert_eq!(strip_py_version(\"foo[extra]==1.0\"), \"foo\");\n2949\t        assert_eq!(strip_py_version(\"foo ~= 2.0\"), \"foo\");\n2950\t        assert_eq!(strip_py_version(\"foo ; python_version>='3.8'\"), \"foo\");\n2951\t    }\n2952\t\n2953\t    #[test]\n2954\t    fn test_index_modules_ya_make() {\n2955\t        let dir = TempDir::new().unwrap();\n2956\t        let root = dir.path();\n2957\t        fs::create_dir_all(root.join(\"library/cpp/foo\")).unwrap();\n2958\t        fs::create_dir_all(root.join(\"app/main\")).unwrap();\n2959\t        fs::write(root.join(\"library/cpp/foo/ya.make\"), \"LIBRARY()\\nEND()\\n\").unwrap();\n2960\t        fs::write(\n2961\t            root.join(\"app/main/ya.make\"),\n2962\t            \"PROGRAM()\\nPEERDIR(\\n    library/cpp/foo\\n)\\nEND()\\n\",\n2963\t        )\n2964\t        .unwrap();\n2965\t\n2966\t        let conn = Connection::open_in_memory().unwrap();\n2967\t        db::init_db(&conn).unwrap();\n2968\t\n2969\t        let files = v