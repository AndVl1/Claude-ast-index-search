n2968\t        assert_eq!(strip_py_version(\"foo ~= 2.0\"), \"foo\");\n2969\t        assert_eq!(strip_py_version(\"foo ; python_version>='3.8'\"), \"foo\");\n2970\t    }\n2971\t\n2972\t    #[test]\n2973\t    fn test_index_modules_ya_make() {\n2974\t        let dir = TempDir::new().unwrap();\n2975\t        let root = dir.path();\n2976\t        fs::create_dir_all(root.join(\"library/cpp/foo\")).unwrap();\n2977\t        fs::create_dir_all(root.join(\"app/main\")).unwrap();\n2978\t        fs::write(root.join(\"library/cpp/foo/ya.make\"), \"LIBRARY()\\nEND()\\n\").unwrap();\n2979\t        fs::write(\n2980\t            root.join(\"app/main/ya.make\"),\n2981\t            \"PROGRAM()\\nPEERDIR(\\n    library/cpp/foo\\n)\\nEND()\\n\",\n2982\t        )\n2983\t        .unwrap();\n2984\t\n2985\t        let conn = Connection::open_in_memory().unwrap();\n2986\t        db::init_db(&conn).unwrap();\n2987\t\n2988\t        let files = vec![\n2989\t            root.join(\"library/cpp/foo/ya.make\"),\n2990\t            root.join(\"app/main/ya.make\"),\n2991\t        ];\n2992\t        index_modules_from_files(&conn, root, &files).unwrap();\n2993\t\n2994\t        let names: Vec<String> = conn\n2995\t            .prepare(\"SELECT name FROM modules ORDER BY name\")\n2996\t            .unwrap()\n2997\t            .query_map([], |r| r.get::<_, String>(0))\n2998\t            .unwrap()\n2999\t            .filter_map(|r| r.ok())\n3000\t            .collect();\n3001\t        assert!(names.contains(&\"library/cpp/foo\".to_string()));\n3002\t        assert!(names.contains(&\"app/main\".to_string()));\n3003\t    }\n3004\t\n3005\t    #[test]\n3006\t    fn test_index_deps_ya_make_peerdir() {\n3007\t        let dir = TempDir::new().unwrap();\n3008\t        let root = dir.path();\n3009\t        fs::create_dir_all(root.join(\"lib/a\")).unwrap();\n3010\t        fs::create_dir_all(root.join(\"lib/b\")).unwrap();\n3011\t        fs::create_dir_all(root.join(\"app\")).unwrap();\n3012\t        fs::write(root.join(\"lib/a/ya.make\"), \"LIBRARY()\\nEND()\\n\").unwrap();\n3013\t        fs::write(root.join(\"lib/b/ya.make\"), \"LIBRARY()\\nEND()\\n\").unwrap();\n3014\t        fs::write(\n3015\t            root.join(\"app/ya.make\"),\n3016\t            \"PROGRAM()\\nPEERDIR(\\n    lib/a\\n    lib/b\\n)\\nEND()\\n\",\n3017\t        )\n3018\t        .unwrap();\n3019\t\n3020\t        let mut conn = Connection::open_in_memory().unwrap();\n3021\t        db::init_db(&conn).unwrap();\n3022\t\n3023\t        let files = vec![\n3024\t            root.join(\"lib/a/ya.make\"),\n3025\t            root.join(\"lib/b/ya.make\"),\n3026\t            root.join(\"app/ya.make\"),\n3027\t        ];\n3028\t        index_modules_from_files(&conn, root, &files).unwrap();\n3029\t        let dep_count = index_module_dependencies(&mut conn, root, &files, false).unwrap();\n3030\t        assert_eq!(dep_count, 2);\n3031\t\n3032\t        let deps = get_module_deps(&conn, \"app\").unwrap();\n3033\t        let dep_names: Vec<String> = deps.iter().map(|(n, _, _)| n.clone()).collect();\n3034\t        assert!(dep_names.contains(&\"lib/a\".to_string()));\n3035\t        assert!(dep_names.contains(&\"lib/b\".to_string()));\n3036\t    }\n3037\t\n3038\t    #[test]\n3039\t    fn test_index_deps_gradle_standard_and_forma() {\n3040\t        // Two consumer modules in one fixture:\n3041\t        //   * feature/login uses the canonical Gradle `dependencies { implementation(project(...)) }`\n3042\t        //   * feature/profile uses the Forma-style `androidLibrary(dependencies = deps(...) + deps(project(...)))`\n3043\t        // Each consumer also lists external accessors (google.material, androidx.appcompat,\n3044\t        // test.junit, test.espresso) to confirm the regex does not false-match non-project entries.\n3045\t        // module_deps has no UNIQUE constraint, so the regex must produce exactly one edge per\n3046\t        // declaration — a previous version with two overlapping patterns silently doubled\n3047\t        // standard-form edges.\n3048\t        let dir = TempDir::new().unwrap();\n3049\t        let root = dir.path();\n3050\t        for sub in &[\"core/network\", \"core/database\", \"feature/login\", \"feature/profile\"] {\n3051\t            fs::create_dir_all(root.join(sub)).unwrap();\n3052\t        }\n3053\t        // Leaf targets — empty build files so they only register as modules.\n3054\t        fs::write(root.join(\"core/network/build.gradle.kts\"), \"\").unwrap();\n3055\t        fs::write(root.join(\"core/database/build.gradle.kts\"), \"\").unwrap();\n3056\t\n3057\t        // Standard Gradle consumer.\n3058\t        fs::write(\n3059\t            root.join(\"feature/login/build.gradle.kts\"),\n3060\t            r#\"\n3061\t            plugins {\n3062\t                id(\"com.android.library\")\n3063\t                kotlin(\"android\")\n3064\t            }\n3065\t            dependencies {\n3066\t                implementation(project(\":core:network\"))\n3067\t                implementation(\"androidx.appcompat:appcompat:1.6.1\")\n3068\t                testImplementation(\"junit:junit:4.13.2\")\n3069\t            }\n3070\t            \"#,\n3071\t        )\n3072\t        .unwrap();\n3073\t\n3074\t        // Forma DSL consumer — mirrors the syntax shown in the Forma README\n3075\t        // (https://github.com/formatools/forma): `dependencies = deps(...) + deps(project(...))`,\n3076\t        // plus testDependencies/androidTestDependencies.\n3077\t        fs::write(\n3078\t            root.join(\"feature/profile/build.gradle.kts\"),\n3079\t            r#\"\n3080\t            androidLibrary(\n3081\t                packageName = \"tools.forma.sample.profile\",\n3082\t                dependencies = deps(\n3083\t                    google.material,\n3084\t                    androidx.appcompat,\n3085\t                ) + deps(\n3086\t                    project(\":core:database\"),\n3087\t                ),\n3088\t                testDependencies = deps(\n3089\t