unwrap();\n2879\t        assert_eq!(detect_project_type(dir.path()), ProjectType::Unknown);\n2880\t    }\n2881\t\n2882\t    #[test]\n2883\t    fn test_excluded_dirs_contains_expected() {\n2884\t        assert!(EXCLUDED_DIRS.contains(&\"node_modules\"));\n2885\t        assert!(EXCLUDED_DIRS.contains(&\"build\"));\n2886\t        assert!(EXCLUDED_DIRS.contains(&\"target\"));\n2887\t        assert!(EXCLUDED_DIRS.contains(&\"bazel-out\"));\n2888\t        assert!(EXCLUDED_DIRS.contains(&\".gradle\"));\n2889\t        assert!(EXCLUDED_DIRS.contains(&\"Pods\"));\n2890\t        assert!(EXCLUDED_DIRS.contains(&\"DerivedData\"));\n2891\t    }\n2892\t\n2893\t    #[test]\n2894\t    fn test_parse_file_skips_large_files() {\n2895\t        let dir = TempDir::new().unwrap();\n2896\t        let large_file = dir.path().join(\"large.kt\");\n2897\t        let content = \"a\".repeat(1_100_000);\n2898\t        fs::write(&large_file, &content).unwrap();\n2899\t\n2900\t        let result = parse_file(dir.path(), &large_file).unwrap();\n2901\t        assert!(result.symbols.is_empty(), \"should skip large files\");\n2902\t        assert!(result.refs.is_empty());\n2903\t    }\n2904\t\n2905\t    #[test]\n2906\t    fn test_parse_file_kotlin() {\n2907\t        let dir = TempDir::new().unwrap();\n2908\t        let kt_file = dir.path().join(\"Test.kt\");\n2909\t        fs::write(&kt_file, \"class TestClass {\\n    fun doSomething() {}\\n}\\n\").unwrap();\n2910\t\n2911\t        let result = parse_file(dir.path(), &kt_file).unwrap();\n2912\t        assert!(result.symbols.iter().any(|s| s.name == \"TestClass\"));\n2913\t        assert!(result.symbols.iter().any(|s| s.name == \"doSomething\"));\n2914\t    }\n2915\t\n2916\t    #[test]\n2917\t    fn test_parse_file_swift() {\n2918\t        let dir = TempDir::new().unwrap();\n2919\t        let swift_file = dir.path().join(\"Test.swift\");\n2920\t        fs::write(&swift_file, \"class MyView: UIView {\\n    func setup() {}\\n}\\n\").unwrap();\n2921\t\n2922\t        let result = parse_file(dir.path(), &swift_file).unwrap();\n2923\t        assert!(result.symbols.iter().any(|s| s.name == \"MyView\"));\n2924\t        assert!(result.symbols.iter().any(|s| s.name == \"setup\"));\n2925\t    }\n2926\t\n2927\t    #[test]\n2928\t    fn test_parse_file_python() {\n2929\t        let dir = TempDir::new().unwrap();\n2930\t        let py_file = dir.path().join(\"test.py\");\n2931\t        fs::write(&py_file, \"class Service:\\n    def process(self):\\n        pass\\n\").unwrap();\n2932\t\n2933\t        let result = parse_file(dir.path(), &py_file).unwrap();\n2934\t        assert!(result.symbols.iter().any(|s| s.name == \"Service\"));\n2935\t        assert!(result.symbols.iter().any(|s| s.name == \"process\"));\n2936\t    }\n2937\t\n2938\t    #[test]\n2939\t    fn test_extract_py_list_strings() {\n2940\t        let body = r#\"\"foo>=1.0\", \"bar[extra]==2.0\", 'baz; python_version>=\"3.8\"'\"#;\n2941\t        let v = extract_py_list_strings(body);\n2942\t        assert_eq!(v.len(), 3);\n2943\t        assert_eq!(v[0], \"foo>=1.0\");\n2944\t        assert_eq!(v[1], \"bar[extra]==2.0\");\n2945\t    }\n2946\t\n2947\t    #[test]\n2948\t    fn test_strip_py_version() {\n2949\t        assert_eq!(strip_py_version(\"foo\"), \"foo\");\n2950\t        assert_eq!(strip_py_version(\"foo>=1.0\"), \"foo\");\n2951\t        assert_eq!(strip_py_version(\"foo[extra]==1.0\"), \"foo\");\n2952\t        assert_eq!(strip_py_version(\"foo ~= 2.0\"), \"foo\");\n2953\t        assert_eq!(strip_py_version(\"foo ; python_version>='3.8'\"), \"foo\");\n2954\t    }\n2955\t\n2956\t    #[test]\n2957\t    fn test_index_modules_ya_make() {\n2958\t        let dir = TempDir::new().unwrap();\n2959\t        let root = dir.path();\n2960\t        fs::create_dir_all(root.join(\"library/cpp/foo\")).unwrap();\n2961\t        fs::create_dir_all(root.join(\"app/main\")).unwrap();\n2962\t        fs::write(root.join(\"library/cpp/foo/ya.make\"), \"LIBRARY()\\nEND()\\n\").unwrap();\n2963\t        fs::write(\n2964\t            root.join(\"app/main/ya.make\"),\n2965\t            \"PROGRAM()\\nPEERDIR(\\n    library/cpp/foo\\n)\\nEND()\\n\",\n2966\t        )\n2967\t        .unwrap();\n2968\t\n2969\t        let conn = Connection::open_in_memory().unwrap();\n2970\t        db::init_db(&conn).unwrap();\n2971\t\n2972\t        let files = vec![\n2973\t            root.join(\"library/cpp/foo/ya.make\"),\n2974\t            root.join(\"app/main/ya.make\"),\n2975\t        ];\n2976\t        index_modules_from_files(&conn, root, &files).unwrap();\n2977\t\n2978\t        let names: Vec<String> = conn\n2979\t            .prepare(\"SELECT name FROM modules ORDER BY name\")\n2980\t            .unwrap()\n2981\t            .query_map([], |r| r.get::<_, String>(0))\n2982\t            .unwrap()\n2983\t            .filter_map(|r| r.ok())\n2984\t            .collect();\n2985\t        assert!(names.contains(&\"library/cpp/foo\".to_string()));\n2986\t        assert!(names.contains(&\"app/main\".to_string()));\n2987\t    }\n2988\t\n2989\t    #[test]\n2990\t    fn test_index_deps_ya_make_peerdir() {\n2991\t        let dir = TempDir::new().unwrap();\n2992\t        let root = dir.path();\n2993\t        fs::create_dir_all(root.join(\"lib/a\")).unwrap();\n2994\t        fs::create_dir_all(root.join(\"lib/b\")).unwrap();\n2995\t        fs::create_dir_all(root.join(\"app\")).unwrap();\n2996\t        fs::write(root.join(\"lib/a/ya.make\"), \"LIBRARY()\\nEND()\\n\").unwrap();\n2997\t        fs::write(root.join(\"lib/b/ya.make\"), \"LIBRARY()\\nEND()\\n\").unwrap();\n2998\t        fs::write(\n2999\t            root.join(\"app/ya.make\"),\n3000\t            \"PROGRAM()\\nPEERDIR(\\n    lib/a\\n    lib/b\\n)\\nEND()\\n\",\n3001\t        )\n3002\t        .unwrap();\n3003\t\n3004\t        let mut conn = Connection::open_in_memory().unwrap();\n3005\t        db::init_db(&conn).unwrap();\n3006\t\n3007\t        let files = vec![\n3008\t            root.join(\"lib/a/ya.make\"),\n3009\t            root.join(\"lib/b/ya.make\"),\n3010\t            root.join(\"app/ya.make\"),\n3011\t        ];\n3012\t        index_modules_from_files(&conn, root, &files).unwrap();\n3013\t        let dep_count = index_module_dependencies(&mut conn, root, &files, false).unwrap();\n3014\t        assert_eq!(dep_count, 2);\n3015\t\n3016\t        let deps = get_module_deps(&conn, \"app\").unwrap();\n3017\t        let dep_names: Vec<String> = deps.iter().map(|(n, _, _)| n.clone()).collect();\n3018\t        assert!(dep_names.contains(&\"lib/a\".to_string()));\n3019\t        assert!(dep_names.contains(&\"lib/b\".to_string()));\n3020\t    }\n3021\t\n3022\t    #[test]\n3023\t    fn test_index_deps_gradle_standard_and_forma() {\n3024\t        // Two consumer modules in one fixture:\n3025\t        //   * feature/login uses the canonical Gradle `dependencies { implementation(project(...)) }`\n3026\t        //   * feature/profile uses the Forma-style `androidLibrary(dependencies = deps(...) + deps(project(...)))`\n3027\t        // Each consumer also lists external accessors (google.material, androidx.appcompat,\n3028\t        // test.junit, test.espresso) to confirm the regex does not false-match non-project entries.\n3029\t        // module_deps has no UNIQUE constraint, so the regex must produce exactly one edge per\n3030\t        // declaration — a previous version with two overlapping patterns silently doubled\n3031\t        // standard-form edges.\n3032\t        let dir = TempDir::new().unwrap();\n3033\t        let root = dir.path();\n3034\t        for sub in &[\"core/network\", \"core/database\", \"feature/login\", \"feature/profile\"] {\n3035\t            fs::create_dir_all(root.join(sub)).unwrap();\n3036\t        }\n3037\t        // Leaf targets — empty build files so they only register as modules.\n3038\t        fs::write(root.join(\"core/network/build.gradle.kts\"), \"\").unwrap();\n3039\t        fs::write(root.join(\"core/database/build.gradle.kts\"), \"\").unwrap();\n3040\t\n3041\t        // Standard Gradle consumer.\n3042\t        fs::write(\n3043\t            root.join(\"feature/login/build.gradle.kts\"),\n3044\t            r#\"\n3045\t            plugins {\n3046\t                id(\"com.android.library\")\n3047\t                kotlin(\"android\")\n3048\t            }\n3049\t            dependencies {\n3050\t                implementation(project(\":core:network\"))\n3051\t                implementation(\"androidx.appcompat:appcompat:1.6.1\")\n3052\t                testImplementation(\"junit:junit:4.13.2\")\n3053\t            }\n3054\t            \"#,\n3055\t        )\n3056\t        .unwrap();\n3057\t\n3058\t        // Forma DSL consumer — mirrors the syntax shown in the Forma README\n3059\t        // (https://github.com/formatools/forma): `dependencies = deps(...) + deps(project(...))`,\n3060\t        // plus testDependencies/androidTestDependencies.\n3061\t        fs::write(\n3062\t            root.join(\"feature/profile/build.gradle.kts\"),\n3063\t            r#\"\n3064\t            androidLibrary(\n3065\t                packageName = \"tools.forma.sample.profile\",\n3066\t                dependencies = deps(\n3067\t                    google.material,\n3068\t                    androidx.appcompat,\n3069\t                ) + deps(\n3070\t                    project(\":core:database\"),\n3071\t                ),\n3072\t                testDependencies = deps(\n3073\t                    test.junit,\n3074\t                ),\n3075\t                androidTestDependencies = deps(\n3076\t                    test.espresso,\n3077\t                ),\n3078\t            )\n3079\t            \"#,\n3080\t        )\n3081\t        .unwrap();\n3082\t\n3083\t        let mut conn = Connection::open_in_memory().unwrap();\n3084\t        db::init_db(&conn).unwrap();\n3085\t\n3086\t        let files = vec![\n3087\t            root.join(\"core/network/build.gradle.kts\"),\n3088\t            root.join(\"core/database/build.gradle.kts\"),\n3089\t          